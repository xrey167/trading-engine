    if(value > 0 && plussign)
      price = "+" + price;
    if(nodigitsabove1000 && (value >= 1000 || value <= -1000) && digits > 0)
      price = _StringSubstr(price, 0, _StringLen(price) - digits - 1);
    if(fillzeros > 0) {
      int l = _StringLen(price);
      if(l < fillzeros) {
        string f = "000000";
        price = _StringSubstr(f, 0, fillzeros - l) + price;
      }
    }
    return price + suffix;
  }
  int                _CalcPointDigits(uint pointbase, uint pricedigits) {
    if(pointbase == 0)pointbase = _CalcPointBase(pricedigits);
    int d = (int)pricedigits;
    int p = (int)pointbase;
    while(p >= 10) {
      d--;
      p /= 10;
    }
    return::MathMax(0, d);
  }
  void               SDecimalSetup() {
    SetupPrice();
    SetupSize();
    SetupPercent();
    SetupCurrency();
    SetupCountry(currency_sign == "EUR");
  }
  void               SetupCountry(bool dotstyleeu) {
    country_dotseu = dotstyleeu;
  }
  void               SetupPrice(double ticksize = 0, uint pointbase = 0) {
    if(ticksize == 0)
      ticksize =::SymbolInfoDouble(::Symbol(), SYMBOL_TRADE_TICK_SIZE);
    price_minchange =::MathMax(0.0000001, ticksize);
    price_digits = _CalcDigits(price_minchange);
    if(pointbase == 0)
      pointbase = _CalcPointBase(price_digits);
    point_base = pointbase;
    point_digits = _CalcPointDigits(point_base, price_digits);
  }
  void               SetupCurrency(int digits = 0, string sign = NULL, bool sign_after = true) {
    if(digits == 0)
      digits = (int)::AccountInfoInteger(ACCOUNT_CURRENCY_DIGITS);
    if(sign == NULL)
      sign =::AccountInfoString(ACCOUNT_CURRENCY);
    currency_sign = sign;
    currency_digits = digits;
    currency_sign_after = sign_after;
    currency_minchange = _CalcMinChange(currency_digits);
  }
  void               SetupSize(double sizestepmin = 0) {
    if(sizestepmin == 0)
      sizestepmin =::SymbolInfoDouble(::Symbol(), SYMBOL_VOLUME_STEP);
    volume_minchange =::MathMax(0.00000001, sizestepmin);
    volume_digits = _CalcDigits(volume_minchange);
  }
  void               SetupPercent(uint digits = 0xFFFF) {
    if(digits == 0xFFFF)
      digits = 2;
    percent_digits =::MathMin(digits, 8);
    percent_minchange = _CalcMinChange(percent_digits);
  }
};
#define DECIMAL_DEFAULT_MAX 4
SDecimalSetup __DecimalDefault[DECIMAL_DEFAULT_MAX];
#define DECIMAL_BASE 0.00000001
