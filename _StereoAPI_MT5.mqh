    point_base = value;
    point_digits = __DecimalDefault[index]._CalcPointDigits(point_base, value_digits);
  }
  void               Points(double pointvalue) {
    value_base = DECIMAL_TOBASE(pointvalue / point_base);
  }
  double             Points(void) {
    return::NormalizeDouble(ToDouble() * point_base, point_digits);
  }
