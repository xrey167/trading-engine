    return m_bar.year;
  }
  int                Month(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.month;
  }
  int                Day(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.day;
  }
  int                Hour(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.hour;
  }
  int                Minute(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.minute;
  }
  int                Second(int shift = 0) {
