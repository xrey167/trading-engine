  if(ABS(add) > 59)
    return false;
  mm += add;
  if(mm < 0) {
    mm += 60;
    hh--;
    if(hh == -1)hh = 23;
  } else if(mm > 59) {
    mm -= 60;
    hh++;
    if(hh == 24)hh = 0;
  }
  return true;
}
