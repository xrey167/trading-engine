//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
long GetUnixTimestamp() {
  ulong fileTime[2] = {0, 0};
  GetSystemTimeAsFileTime(fileTime);
  ulong high = fileTime[1];
  ulong low = fileTime[0];
  ulong fileTime64 = (high << 32) | low;
  long unixTime = (long)(fileTime64 / 10000000) - 11644473600LL;
  return unixTime;
}
