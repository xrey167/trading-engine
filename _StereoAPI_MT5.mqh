public:
  void               ScaleScalping(double ticksize, double midprice = 0, int pixelspertick = 12, int scale = 4) {
    if(midprice == 0)
      midprice = __SymbolRaw.Last();
    if(midprice == 0)
      midprice = __SymbolRaw.Bid();
    if(midprice == 0)
      midprice = _iClose(NULL, PERIOD_CURRENT);
    double h = __Chart.MaxY();
    double v = (h * ticksize / pixelspertick);
    double min = midprice - (v / 2);
    double max = midprice + (v / 2);
    ScaleFix_11(false);
    ScaleFix(true);
    FixedMin(min);
    FixedMax(max);
    CChartBase::Scale(scale);
    Navigate(CHART_END);
    UpdateMetrics();
  }
public:
  void               ScaleCustom(double vzoom = 1.0, int scale = -1, double midprice = 0) {
    if(midprice == 0)
      midprice = __SymbolRaw.Last();
    if(midprice == 0)
      midprice = __SymbolRaw.Bid();
    if(midprice == 0)
      midprice = _iClose(NULL, PERIOD_CURRENT);
    double range = YToPrice(0) - YToPrice(HeightInPixels(0));
    ScaleFix_11(false);
    ScaleFix(true);
    FixedMin(midprice - range / (2 * vzoom));
    FixedMax(midprice + range / (2 * vzoom));
    if(scale != -1)
      CChartBase::Scale(scale);
    Navigate(CHART_END);
    UpdateMetrics();
  }
public:
  void               ScaleStandard(int scale = -1) {
    if(scale == -1)
      scale = Scale();
    ScaleFix_11(false);
    ScaleFix(false);
    CChartBase::Scale(scale);
    Navigate(CHART_END);
    UpdateMetrics();
  }
protected:
  void               VerifyShift(bool initialverify = false) {
    if(m_fixedshift < 0)
      return;
    if(m_fixedshift == 0) {
      if(Metrics.shift_status) {
        CChartBase::Shift(false);
        UpdateMetrics();
      }
      return;
    }
    double w = Metrics.width;
    double v = w > 0 ? (m_fixedshift * 100.0) / w : 0;
    int h = Metrics.height;
    m_validshift = !(w <= m_minwidth || h < m_minheight);
    if(!m_validshift) {
      if(Metrics.shift_status) {
        CChartBase::Shift(false);
        UpdateMetrics();
      }
      return;
    }
    if(v < 10)v = 10;
    bool changed = false;
    int s = (int)Metrics.shift_size;
    if(s < (int)v - 1 || (initialverify && s > (int)v + 1)) {
      CChartBase::ShiftSize(v);
      changed = true;
    }
    if(changed) {
      Navigate(CHART_END);
      UpdateMetrics();
    }
  }
