                     CChartExt(string prefix = NULL, CHART chartid = INVALID_CHART, bool cleanup_on_delete = false) {
    m_cleanup = cleanup_on_delete;
    m_varprefix = prefix;
    m_var_fixednames = false;
    m_fixedshift = -1;
    m_minwidth = 500;
    m_minheight = 300;
    Metrics.max_x = 0;
    Metrics.max_y = 0;
    m_hwndchart = 0;
    m_hwndmt = 0;
    m_validshift = true;
    m_metrics_changes = 0;
    m_metrics_init = false;
    m_colors_changes = 0;
    m_colors_init = false;
    m_timeframe = WRONG_VALUE;
    m_timeframename = NULL;
    m_classname = "CChartExt";
    if(chartid != INVALID_CHART)
      Attach(chartid);
    m_metrics_method = CHART_PROPERTIES_METHOD_NONE;
    m_colors_method = CHART_PROPERTIES_METHOD_NONE;
  }
                    ~CChartExt(void) {
    if(m_cleanup)
      DeleteAllVars();
    Detach();
  }
public:
  void               Attach(void) {
    Attach(__CHARTID);
