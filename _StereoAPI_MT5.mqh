class CScreenScale {
private:
  double             m_dpiscale_native;
  double             m_fontscale_native;
  double             m_fontscale;
  double             m_dpiscale;
  double             m_userscale;
public:
                     CScreenScale() {
    m_userscale = 1.0;
    Init();
  }
  void               Init() {
    double dpi = (double)__Terminal.ScreenDPI();
    if(dpi == 0) {
      m_dpiscale_native = 1.0;
      m_fontscale_native = 1.0;
    } else {
      m_fontscale_native = 96.0 / dpi;
      m_dpiscale_native = dpi / 96.0;
    }
    m_dpiscale = m_dpiscale_native * m_userscale;
    m_fontscale = m_userscale;
  }
  void               UserScale(double value) {
    m_userscale = value >= 0.1 ? value : 1.0;
    Init();
  }
  double             GetDPIScale() {
    return m_dpiscale_native;
  }
  double             GetFontScale() {
    return m_fontscale_native;
  }
  int                Font(double size) {
    return(int)MathRound(size * m_fontscale);
  }
  int                Font(int size) {
    return(int)MathRound((double)size * m_fontscale);
  }
  int                FontUnscale(double size) {
    return(int)MathRound(size / m_fontscale);
  }
  int                FontUnscale(int size) {
    return(int)MathRound((double)size / m_fontscale);
  }
  int                Int(int size) {
    return(int)MathRound((double)size * m_dpiscale);
  }
  int                Int(double size) {
    return(int)MathRound(size * m_dpiscale);
  }
  double             Double(double size) {
    return(size * m_dpiscale);
  }
  int                IntUnscale(int size) {
    return(int)MathRound((double)size / m_dpiscale);
  }
  double             DoubleUnscale(double size) {
    return MathRound((double)size / m_dpiscale);
  }
};
CScreenScale __Scale;
