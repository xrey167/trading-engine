private:
  void               _HwndInit(void) {
    m_hwndchart = 0;
    m_hwndmt = 0;
    m_hwndchart = (int)ChartGetInteger(m_chart_id, CHART_WINDOW_HANDLE);
    if(this.ChartId() != __CHARTID)
      return;
    if(m_hwndchart == 0)
      m_hwndchart = _FindChartWindow();
    if(m_hwndmt == 0)
      m_hwndmt =::user32::GetForegroundWindow();
  }
