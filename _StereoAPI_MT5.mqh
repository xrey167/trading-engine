class CSDialogContainer: public CWndContainer {
protected:
  bool               m_isdialog;
  ENUM_SPANEL_ALIGN  m_align;
  CPanel             m_panel;
  bool               m_opaque;
  CLabel             m_title;
  int                m_items;
  int                m_x_last;
  int                m_y_last;
  int                m_itemwidth;
  int                m_itemheight;
  bool               m_vertical;
  int                m_gap;
public:
                     CSDialogContainer(void): m_opaque(true) {
    m_classname = "CSDialogContainer";
    m_items = 0;
    m_gap = 4;
    m_x_last = SPANEL_GAP;
    m_y_last = SPANEL_GAP;
  }
public:
                    ~CSDialogContainer(void) {
  }
                     SYNC_CHILD_11(ColorBackground, color, m_panel.ColorBackground)
                     SYNC_CHILD_11(ColorBorder, color, m_panel.ColorBorder)
                     SYNC_CHILD_11(BorderType, ENUM_BORDER_TYPE, m_panel.BorderType)
protected:
  int                _GetYOffset() {
    if(__Chart.SubWindow() != 0)
      return 0;
    int n =::ObjectsTotal(m_chart_id, 0, OBJ_RECTANGLE_LABEL);
    string namelocalpanel = m_panel.Name();
    int p = _StringIndexOf(namelocalpanel, "#p");
    if(p < 0)return 0;
    int panellocal = (int)_StringSubstrFrom(namelocalpanel, p + 2);
    int slotlocal = __SD_Master.SEASlot();
    int cnt = 0, pos = -1, offset = 0;
    for(int i = n - 1; i >= 0; i--) {
      string name =::ObjectName(m_chart_id, i, 0, OBJ_RECTANGLE_LABEL);
      ENUM_OBJECT type = (ENUM_OBJECT)__MT_Object_GetType(m_chart_id, name);
      if(type == OBJ_RECTANGLE_LABEL && _StringIndexOf(name, SEAPANEL#") >= 0) {
        if(__MT_Object_IsVisible(m_chart_id, name)) {
          int pslot = _StringIndexOf(name, "#s");
          int ppanel = _StringIndexOfFrom(name, "#p", pslot);
          if(pslot < 0 || ppanel < 0)continue;
          int slotfound = (int)_StringSubstr(name, pslot + 2, ppanel - pslot - 2);
          int panelfound = (int)_StringSubstrFrom(name, ppanel + 2);
          if(slotlocal < slotfound || (slotlocal == slotfound && panelfound > panellocal)) {
            int w, h = 0;
            __MT_Object_XY_GetSize(m_chart_id, name, w, h);
            offset += h;
          }
          cnt++;
        }
      }
    }
    return offset + Height();
  }

public:
  bool               Opaque(void) {
    return m_opaque;
  }
public:
  bool               Opaque(const bool flag) {
    m_opaque = flag;
    if(IsVisible())
      m_panel.Visible(flag);
    return true;
  }
public:
  int                Gap(void) {
    return m_gap;
  }
public:
  bool               Gap(const int value) {
    m_gap = value;
    return true;
  }
protected:
  virtual bool       OnShow(void) {
    bool result = CWndContainer::OnShow();
    if(IsVisible() && !m_opaque)
      m_panel.Hide();
    if(m_isdialog)
      __Chart.Invalidate();
    return result;
  }
protected:
  virtual bool       OnResize(void) {
    if(!CWndContainer::OnResize())
      return false;
    m_panel.Size(Width(), Height());
    return true;
  }
protected:
  virtual bool       OnCreate(void) {
    if(!CWndContainer::OnCreate())
      return false;
    string id = __RNDID;
    if(!m_panel.Create(m_chart_id, id, m_subwin, 0, 0, Width() - 1, Height() - 1))
      return false;
    __MT_Object_SetToolTip(m_chart_id, m_name, NULL);
    Add(m_panel);
    return true;
  }
protected:
  virtual bool       OnApplyDesign(void) {
    CWndContainer::OnApplyDesign();
    ColorBackground(__m_clr_panel_bg);
    ColorBorder(__m_clr_panel_brd);
    BorderType(BORDER_FLAT);
