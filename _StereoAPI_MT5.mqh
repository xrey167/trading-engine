class CSLabel: public CLabel {
private:
  int                m_digits;
  string             m_postfix;
  string             m_prefix;
  color              m_clr_custom;
  color              m_clr_negative;
  color              m_clr_positive;
  color              m_clr_neutral;
  double             m_th;
  double             m_navalue;
  double             m_value;
  bool               m_showplussign;
  bool               m_autocolor;
public:
                     CSLabel() {
    m_classname = "CSLabel";
    m_digits = 0;
    m_th = 0;
    m_showplussign = false;
    m_navalue = PRICE_INVALID;
    m_clr_custom = clrNONE;
    m_autocolor = false;
  }
  bool               Value(double value) {
    m_value = value;
    if(value == m_navalue) {
      CLabel::Color(m_clr_neutral);
      return Text("n/a");
    }
    if(m_autocolor) {
      if(value < m_th)
        CLabel::Color(m_clr_negative);
      else if(value > m_th)
        CLabel::Color(m_clr_positive);
      else
        CLabel::Color(m_clr_neutral);
    } else
      CLabel::Color(m_clr_neutral);
    if(m_showplussign && value > 0)
      return Text(m_prefix + "+" + DoubleToString(value, m_digits) + m_postfix);
    else
      return Text(m_prefix + DoubleToString(value, m_digits) + m_postfix);
  }
  double             Value(void) {
    return m_value;
  }
  bool               NAValue(double value) {
    m_navalue = value;
    return true;
  }
  double             NAValue(void) {
    return m_navalue;
  }
  bool               Digits(int num) {
    m_digits = ABS(num);
    return true;
  }
  int                Digits(void) {
    return m_digits;
  }
  bool               ShowPlusSign(bool flag) {
    m_showplussign = flag;
    return true;
  }
  bool               ShowPlusSign(void) {
    return m_showplussign;
  }
  bool               Postfix(string v) {
    m_postfix = v;
    return true;
  }
  string             Postfix(void) {
    return m_postfix;
  }
  bool               Prefix(string v) {
    m_prefix = v;
    return true;
  }
  string             Prefix(void) {
    return m_prefix;
  }
  bool               Color(const color value) {
    m_clr_custom = value;
    if(!CLabel::Color(m_clr_custom))
      return false;
    m_clr_neutral = m_clr_custom;
    m_clr_negative = m_clr_custom;
    m_clr_positive = m_clr_custom;
    return true;
  }
  bool               AutoColor(double threshold, color negative, color positive, color neutral = clrNONE) {
    m_autocolor = true;
    m_th = threshold;
    if(neutral != clrNONE)
      m_clr_neutral = neutral;
    else
      m_clr_neutral = __m_clr_caption;
    m_clr_negative = negative;
    m_clr_positive = positive;
    return true;
  }
  bool               ToolTip(const string value = NULL) {
    return __MT_Object_SetToolTip(m_chart_id, m_name, value);
  }
protected:
  virtual bool       OnCreate(void) {
    ToolTip(NULL);
    CLabel::Font(SPANEL_FONTNAME);
    CLabel::FontSize(SPANEL_FONTSIZE_EDIT);
    m_clr_negative = __m_clr_bear;
    m_clr_positive = __m_clr_bull;
    m_clr_neutral = __m_clr_caption;
    return CLabel::OnCreate();
  }
  virtual bool       OnApplyDesign(void) {
    if(m_clr_custom == clrNONE)
      CLabel::Color(__m_clr_caption);
    return true;
  }
};
class CSEdit: public CEdit {
private:
  int                m_digits;
protected:
  bool               m_flagchange;
  bool               m_endedit;
  CSimpleDialog*m_panelcontainer;
public:
                     CSEdit() {
    m_classname = "CSEdit";
    m_digits = 0;
    m_flagchange = true;
    m_endedit = false;
  }
public:
  void               AssignDialog(CSimpleDialog*object) {
    m_panelcontainer = object;
    if(m_panelcontainer == NULL)
      return;
    if(SettingsID() == NULL)
      SettingsID(NULL);
  }
  bool               Save(const int file_handle) {
    return false;
  }
  bool               Load(const int file_handle) {
    return false;
  }
public:
  bool               _SettingsID(string id) {
    SettingsID(id);
    return true;
  }
  bool               OnSetStringValue(const string value) {
    return Text(value);
  }
  string             OnGetStringValue(void) {
    return Text();
  }
public:
  bool               ToolTip(const string value = NULL) {
    return __MT_Object_SetToolTip(m_chart_id, m_name, value);
  }
public:
  string             GetArg(int number, string separator = ";") {
    CArgStr args(Text() + separator, separator);
    return args.GetString(number);
  }
public:
  bool               IsEdited(void) {
    bool temp = m_endedit;
    m_endedit = false;
    return temp;
  }
  bool               _HasEvent(void) {
    return m_endedit;
  }
protected:
  virtual bool       OnCreate(void) {
    ToolTip(NULL);
    CEdit::Font(SPANEL_FONTNAME);
    CEdit::FontSize(SPANEL_FONTSIZE_EDIT);
    return CEdit::OnCreate();
  }
  virtual bool       OnEndEdit() {
    m_endedit = true;
    TextAlign(ALIGN_CENTER);
    if(m_flagchange && m_panelcontainer != NULL)
      m_panelcontainer._SetChanged(true);
    return true;
  }
  virtual void       OnMouseHOver(void) {
    static ENUM_ALIGN_MODE mode = WRONG_VALUE;
    if(IsMouseHOver()) {
      mode = m_align_mode;
      TextAlign(mode == ALIGN_LEFT ? ALIGN_CENTER : ALIGN_LEFT);
    } else
      TextAlign(mode);
    __Chart.Invalidate();
  }
protected:
  virtual bool       OnApplyDesign(void) {
    return Color(__m_clr_edit_fg) &&
           ColorBackground(__m_clr_edit_bg) &&
           ColorBorder(__m_clr_edit_brd);
  }
public:
  bool               NotifyOnChange(bool flag) {
    m_flagchange = flag;
    return true;
  }
  bool               NotifyOnChange(void) {
    return m_flagchange;
  }
  bool               IsEmpty(void) {
    string t = _StringTrim(m_text + "");
    StringReplace(t, "\n", "");
    StringReplace(t, "\r", "");
    return m_text == "";
  }
};
class CSNumEdit: public CSEdit {
private:
  int                m_digits;
  double             m_value;
  bool               m_allowempty;
  double             m_min;
  double             m_max;
public:
                     CSNumEdit() {
    m_classname = "CSNumEdit";
    m_digits = 0;
    m_min = -999999999;
    m_max = 999999999;
    m_allowempty = true;
  }
protected:
  virtual bool       OnSetStringValue(const string value) {
    return Value(StringToDouble(value));
  }
public:
  bool               Value(double value) {
    m_value = value;
    if(m_value == PRICE_INVALID) {
      if(m_allowempty)
        return Text("-");
      m_value = StringToDouble(DefaultValue());
    }
    m_value = MAX(m_value, m_min);
    m_value = MIN(m_value, m_max);
    return Text(DoubleToString(m_value, m_digits));
  }
  double             Value(void) {
    return m_value;
  }
  bool               Digits(int num) {
    m_digits = ABS(num);
    return true;
  }
  int                Digits(void) {
    return m_digits;
  }
  bool               AllowEmpty(void) {
    return m_allowempty;
  }
  bool               AllowEmpty(bool flag) {
    m_allowempty = flag;
    return true;
  }
  bool               MinValue(double v) {
    m_min = v;
    return true;
  }
  double             MinValue(void) {
    return m_min;
  }
  bool               MaxValue(double v) {
    m_max = v;
    return true;
  }
  double             MaxValue(void) {
    return m_max;
  }
  bool               IsEmpty(void) {
    return m_value == PRICE_INVALID;
  }
  bool               SetEmpty(void) {
    return Value(PRICE_INVALID);
  }
protected:
  virtual bool       OnEndEdit() {
    string text = Text();
    StringReplace(text, " ", "");
    if(text == "" || text == "-" || text == NULL)
      m_value = PRICE_INVALID;
    else
      m_value = (double)text;
    Value(m_value);
    m_endedit = true;
    if(m_flagchange && m_panelcontainer != NULL)
      m_panelcontainer._SetChanged(true);
    return true;
  }
};
class CSTimeEdit: public CSEdit {
private:
  int                m_h;
  int                m_m;
  string             m_value;
  bool               m_allowempty;
public:
                     CSTimeEdit() {
    m_classname = "CSTimeEdit";
    m_allowempty = true;
  }
protected:
  virtual bool       OnSetStringValue(const string value) {
    return this.Text(value);
  }
public:
  bool               Text(const string timestring) {
    int h, m;
    _StringToTime(timestring, h, m);
    return Value(h, m);
  }
  bool               Value(int hh, int mm) {
    m_h = hh;
    m_m = mm;
    if((m_h == -1 || m_m == -1) && !m_allowempty) {
      _StringToTime(DefaultValue(), m_h, m_m);
      if(m_h == -1) {
        m_h = 0;
        m_m = 0;
      }
    }
    m_value = _TimeToString(m_h, m_m);
    return CEdit::Text(m_value);
  }
  string             Text(void) {
    return m_value;
  }
  int                Hour(void) {
    return m_h;
  }
  int                Minute(void) {
    return m_m;
  }
  bool               AllowEmpty(void) {
    return m_allowempty;
  }
  bool               AllowEmpty(bool flag) {
    m_allowempty = flag;
    return true;
  }
  bool               IsEmpty(void) {
    return m_h == -1;
  }
  bool               SetEmpty(void) {
    return Value(-1, -1);
  }
protected:
  virtual bool       OnEndEdit() {
    string text = CSEdit::Text();
    StringReplace(text, " ", "");
    if(text == "" || text == "-" || text == NULL)
      this.Value(-1, -1);
    else
      this.Text(text);
    m_endedit = true;
    if(m_flagchange && m_panelcontainer != NULL)
      m_panelcontainer._SetChanged(true);
    return true;
  }
};
