//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CCanvas::LoadFromFile(const string filename) {
  if(!CCanvas::LoadBitmap(filename, m_pixels, m_width, m_height))
    return(false);
  if(m_format == COLOR_FORMAT_ARGB_RAW) {
    uchar a, r, g, b;
    int img_size = m_width * m_height;
    for(int i = 0; i < img_size; i++) {
      switch(a = GETRGBA(m_pixels[i])) {
      case 0xFF:
        break;
      case 0x00:
        m_pixels[i] = 0;
        break;
      default:
        r = GETRGBR(m_pixels[i]) * a / 255;
        g = GETRGBG(m_pixels[i]) * a / 255;
        b = GETRGBB(m_pixels[i]) * a / 255;
        m_pixels[i] = ARGB(a, r, g, b);
        break;
      }
    }
  }
  return(true);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CCanvas::LoadBitmap(const string filename, uint&data[], int&width, int&height) {
  struct BitmapHeader {
    ushort           type;
    uint             size;
    uint             reserv;
    uint             offbits;
    uint             imgSSize;
    uint             imgWidth;
    uint             imgHeight;
    ushort           imgPlanes;
    ushort           imgBitCount;
    uint             imgCompression;
    uint             imgSizeImage;
    uint             imgXPelsPerMeter;
    uint             imgYPelsPerMeter;
    uint             imgClrUsed;
    uint             imgClrImportant;
  };
  BitmapHeader header;
  bool result = true;
  CFileBin file;
  uint img_size;
  bool no_alpha, no_flip = false;
  uchar r, g, b;
  if(file.Open(filename, FILE_READ) == INVALID_HANDLE) {
    Print("File not found");
    return(false);
  }
  if(file.ReadStruct(header) != sizeof(header)) {
    Print("Failed to read file header");
    file.Close();
    return(false);
  }
  width = (int)header.imgWidth;
  height = (int)header.imgHeight;
  if(height < 0) {
    height = -height;
    no_flip = true;
  }
  if(header.imgBitCount == 32) {
    no_alpha = true;
    img_size = file.ReadArray(data);
    if(!no_flip)
      for(int i = 0; i < height / 2; i++) {
        uint tmp[];
        ArrayCopy(tmp, data, 0, width * i, width);
        ArrayCopy(data, data, width * i, width * (height - i - 1), width);
        ArrayCopy(data, tmp, width * (height - i - 1), 0, width);
      }
    for(uint i = 0; i < img_size; i++) {
      if(GETRGBA(data[i]) != 0) {
        no_alpha = false;
        break;
      }
    }
    if(no_alpha) {
      for(uint i = 0; i < img_size; i++)
        data[i] |= 0xFF000000;
    }
  } else {
    int byte_width;
    if(ArrayResize(data, width * height) != -1) {
      byte_width = width * 3;
      byte_width = (byte_width + 3) & ~3;
      uchar tmp[];
      for(int i = 0; i < height; i++) {
        if(file.ReadArray(tmp, 0, byte_width) != byte_width) {
          result = false;
          break;
        }
        for(int j = 0, k = 0, p = width * (height - i - 1); j < width; j++, p++, k += 3) {
          r = tmp[k + 2];
          g = tmp[k + 1];
          b = tmp[k];
          data[p] = XRGB(r, g, b);
        }
      }
    } else
      result = false;
  }
  file.Close();
  return(result);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
int CCanvas::PointClassify(const CPoint&p0, const CPoint&p1, const CPoint&p2) {
  return((p1.x - p0.x) * (p2.y - p0.y) - (p2.x - p0.x) * (p1.y - p0.y));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
int CCanvas::PolygonClassify(const CPoint&p[]) {
  int total = ArraySize(p);
  int im = 0;
  int xm = p[0].x;
  int ym = p[0].y;
  for(int i = 1; i < total; i++) {
    if(p[i].y > ym)
      continue;
    if((p[i].y == ym) && (p[i].x > xm))
      continue;
    im = i;
    xm = p[i].x;
    ym = p[i].y;
  }
  return PointClassify(p[(im - 1 + total) % total], p[im], p[(im + 1) % total]);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CCanvas::IsPolygonConvex(CPoint&p[]) {
  int total = ArraySize(p);
  if(total == 3)
    return(true);
  int res = SIGN(PointClassify(p[0], p[1], p[2]));
  for(int i = 1; i < total; i++) {
    int res1 = SIGN(PointClassify(p[i], p[(i + 1) % total], p[(i + 2) % total]));
    if(res != res1)
      return(false);
  }
  return(true);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonNormalize(CPoint&p[]) {
  int total = ArraySize(p);
  int imin = 0;
  int xmin = p[0].x;
  int ymin = p[0].y;
  for(int i = 1; i < total; i++) {
    if(p[i].y > ymin)
      continue;
    if(p[i].y == ymin) {
      if(p[i].x < xmin) {
        xmin = p[i].x;
        imin = i;
      }
      continue;
    }
    xmin = p[i].x;
    ymin = p[i].y;
    imin = i;
  }
  if(imin == 0)
    return;
  for(int i = 0; i < imin; i++) {
    CPoint tmp = p[0];
    ArrayCopy(p, p, 0, 1);
    p[total - 1] = tmp;
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonIntersect(CPoint&p[], CPoint&add[]) {
  int total = ArraySize(p);
  int res = SIGN(PolygonClassify(p));
  for(int i = 0; i < total; i++) {
    int rr = SIGN(PointClassify(p[i], p[(i + 1) % total], p[(i + 2) % total]));
    int rl = SIGN(PointClassify(p[(total - i - 2) % total], p[(total - i - 1) % total], p[(total - i) % total]));
    if(rl != res || rr != res) {
      res = (total - i - 1) - (i + 1);
      if(res < 0)
        return;
      if(res < 2) {
        ArrayResize(add, total - i);
        add[0] = p[0];
        ArrayCopy(add, p, 1, i + 1, total - i - 1);
        ArrayResize(p, i + 2);
      } else {
        ArrayResize(add, res + 1);
        ArrayCopy(add, p, 0, i + 1, res + 1);
        ArrayCopy(p, p, i + 2, i + res + 1, total - res - i - 1);
        ArrayResize(p, total - res + 1);
      }
      break;
    }
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonFill(CPoint&p[], const uint clr) {
  int il, ir;
  double xl, xr;
  int yy;
  double dl = 0.0, dr = 0.0;
  int total = ArraySize(p);
  if(total < 3)
    return;
  while(!IsPolygonConvex(p)) {
    CPoint add[];
    PolygonIntersect(p, add);
    PolygonNormalize(add);
    PolygonFill(add, clr);
    ArrayFree(add);
  }
  total = ArraySize(p);
  il = ir = 0;
  xl = xr = p[0].x;
  yy = p[0].y;
  if(yy == p[1].y)
    xr = p[ir = 1].x;
  LineHorizontal((int)MathCeil(xl), (int)MathFloor(xr), yy, clr);
  do {
    while(yy == p[il].y) {
      il = (il - 1 + total) % total;
      if(yy > p[il].y)
        return;
      if(yy != p[il].y) {
        dl = (p[il].x - xl) / (p[il].y - yy);
        LineHorizontal((int)MathCeil(xl + dl / 2), (int)MathFloor(xl), yy, clr);
        xl += dl / 2;
      } else
        LineHorizontal((int)MathCeil(xl), (int)MathFloor(p[il].x), yy, clr);
    }
    while(yy == p[ir].y) {
      ir = (ir + 1) % total;
      if(yy > p[ir].y)
        return;
      if(yy != p[ir].y) {
        dr = (p[ir].x - xr) / (p[ir].y - yy);
        LineHorizontal((int)MathCeil(xr), (int)MathFloor(xr + dr / 2), yy, clr);
        xr += dr / 2;
      } else
        LineHorizontal((int)MathCeil(p[ir].x), (int)MathFloor(xr), yy, clr);
    }
    yy++;
    if(yy == p[il].y)
      xl = p[il].x;
    else
      xl += dl;
    if(yy == p[ir].y)
      xr = p[ir].x;
    else
      xr += dr;
    LineHorizontal((int)MathCeil(xl), (int)MathFloor(xr), yy, clr);
  } while(il >= ir && ir != 0);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineWu(int x1, int y1, int x2, int y2, const uint clr, const uint style = UINT_MAX) {
  int dx = (x2 > x1) ? (x2 - x1) : (x1 - x2);
  int dy = (y2 > y1) ? (y2 - y1) : (y1 - y2);
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  int tmp;
  if(dx == 0) {
    if(y1 > y2) {
      tmp = y1;
      y1 = y2;
      y2 = tmp;
    }
    if(y2 < 0 || y1 >= m_height || x1 < 0 || x1 >= m_width) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(y1 < 0)
      y1 = 0;
    if(y2 >= m_height - 1)
      y2 = m_height - 1;
    int index = y1 * m_width + x1;
    for(int i = y1; i <= y2; i++, index += m_width) {
      if((m_style & mask) == mask)
        m_pixels[index] = clr;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if(style != UINT_MAX)
      m_style = prev_style;
    return;
  }
  if(dy == 0) {
    if(x1 > x2) {
      tmp = x1;
      x1 = x2;
      x2 = tmp;
    }
    if(x2 < 0 || x1 >= m_width || y1 < 0 || y1 >= m_height) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(x1 < 0)
      x1 = 0;
    if(x2 >= m_width)
      x2 = m_width - 1;
    for(int i = 0, index = y1 * m_width + x1; i < x2 - x1; i++, index++) {
      if((m_style & mask) == mask)
        m_pixels[index] = clr;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if(style != UINT_MAX)
      m_style = prev_style;
    return;
  }
  if(dx == 0 && dy == 0) {
    PixelSet(x1, y1, clr);
    if(style != UINT_MAX)
      m_style = prev_style;
    return;
  }
  if(dy < dx) {
    if(x2 < x1) {
      x2 += x1;
      x1 = x2 - x1;
      x2 -= x1;
      y2 += y1;
      y1 = y2 - y1;
      y2 -= y1;
    }
    if(y2 < y1) {
      dy *= -1;
    }
    float grad = (float)dy / dx;
    float intery = y1 + grad;
    if((m_style & mask) == mask)
      PixelSet(x1, y1, clr);
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
    for(int x = x1 + 1; x < x2; x++) {
      double alpha1 = 1 - (intery - (int)intery);
      double alpha2 = (intery - (int)intery);
      if((m_style & mask) == mask) {
        PixelTransform(x, (int)(intery), clr, alpha1);
        PixelTransform(x, (int)(intery) + 1, clr, alpha2);
      }
      intery += grad;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if((m_style & mask) == mask)
      PixelSet(x2, y2, clr);
  } else {
    if(y2 < y1) {
      x2 += x1;
      x1 = x2 - x1;
      x2 -= x1;
      y2 += y1;
      y1 = y2 - y1;
      y2 -= y1;
    }
    if(x2 < x1) {
      dx *= -1;
    }
    float grad = (float)dx / dy;
    float interx = x1 + grad;
    if((m_style & mask) == mask)
      PixelSet(x1, y1, clr);
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
    for(int y = y1 + 1; y < y2; y++) {
      double alpha1 = 1 - (interx - (int)interx);
      double alpha2 = (interx - (int)interx);
      if((m_style & mask) == mask) {
        PixelTransform((int)(interx), y, clr, alpha1);
        PixelTransform((int)(interx) + 1, y, clr, alpha2);
      }
      interx += grad;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if((m_style & mask) == mask)
      PixelSet(x2, y2, clr);
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolylineWu(const int&x[], const int&y[], const uint clr, const uint style = UINT_MAX) {
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  total--;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int i = 0; i < total; i++) {
    int x1 = x[i];
    int x2 = x[i + 1];
    int y1 = y[i];
    int y2 = y[i + 1];
    int dx = (x2 > x1) ? (x2 - x1) : (x1 - x2);
    int dy = (y2 > y1) ? (y2 - y1) : (y1 - y2);
    int tmp;
    if(dx == 0) {
      if(y1 > y2) {
        tmp = y1;
        y1 = y2;
        y2 = tmp;
      }
      if(y2 < 0 || y1 >= m_height || x1 < 0 || x1 >= m_width)
        continue;
      if(y1 < 0)
        y1 = 0;
      if(y2 >= m_height - 1)
        y2 = m_height - 1;
      int index = y1 * m_width + x1;
      for(int j = y1; j <= y2; j++, index += m_width) {
        if((m_style & mask) == mask)
          m_pixels[index] = clr;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      continue;
    }
    if(dy == 0) {
      if(x1 > x2) {
        tmp = x1;
        x1 = x2;
        x2 = tmp;
      }
      if(x2 < 0 || x1 >= m_width || y1 < 0 || y1 >= m_height)
        continue;
      if(x1 < 0)
        x1 = 0;
      if(x2 >= m_width)
        x2 = m_width - 1;
      for(int j = 0, index = y1 * m_width + x1; j < x2 - x1; j++, index++) {
        if((m_style & mask) == mask)
          m_pixels[index] = clr;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      continue;
    }
    if(dx == 0 && dy == 0) {
      PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      continue;
    }
    if(dy < dx) {
      if(x2 < x1) {
        x2 += x1;
        x1 = x2 - x1;
        x2 -= x1;
        y2 += y1;
        y1 = y2 - y1;
        y2 -= y1;
      }
      if(y2 < y1) {
        dy *= -1;
      }
      float grad = (float)dy / dx;
      float intery = y1 + grad;
      if((m_style & mask) == mask)
        PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      for(int xc = x1 + 1; xc < x2; xc++) {
        double alpha1 = 1 - (intery - (int)intery);
        double alpha2 = (intery - (int)intery);
        if((m_style & mask) == mask) {
          PixelTransform(xc, (int)(intery), clr, alpha1);
          PixelTransform(xc, (int)(intery) + 1, clr, alpha2);
        }
        intery += grad;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if((m_style & mask) == mask)
        PixelSet(x2, y2, clr);
    } else {
      if(y2 < y1) {
        x2 += x1;
        x1 = x2 - x1;
        x2 -= x1;
        y2 += y1;
        y1 = y2 - y1;
        y2 -= y1;
      }
      if(x2 < x1) {
        dx *= -1;
      }
      float grad = (float)dx / dy;
      float interx = x1 + grad;
      if((m_style & mask) == mask)
        PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      for(int yc = y1 + 1; yc < y2; yc++) {
        double alpha1 = 1 - (interx - (int)interx);
        double alpha2 = (interx - (int)interx);
        if((m_style & mask) == mask) {
          PixelTransform((int)(interx), yc, clr, alpha1);
          PixelTransform((int)(interx) + 1, yc, clr, alpha2);
        }
        interx += grad;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if((m_style & mask) == mask)
        PixelSet(x2, y2, clr);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonWu(const int&x[], const int&y[], const uint clr, const uint style = UINT_MAX) {
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int i = 0; i < total; i++) {
    int x1 = x[i];
    int y1 = y[i];
    int x2 = (i + 1 != total) ? x[i + 1] : x[0];
    int y2 = (i + 1 != total) ? y[i + 1] : y[0];
    int dx = (x2 > x1) ? (x2 - x1) : (x1 - x2);
    int dy = (y2 > y1) ? (y2 - y1) : (y1 - y2);
    int tmp;
    if(dx == 0) {
      if(y1 > y2) {
        tmp = y1;
        y1 = y2;
        y2 = tmp;
      }
      if(y2 < 0 || y1 >= m_height || x1 < 0 || x1 >= m_width)
        continue;
      if(y1 < 0)
        y1 = 0;
      if(y2 >= m_height - 1)
        y2 = m_height - 1;
      int index = y1 * m_width + x1;
      for(int j = y1; j <= y2; j++, index += m_width) {
        if((m_style & mask) == mask)
          m_pixels[index] = clr;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      continue;
    }
    if(dy == 0) {
      if(x1 > x2) {
        tmp = x1;
        x1 = x2;
        x2 = tmp;
      }
      if(x2 < 0 || x1 >= m_width || y1 < 0 || y1 >= m_height)
        continue;
      if(x1 < 0)
        x1 = 0;
      if(x2 >= m_width)
        x2 = m_width - 1;
      for(int j = 0, index = y1 * m_width + x1; j < x2 - x1; j++, index++) {
        if((m_style & mask) == mask)
          m_pixels[index] = clr;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      continue;
    }
    if(dx == 0 && dy == 0) {
      PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      continue;
    }
    if(dy < dx) {
      if(x2 < x1) {
        x2 += x1;
        x1 = x2 - x1;
        x2 -= x1;
        y2 += y1;
        y1 = y2 - y1;
        y2 -= y1;
      }
      if(y2 < y1) {
        dy *= -1;
      }
      float grad = (float)dy / dx;
      float intery = y1 + grad;
      if((m_style & mask) == mask)
        PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      for(int xc = x1 + 1; xc < x2; xc++) {
        double alpha1 = 1 - (intery - (int)intery);
        double alpha2 = (intery - (int)intery);
        if((m_style & mask) == mask) {
          PixelTransform(xc, (int)(intery), clr, alpha1);
          PixelTransform(xc, (int)(intery) + 1, clr, alpha2);
        }
        intery += grad;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if((m_style & mask) == mask)
        PixelSet(x2, y2, clr);
    } else {
      if(y2 < y1) {
        x2 += x1;
        x1 = x2 - x1;
        x2 -= x1;
        y2 += y1;
        y1 = y2 - y1;
        y2 -= y1;
      }
      if(x2 < x1) {
        dx *= -1;
      }
      float grad = (float)dx / dy;
      float interx = x1 + grad;
      if((m_style & mask) == mask)
        PixelSet(x1, y1, clr);
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
      for(int yc = y1 + 1; yc < y2; yc++) {
        double alpha1 = 1 - (interx - (int)interx);
        double alpha2 = (interx - (int)interx);
        if((m_style & mask) == mask) {
          PixelTransform((int)(interx), yc, clr, alpha1);
          PixelTransform((int)(interx) + 1, yc, clr, alpha2);
        }
        interx += grad;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if((m_style & mask) == mask)
        PixelSet(x2, y2, clr);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::TriangleWu(const int x1, const int y1, const int x2, const int y2, const int x3, const int y3, const uint clr, const uint style = UINT_MAX) {
  int x[3];
  int y[3];
  x[0] = x1;
  x[1] = x2;
  x[2] = x3;
  y[0] = y1;
  y[1] = y2;
  y[2] = y3;
  PolygonWu(x, y, clr, style);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::CircleWu(const int x, const int y, const double r, const uint clr, const uint style = UINT_MAX) {
  if(r <= 0)
    return;
  double r2 = r * r;
  double quarter = round(r / sqrt(2.0));
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int d1 = 0; d1 <= quarter; d1++) {
    double d2 = sqrt(r2 - d1 * d1);
    double alpha1 = d2 - floor(d2);
    double alpha2 = 1 - alpha1;
    if((m_style & mask) == mask) {
      PixelTransform4(x, y, (int)d2 + 1, d1, clr, alpha1);
      PixelTransform4(x, y, d1, (int)(d2) + 1, clr, alpha1);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
    if((m_style & mask) == mask) {
      PixelTransform4(x, y, d1, (int)(d2), clr, alpha2);
      PixelTransform4(x, y, (int)d2, d1, clr, alpha2);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::EllipseWu(const int x1, const int y1, const int x2, const int y2, const uint clr, const uint style = UINT_MAX) {
  int rx = (int)(x2 - x1) / 2;
  int ry = (int)(y2 - y1) / 2;
  int x = (x2 > x1) ? x1 + rx : x2 + rx;
  int y = (y2 > y1) ? y1 + ry : y2 + ry;
  if(rx <= 0 || ry <= 0)
    return;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  double rx2 = rx * rx;
  double ry2 = ry * ry;
  double quarter = round(rx2 / sqrt(rx2 + ry2));
  for(int dx = 0; dx <= quarter; dx++) {
    double dy = ry * sqrt(1 - dx * dx / rx2);
    double alpha1 = dy - floor(dy);
    double alpha2 = 1 - alpha1;
    if((m_style & mask) == mask) {
      PixelTransform4(x, y, dx, (int)(dy) + 1, clr, alpha1);
      PixelTransform4(x, y, dx, (int)(dy), clr, alpha2);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  quarter = round(ry2 / sqrt(rx2 + ry2));
  for(int dy = 0; dy <= quarter; dy++) {
    double dx = rx * sqrt(1 - dy * dy / ry2);
    double alpha1 = dx - floor(dx);
    double alpha2 = 1 - alpha1;
    if((m_style & mask) == mask) {
      PixelTransform4(x, y, (int)(dx) + 1, dy, clr, alpha1);
      PixelTransform4(x, y, (int)(dx), dy, clr, alpha2);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineThickVertical(const int x, const int y1, const int y2, const uint clr, const int size, const uint style, ENUM_LINE_END end_style) {
  if(size <= 2) {
    if(size > 0)
      LineWu(x, y1, x, y2, clr, style);
    return;
  }
  double r = (size / 2.0);
  int dy = MathAbs(y2 - y1);
  int sign = (y1 < y2) ? 1 : -1;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  if(style == STYLE_SOLID) {
    SegmentVertical(x, y1, y2, sign, r, clr, end_style);
  } else {
    int ys = 0;
    int ye = 0;
    int steps = (int)MathRound(dy / r);
    bool segment = false;
    for(int i = 0; i <= steps; i++) {
      if((m_style & mask) == mask && !segment) {
        ys = y1 + (sign) * (int)(i * r);
        segment = true;
      } else if((m_style & mask) != mask && segment) {
        ye = y1 + (sign) * (int)(i * r);
        SegmentVertical(x, ys, ye, sign, r, clr, end_style);
        segment = false;
      }
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if(segment)
      SegmentVertical(x, ys, y2, sign, r, clr, end_style);
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineThickHorizontal(const int x1, const int x2, const int y, const uint clr, const int size, const uint style, ENUM_LINE_END end_style) {
  if(size <= 2) {
    if(size > 0)
      LineWu(x1, y, x2, y, clr, style);
    return;
  }
  double r = (size / 2.0);
  int dx = MathAbs(x2 - x1);
  int sign = (x1 < x2) ? 1 : -1;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  if(style == STYLE_SOLID) {
    SegmentHorizontal(x1, x2, y, sign, r, clr, end_style);
  } else {
    int xs = 0;
    int xe = 0;
    int steps = (int)MathRound(dx / r);
    bool segment = false;
    for(int i = 0; i <= steps; i++) {
      if((m_style & mask) == mask && !segment) {
        xs = x1 + (sign) * (int)(i * r);
        segment = true;
      } else if((m_style & mask) != mask && segment) {
        xe = x1 + (sign) * (int)(i * r);
        SegmentHorizontal(xs, xe, y, sign, r, clr, end_style);
        segment = false;
      }
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if(segment)
      SegmentHorizontal(xs, x2, y, sign, r, clr, end_style);
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineThick(const int x1, const int y1, const int x2, const int y2, const uint clr, const int size, const uint style, ENUM_LINE_END end_style) {
  if(size <= 2) {
    if(size > 0)
      LineWu(x1, y1, x2, y2, clr, style);
    return;
  }
  double r = (size / 2.0);
  double dx = MathAbs(x2 - x1);
  double dy = MathAbs(y2 - y1);
  if(dx == 0) {
    LineThickVertical(x1, y1, y2, clr, size, style, end_style);
    return;
  }
  if(dy == 0) {
    LineThickHorizontal(x1, x2, y1, clr, size, style, end_style);
    return;
  }
  double k = MathArctan(dx / dy);
  double rcos_k = r * cos(k);
  double rsin_k = r * sin(k);
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  int xsign = (x1 < x2) ? 1 : -1;
  int ysign = (y1 < y2) ? 1 : -1;
  double kp0 = (-xsign * ysign) * (dx / dy);
  double kp1 = -1 / kp0;
  if(style == STYLE_SOLID) {
    Segment(x1, y1, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
  } else {
    int xs = 0;
    int ys = 0;
    int xe = 0;
    int ye = 0;
    double length = MathSqrt(dx * dx + dy * dy);
    int steps = (int)MathRound(length / r);
    bool segment = false;
    for(int i = 0; i <= steps; i++) {
      if((m_style & mask) == mask && !segment) {
        xs = x1 + (xsign) * (int)(i * rsin_k);
        ys = y1 + (ysign) * (int)(i * rcos_k);
        segment = true;
      } else if((m_style & mask) != mask && segment) {
        xe = x1 + (xsign) * (int)(i * rsin_k);
        ye = y1 + (ysign) * (int)(i * rcos_k);
        Segment(xs, ys, xe, ye, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
        segment = false;
      }
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    }
    if(segment)
      Segment(xs, ys, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolylineThick(const int&x[], const int&y[], const uint clr, const int size, const uint style, ENUM_LINE_END end_style) {
  if(size <= 2) {
    if(size > 0)
      PolylineWu(x, y, clr, style);
    return;
  }
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  total--;
  double r = (size / 2.0);
  double gap = 1.0;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int index = 0; index < total; index++) {
    int x1 = x[index];
    int y1 = y[index];
    int x2 = x[index + 1];
    int y2 = y[index + 1];
    double dx = MathAbs(x2 - x1);
    double dy = MathAbs(y2 - y1);
    if(dx == 0) {
      int sign = (y1 < y2) ? 1 : -1;
      if(style == STYLE_SOLID) {
        SegmentVertical(x1, y1, y2, sign, r, clr, end_style);
      } else {
        int ys = y1;
        int ye = 0;
        double steps = dy / r;
        int isteps = (int)steps;
        bool segment = false;
        for(int i = 0; i < isteps; i++) {
          if((m_style & mask) == mask && !segment) {
            ys = y1 + (sign) * (int)(i * r);
            segment = true;
          } else if((m_style & mask) != mask && segment) {
            ye = y1 + (sign) * (int)(i * r);
            SegmentVertical(x1, ys, ye, sign, r, clr, end_style);
            segment = false;
          }
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
        if(segment || (steps < 1 && (m_style & mask) == mask))
          SegmentVertical(x1, ys, y2, sign, r, clr, end_style);
        gap -= steps - isteps;
        if(gap < 0) {
          gap++;
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
      }
      continue;
    }
    if(dy == 0) {
      int sign = (x1 < x2) ? 1 : -1;
      if(style == STYLE_SOLID) {
        SegmentHorizontal(x1, x2, y1, sign, r, clr, end_style);
      } else {
        int xs = x1;
        int xe = 0;
        double steps = dx / r;
        int isteps = (int)steps;
        bool segment = false;
        for(int i = 0; i < isteps; i++) {
          if((m_style & mask) == mask && !segment) {
            xs = x1 + (sign) * (int)(i * r);
            segment = true;
          } else if((m_style & mask) != mask && segment) {
            xe = x1 + (sign) * (int)(i * r);
            SegmentHorizontal(xs, xe, y1, sign, r, clr, end_style);
            segment = false;
          }
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
        if(segment || (steps < 1 && (m_style & mask) == mask))
          SegmentHorizontal(xs, x2, y1, sign, r, clr, end_style);
        gap -= steps - isteps;
        if(gap < 0) {
          gap++;
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
      }
      continue;
    }
    double k = MathArctan(dx / dy);
    double rcos_k = r * cos(k);
    double rsin_k = r * sin(k);
    int xsign = (x1 < x2) ? 1 : -1;
    int ysign = (y1 < y2) ? 1 : -1;
    double kp0 = (-xsign * ysign) * (dx / dy);
    double kp1 = -1 / kp0;
    if(style == STYLE_SOLID) {
      Segment(x1, y1, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
    } else {
      int xs = x1;
      int ys = y1;
      int xe = 0;
      int ye = 0;
      double length = MathSqrt(dx * dx + dy * dy);
      double steps = length / r;
      int isteps = (int)steps;
      bool segment = false;
      for(int i = 0; i < isteps; i++) {
        if((m_style & mask) == mask && !segment) {
          xs = x1 + (xsign) * (int)(i * rsin_k);
          ys = y1 + (ysign) * (int)(i * rcos_k);
          segment = true;
        } else if((m_style & mask) != mask && segment) {
          xe = x1 + (xsign) * (int)(i * rsin_k);
          ye = y1 + (ysign) * (int)(i * rcos_k);
          Segment(xs, ys, xe, ye, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
          segment = false;
        }
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if(segment || (steps < 1 && (m_style & mask) == mask))
        Segment(xs, ys, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
      gap -= steps - isteps;
      if(gap < 0) {
        gap++;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
    }
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonThick(const int&x[], const int&y[], const uint clr, const int size, const uint style, ENUM_LINE_END end_style) {
  if(size <= 2) {
    if(size > 0)
      PolylineWu(x, y, clr, style);
    return;
  }
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  double r = (size / 2.0);
  double gap = 1.0;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int index = 0; index < total; index++) {
    int x1 = x[index];
    int y1 = y[index];
    int x2 = (index != total - 1) ? x[index + 1] : x[0];
    int y2 = (index != total - 1) ? y[index + 1] : y[0];
    double dx = MathAbs(x2 - x1);
    double dy = MathAbs(y2 - y1);
    if(dx == 0) {
      int sign = (y1 < y2) ? 1 : -1;
      if(style == STYLE_SOLID) {
        SegmentVertical(x1, y1, y2, sign, r, clr, end_style);
      } else {
        int ys = y1;
        int ye = 0;
        double steps = dy / r;
        int isteps = (int)steps;
        bool segment = false;
        for(int i = 0; i < isteps; i++) {
          if((m_style & mask) == mask && !segment) {
            ys = y1 + (sign) * (int)(i * r);
            segment = true;
          } else if((m_style & mask) != mask && segment) {
            ye = y1 + (sign) * (int)(i * r);
            SegmentVertical(x1, ys, ye, sign, r, clr, end_style);
            segment = false;
          }
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
        if(segment || (steps < 1 && (m_style & mask) == mask))
          SegmentVertical(x1, ys, y2, sign, r, clr, end_style);
        gap -= steps - isteps;
        if(gap < 0) {
          gap++;
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
      }
      continue;
    }
    if(dy == 0) {
      int sign = (x1 < x2) ? 1 : -1;
      if(style == STYLE_SOLID) {
        SegmentHorizontal(x1, x2, y1, sign, r, clr, end_style);
      } else {
        int xs = x1;
        int xe = 0;
        double steps = dx / r;
        int isteps = (int)steps;
        bool segment = false;
        for(int i = 0; i < isteps; i++) {
          if((m_style & mask) == mask && !segment) {
            xs = x1 + (sign) * (int)(i * r);
            segment = true;
          } else if((m_style & mask) != mask && segment) {
            xe = x1 + (sign) * (int)(i * r);
            SegmentHorizontal(xs, xe, y1, sign, r, clr, end_style);
            segment = false;
          }
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
        if(segment || (steps < 1 && (m_style & mask) == mask))
          SegmentHorizontal(xs, x2, y1, sign, r, clr, end_style);
        gap -= steps - isteps;
        if(gap < 0) {
          gap++;
          mask <<= 1;
          if(mask == 0x1000000)
            mask = 1;
        }
      }
      continue;
    }
    double k = MathArctan(dx / dy);
    double rcos_k = r * cos(k);
    double rsin_k = r * sin(k);
    int xsign = (x1 < x2) ? 1 : -1;
    int ysign = (y1 < y2) ? 1 : -1;
    double kp0 = (-xsign * ysign) * (dx / dy);
    double kp1 = -1 / kp0;
    if(style == STYLE_SOLID) {
      Segment(x1, y1, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
    } else {
      int xs = x1;
      int ys = y1;
      int xe = 0;
      int ye = 0;
      double length = MathSqrt(dx * dx + dy * dy);
      double steps = length / r;
      int isteps = (int)steps;
      bool segment = false;
      for(int i = 0; i < isteps; i++) {
        if((m_style & mask) == mask && !segment) {
          xs = x1 + (xsign) * (int)(i * rsin_k);
          ys = y1 + (ysign) * (int)(i * rcos_k);
          segment = true;
        } else if((m_style & mask) != mask && segment) {
          xe = x1 + (xsign) * (int)(i * rsin_k);
          ye = y1 + (ysign) * (int)(i * rcos_k);
          Segment(xs, ys, xe, ye, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
          segment = false;
        }
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
      if(segment || (steps < 1 && (m_style & mask) == mask))
        Segment(xs, ys, x2, y2, kp0, kp1, xsign, ysign, rcos_k, rsin_k, r, clr, end_style);
      gap -= steps - isteps;
      if(gap < 0) {
        gap++;
        mask <<= 1;
        if(mask == 0x1000000)
          mask = 1;
      }
    }
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CCanvas::PixelsSimilar(const uint clr0, const uint clr1, const uint threshould) {
  uint dr = MathAbs(uint((clr0 >> 16) & 0xff) -
                    uint((clr1 >> 16) & 0xff));
  uint dg = MathAbs(uint((clr0 >> 8) & 0xff) -
                    uint((clr1 >> 8) & 0xff));
  uint db = MathAbs(uint((clr0 >> 0) & 0xff) -
                    uint((clr1 >> 0) & 0xff));
  return(dr <= threshould || dg <= threshould || db <= threshould);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PixelTransform(const int x, const int y, const uint clr, const double alpha) {
  int index = y * m_width + x;
  if(x < 0 || y < 0 || x > m_width || y > m_height || index >= ArraySize(m_pixels))
    return;
  if(alpha == 1) {
    m_pixels[index] = clr;
    return;
  }
  uint clr0 = m_pixels[index];
  double r0 = ((clr0 >> 16) & 0xFF) * (1.0 - alpha);
  double g0 = ((clr0 >> 8) & 0xFF) * (1.0 - alpha);
  double b0 = ((clr0 >> 0) & 0xFF) * (1.0 - alpha);
  double r1 = ((clr >> 16) & 0xFF) * (alpha);
  double g1 = ((clr >> 8) & 0xFF) * (alpha);
  double b1 = ((clr >> 0) & 0xFF) * (alpha);
  int r = (int)(r0 + r1);
  int g = (int)(g0 + g1);
  int b = (int)(b0 + b1);
  m_pixels[y * m_width + x] = ((r << 16) | (g << 8) | (b << 0) | (255 << 24));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PixelTransform4(const int x, const int y, const int dx, const int dy, const uint clr, const double alpha) {
  PixelTransform(x + dx, y + dy, clr, alpha);
  PixelTransform(x - dx, y + dy, clr, alpha);
  PixelTransform(x + dx, y - dy, clr, alpha);
  PixelTransform(x - dx, y - dy, clr, alpha);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PixelSet4AA(const double x, const double y, const double dx, const double dy, const uint clr) {
  PixelSetAA(x + dx, y + dy, clr);
  PixelSetAA(x - dx, y + dy, clr);
  PixelSetAA(x + dx, y - dy, clr);
  PixelSetAA(x - dx, y - dy, clr);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::SegmentVertical(const int x, const int y1, const int y2, const int ysign, const double r, const uint clr, ENUM_LINE_END end_style) {
  int ye1, ye2;
  int ys1, ys2;
  switch(end_style) {
  case LINE_END_ROUND: {
    ye1 = y1;
    ye2 = y2;
    ys1 = y1 - (int)(ysign * r);
    ys2 = y2 + (int)(ysign * r);
    break;
  }
  case LINE_END_BUTT: {
    ye1 = y1;
    ye2 = y2;
    ys1 = y1;
    ys2 = y2;
    break;
  }
  case LINE_END_SQUARE: {
    ye1 = y1 - (int)(ysign * r);
    ye2 = y2 + (int)(ysign * r);
    ys1 = ye1;
    ys2 = ye2;
    break;
  }
  default:
    return;
  };
  for(int i = 0; i <= MathAbs(ys2 - ys1); i++) {
    double yi = ys1 + (ysign * i);
    for(int j = 0; j < 2 * r; j++) {
      double xi = x - r + j;
      double dist = DistancePointSegment(xi, yi, x, ye1, x, ye2);
      double val = MathAbs(dist / r);
      PixelTransform((int)xi, (int)yi, clr, FilterFunction(val));
    }
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::SegmentHorizontal(const int x1, const int x2, const int y, const int xsign, const double r, const uint clr, ENUM_LINE_END end_style) {
  int xe1, xe2;
  int xs1, xs2;
  switch(end_style) {
  case LINE_END_ROUND: {
    xe1 = x1;
    xe2 = x2;
    xs1 = x1 - (int)(xsign * r);
    xs2 = x2 + (int)(xsign * r);
    break;
  }
  case LINE_END_BUTT: {
    xe1 = x1;
    xe2 = x2;
    xs1 = x1;
    xs2 = x2;
    break;
  }
  case LINE_END_SQUARE: {
    xe1 = x1 - (int)(xsign * r);
    xe2 = x2 + (int)(xsign * r);
    xs1 = xe1;
    xs2 = xe2;
    break;
  }
  default:
    return;
  };
  for(int i = 0; i <= MathAbs(xs2 - xs1); i++) {
    double xi = xs1 + (xsign * i);
    for(int j = 0; j < 2 * r; j++) {
      double yi = y - r + j;
      double dist = DistancePointSegment(xi, yi, xe1, y, xe2, y);
      double val = MathAbs(dist / r);
      PixelTransform((int)xi, (int)yi, clr, FilterFunction(val));
    }
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::Segment(const int x1, const int y1, const int x2, const int y2, const double kp0, const double kp1, const int xsign, const int ysign,
                      const double rcos_k, const double rsin_k, const double r, const uint clr, ENUM_LINE_END end_style) {
  if(x1 == x2 && y1 == y2)
    return;
  if(x1 == x2) {
    SegmentVertical(x1, y1, y2, ysign, r, clr, end_style);
    return;
  }
  if(y1 == y2) {
    SegmentHorizontal(x1, x2, y1, xsign, r, clr, end_style);
    return;
  }
  int xe1, ye1, xe2, ye2;
  int xs1, ys1, xs2, ys2;
  switch(end_style) {
  case LINE_END_ROUND: {
    xe1 = x1;
    ye1 = y1;
    xe2 = x2;
    ye2 = y2;
    xs1 = x1 - (xsign) * (int)(rsin_k);
    ys1 = y1 - (ysign) * (int)(rcos_k);
    xs2 = x2 + (xsign) * (int)(rsin_k);
    ys2 = y2 + (ysign) * (int)(rcos_k);
    break;
  }
  case LINE_END_BUTT: {
    xe1 = x1;
    ye1 = y1;
    xe2 = x2;
    ye2 = y2;
    xs1 = x1;
    ys1 = y1;
    xs2 = x2;
    ys2 = y2;
    break;
  }
  case LINE_END_SQUARE: {
    xe1 = x1 - (xsign) * (int)(rsin_k);
    ye1 = y1 - (ysign) * (int)(rcos_k);
    xe2 = x2 + (xsign) * (int)(rsin_k);
    ye2 = y2 + (ysign) * (int)(rcos_k);
    xs1 = xe1;
    ys1 = ye1;
    xs2 = xe2;
    ys2 = ye2;
    break;
  }
  default:
    return;
  };
  double p0x = xs1 + (xsign) * (rcos_k);
  double p0y = ys1 - (ysign) * (rsin_k);
  double p1x = xs1 - (xsign) * (rcos_k);
  double p1y = ys1 + (ysign) * (rsin_k);
  double p2x = xs2 + (xsign) * (rcos_k);
  double p2y = ys2 - (ysign) * (rsin_k);
  double p3x = xs2 - (xsign) * (rcos_k);
  double p3y = ys2 + (ysign) * (rsin_k);
  if(MathAbs(kp0) >= 1) {
    double xi0, xi1;
    double height = MathAbs(p3y - p0y);
    for(int i = 0; i <= height; i++) {
      double y = p0y + (ysign * i);
      double xi00 = MathRound(p0x + (y - p0y) / kp0);
      double xi01 = MathRound(p1x + (y - p1y) / kp1);
      double xi02 = MathRound(p2x + (y - p2y) / kp1);
      double xi03 = MathRound(p3x + (y - p3y) / kp0);
      if(xsign == 1) {
        xi0 = MathMax(xi00, xi01);
        xi1 = MathMin(xi02, xi03);
      } else {
        xi0 = MathMin(xi00, xi01);
        xi1 = MathMax(xi02, xi03);
      }
      double width = MathAbs(MathRound(xi1 - xi0));
      for(int j = 0; j <= width; j++) {
        double xi = xi0 + (xsign * j);
        double dist = DistancePointSegment(xi, y, xe1, ye1, xe2, ye2);
        double val = MathAbs(dist / r);
        PixelTransform((int)xi, (int)y, clr, FilterFunction(val));
      }
    }
  } else {
    double yi0, yi1;
    double width = MathAbs(p2x - p1x);
    for(int i = 0; i <= width; i++) {
      double x = p1x + (xsign * i);
      double yi00 = MathRound(p0y + (x - p0x) * kp0);
      double yi01 = MathRound(p1y + (x - p1x) * kp1);
      double yi02 = MathRound(p2y + (x - p2x) * kp1);
      double yi03 = MathRound(p3y + (x - p3x) * kp0);
      if(ysign == 1) {
        yi0 = MathMax(yi00, yi02);
        yi1 = MathMin(yi01, yi03);
      } else {
        yi0 = MathMin(yi00, yi02);
        yi1 = MathMax(yi01, yi03);
      }
      double height = MathAbs(yi1 - yi0);
      for(int j = 0; j <= height; j++) {
        double yi = yi0 + (ysign * j);
        double dist = DistancePointSegment(x, yi, xe1, ye1, xe2, ye2);
        double val = MathAbs(dist / r);
        PixelTransform((int)x, (int)yi, clr, FilterFunction(val));
      }
    }
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CCanvas::FilterFunction(const double x) {
  if(x <= 0.8)
    return(1.0);
  else
    return MathExp(-(x - 0.8) * (x - 0.8) * 50);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CCanvas::DistancePointSegment(const double px, const double py, const double x1, const double y1, const double x2, const double y2) {
  double a = (px - x1) * (px - x1) + (py - y1) * (py - y1);
  double b = (px - x2) * (px - x2) + (py - y2) * (py - y2);
  double c = (x2 - x1) * (x2 - x1) + (y2 - y1) * (y2 - y1);
  if(a >= b + c)
    return(MathSqrt(b));
  if(b >= a + c)
    return(MathSqrt(a));
  a = MathSqrt(a);
  b = MathSqrt(b);
  c = MathSqrt(c);
  double p = (a + b + c) / 2;
  double s = MathSqrt((p - a) * (p - b) * (p - c) * p);
  if(MathIsValidNumber(s))
    return(s * 2.0 / c);
  else
    return(0);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolylineSmooth(const int&x[], const int&y[], const uint clr, const int size, ENUM_LINE_STYLE style = STYLE_SOLID,
                             ENUM_LINE_END end_style = LINE_END_ROUND, double tension = 0.5, double step = 10) {
  int arr_size = ArraySize(x);
  if(arr_size != ArraySize(y))
    return;
  double x1, x2, y1, y2;
  tension *= 0.3;
  int xc[];
  int yc[];
  double ptX[];
  double ptY[];
  int size_pt = arr_size * 3 - 2;
  ArrayResize(ptX, size_pt);
  ArrayResize(ptY, size_pt);
  CalcCurveBezierEndp(x[0], y[0], x[1], y[1], tension, x1, y1);
  ptX[0] = x[0];
  ptY[0] = y[0];
  ptX[1] = x1;
  ptY[1] = y1;
  for(int i = 0; i < arr_size - 2; i++) {
    CalcCurveBezier(x, y, i, tension, x1, y1, x2, y2);
    ptX[3 * i + 2] = x1;
    ptY[3 * i + 2] = y1;
    ptX[3 * i + 3] = x[i + 1];
    ptY[3 * i + 3] = y[i + 1];
    ptX[3 * i + 4] = x2;
    ptY[3 * i + 4] = y2;
  }
  CalcCurveBezierEndp(x[arr_size - 1], y[arr_size - 1], x[arr_size - 2], y[arr_size - 2], tension, x1, y1);
  ptX[size_pt - 2] = x1;
  ptY[size_pt - 2] = y1;
  ptX[size_pt - 1] = x[arr_size - 1];
  ptY[size_pt - 1] = y[arr_size - 1];
  int index = 0;
  for(int i = 0; i < arr_size - 1; i++) {
    double distance = MathSqrt((x[i + 1] - x[i]) * (x[i + 1] - x[i]) + (y[i + 1] - y[i]) * (y[i + 1] - y[i]));
    int size_i = (step > 0.0) ? (int)(distance / step) : 1;
    if(size_i < 1)
      size_i = 2;
    ArrayResize(xc, ArraySize(xc) + size_i, 1024);
    ArrayResize(yc, ArraySize(yc) + size_i, 1024);
    for(int t = 0; t < size_i; t++, index++) {
      xc[index] = (int)MathRound(CalcBezierX((double)t / size_i, ptX[3 * i], ptX[3 * i + 1], ptX[3 * i + 2], ptX[3 * i + 3]));
      yc[index] = (int)MathRound(CalcBezierY((double)t / size_i, ptY[3 * i], ptY[3 * i + 1], ptY[3 * i + 2], ptY[3 * i + 3]));
    }
  }
  PolylineThick(xc, yc, clr, size, style, LINE_END_ROUND);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonSmooth(int&x[], int&y[], const uint clr, const int size, ENUM_LINE_STYLE style = STYLE_SOLID,
                            ENUM_LINE_END end_style = LINE_END_ROUND, double tension = 0.5, double step = 10) {
  int size_arr = ArraySize(x);
  if(size_arr != ArraySize(y))
    return;
  double x1, x2, y1, y2;
  tension *= 0.3;
  int xc[];
  int yc[];
  double ptX[];
  double ptY[];
  int size_pt = (size_arr + 1) * 3 - 3;
  ArrayResize(ptX, size_pt);
  ArrayResize(ptY, size_pt);
  int xe[];
  int ye[];
  ArrayResize(xe, size_arr + 2);
  ArrayResize(ye, size_arr + 2);
  xe[0] = x[size_arr - 1];
  ye[0] = y[size_arr - 1];
  xe[size_arr + 1] = x[0];
  ye[size_arr + 1] = y[0];
  ArrayCopy(xe, x, 1, 0, size_arr);
  ArrayCopy(ye, y, 1, 0, size_arr);
  for(int i = 0; i < size_arr; i++) {
    CalcCurveBezier(xe, ye, i, tension, x1, y1, x2, y2);
    ptX[3 * i + 0] = x1;
    ptY[3 * i + 0] = y1;
    ptX[3 * i + 1] = xe[i + 1];
    ptY[3 * i + 1] = ye[i + 1];
    ptX[3 * i + 2] = x2;
    ptY[3 * i + 2] = y2;
  }
  int index = 0;
  for(int i = 0; i < size_arr - 1; i++) {
    double distance = MathSqrt((x[i] - x[i + 1]) * (x[i] - x[i + 1]) + (y[i] - y[i + 1]) * (y[i] - y[i + 1]));
    int size_i = (step > 0.0) ? (int)(distance / step) : 1;
    if(size_i < 1)
      size_i = 2;
    ArrayResize(xc, ArraySize(xc) + size_i, 1024);
    ArrayResize(yc, ArraySize(yc) + size_i, 1024);
    for(int t = 0; t < size_i; t++, index++) {
      xc[index] = (int)MathRound(CalcBezierX((double)t / size_i, ptX[1 + i * 3], ptX[2 + i * 3], ptX[3 + i * 3], ptX[4 + i * 3]));
      yc[index] = (int)MathRound(CalcBezierY((double)t / size_i, ptY[1 + i * 3], ptY[2 + i * 3], ptY[3 + i * 3], ptY[4 + i * 3]));
    }
  }
  double distance = MathSqrt((x[size_arr - 1] - x[0]) * (x[size_arr - 1] - x[0]) + (y[size_arr - 1] - y[0]) * (y[size_arr - 1] - y[0]));
  int size_i = (step > 0.0) ? (int)(distance / step) : 1;
  if(size_i < 1)
    size_i = 2;
  ArrayResize(xc, ArraySize(xc) + size_i, 1024);
  ArrayResize(yc, ArraySize(yc) + size_i, 1024);
  for(int t = 0; t < size_i; t++, index++) {
    xc[index] = (int)MathRound(CalcBezierX((double)t / size_i, ptX[size_pt - 2], ptX[size_pt - 1], ptX[0], ptX[1]));
    yc[index] = (int)MathRound(CalcBezierY((double)t / size_i, ptY[size_pt - 2], ptY[size_pt - 1], ptY[0], ptY[1]));
  }
  PolygonThick(xc, yc, clr, size, style, LINE_END_ROUND);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::CalcCurveBezierEndp(const double xend, const double yend, const double xadj, const double yadj, const double tension, double&x, double&y) {
  x = (tension * (xadj - xend) + xend);
  y = (tension * (yadj - yend) + yend);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::CalcCurveBezier(const int&x[], const int&y[], const int i, const double tension, double&x1, double&y1, double&x2, double&y2) {
  double xdiff, ydiff;
  xdiff = x[i + 2] - x[i];
  ydiff = y[i + 2] - y[i];
  x1 = x[i + 1] - tension * xdiff;
  y1 = y[i + 1] - tension * ydiff;
  x2 = x[i + 1] + tension * xdiff;
  y2 = y[i + 1] + tension * ydiff;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CCanvas::CalcBezierX(const double t, const double x0, const double x1, const double x2, const double x3) {
  return(x0 * ((1 - t) * (1 - t) * (1 - t)) +
         x1 * 3 * t * ((1 - t) * (1 - t)) +
         x2 * 3 * (t * t) * (1 - t) +
         x3 * (t * t * t));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CCanvas::CalcBezierY(const double t, const double y0, const double y1, const double y2, const double y3) {
  return(y0 * ((1 - t) * (1 - t) * (1 - t)) +
         y1 * 3 * t * ((1 - t) * (1 - t)) +
         y2 * 3 * (t * t) * (1 - t) +
         y3 * (t * t * t));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::BitBlt(int dst_x, int dst_y, const uint&src[], int src_width, int src_height, int src_x, int src_y, int src_dx, int src_dy, uint mode) {
  for(int y = 0; y < src_dy; y++)
    for(int x = 0; x < src_dx; x++) {
      PixelSet(dst_x + x, dst_y + y, src[(src_y + y)*src_width + src_x + x]);
    }
}
/* ******* File: _SimpleDialog.mqh:1256 ******* */
class CCanvasExt: public CCanvas {
public:
  bool               LoadFromFile(const string filename) {
    int oldwidth = m_width;
    if(!ResourceReadImage(filename, m_pixels, m_width, m_height))
      if(!CCanvas::LoadFromFile(filename))
        return false;
    if(oldwidth != m_width)
      ResizeBitmap(oldwidth);
    return true;
  }
  bool               FontSet(const string name, const int size, const uint flags = 0, const uint angle = 0) {
    int fontsizeuse = __Scale.Font(ABS(size));
    fontsizeuse = -fontsizeuse * 10;
    if(!TextSetFont(name, (int)fontsizeuse, flags, angle))
      return(false);
    m_fontname = name;
    m_fontsize = (int)fontsizeuse;
    m_fontflags = flags;
    m_fontangle = angle;
    return(true);
  }
  bool               ResizeBitmap(int width) {
    double NewWidth = width;
    if(NewWidth == 0)NewWidth = 1;
    double k = NewWidth / m_width;
    double k2 = k * k;
    double kk = m_width / NewWidth;
    double w1 = (double)m_width * k;
    int W = _CEIL(w1);
    double h1 = (double)m_height * k;
    int H = _CEIL(h1);
    rgb_union col;
    uint M[];
    int ArrSize = W * H;
    ArrayResize(M, ArrSize);
    int ArrSizeOrg = m_width * m_height;
    int pos = 0;
    double y0 = 0, x0, y1 = kk, x1;
    for(int y = 0; y < H; y++, y0 = y1, y1 += kk) {
      x0 = 0;
      x1 = kk;
      for(int x = 0; x < W; x++, x0 = x1, x1 += kk, pos++) {
        int xs = (int)x0;
        int xf = (int)x1;
        int ys = (int)y0;
        int yf = (int)y1;
        double r = 0, g = 0, b = 0, p = 0;
        int pos2 = ys * (int)Width() + xs;
        for(int Y1 = ys; Y1 <= yf; Y1++, pos2 += (int)m_width) {
          double dx, dy;
          int pos1 = pos2;
          if(Y1 == ys) {
            dy = ys + 1 - y0;
            if(ys == yf)dy = dy - 1 + y1 - yf;
          } else if(Y1 == yf)dy = y1 - yf;
          else dy = 1;
          for(int X1 = xs; X1 <= xf; X1++, pos1++) {
            if(pos1 < ArrSizeOrg) {
              if(m_pixels[pos1] != 0) {
                col.clr = m_pixels[pos1];
                if(X1 == xs) {
                  dx = xs + 1 - x0;
                  if(xs == xf)dx = dx - 1 + x1 - xf;
                } else if(X1 == xf)dx = x1 - xf;
                else dx = 1;
                dx = dx * dy;
                r += (double)col.argb[2] * dx;
                g += (double)col.argb[1] * dx;
                b += (double)col.argb[0] * dx;
                p += (double)col.argb[3] * dx;
              }
            } else break;
          }
        }
        col.argb[0] = uchar(b * k2);
        col.argb[1] = uchar(g * k2);
        col.argb[2] = uchar(r * k2);
        col.argb[3] = uchar(p * k2);
        M[pos] = col.clr;
      }
    }
    Resize(W, H);
    ArrayCopy(m_pixels, M);
    return true;
  }
public:
  bool               TextOutRect(int x1, int y1, int x2, int y2, string text, uint argb, ENUM_ALIGN_MODE alignh = ALIGN_LEFT, ENUM_ALIGNV_MODE alignv = ALIGN_TOP) {
    if(!IS_CANVAS_CREATED)
      return false;
    int textwidth, textheight;
    TextSize(text, textwidth, textheight);
    int x = 0, y = 0;
    switch(alignh) {
    case ALIGN_LEFT:
      x = x1;
      break;
    case ALIGN_RIGHT:
      x = x2 - textwidth;
      break;
    case ALIGN_CENTER:
      x = ((x1 + x2) / 2) - (textwidth / 2);
      break;
    }
    switch(alignv) {
    case ALIGN_TOP:
      y = y1;
      break;
    case ALIGN_BOTTOM:
      y = y2 - textheight;
      break;
    case ALIGN_MID:
      y = ((y1 + y2) / 2) - (textheight / 2);
      break;
    }
    this.TextOut(x, y, text, argb);
    return true;
  }
};
class CWndBmp: public CWnd {
public:
                     CWndBmp(void);
                    ~CWndBmp(void);
  bool               CreateLocal(int x, int y, int x2, int y2);
  bool               Redraw(void) {
    if(!m_bitmapcreated)ReCreate();
    return OnRedraw();
  }
  bool               Size(const int w, const int h);
  bool               ToolTip(string value) {
    m_tooltip = value;
    if(!m_bitmapcreated)return false;
    return __MT_Object_SetToolTip(m_chart_id, m_name, value);
  }
  string             ToolTip(void) {
    return m_tooltip;
  }
public:
  CCanvasExt         m_canvas;
  string             m_file;
  CCanvasExt         m_filecanvas;
  bool               m_bitmapcreated;
protected:
  int                m_fc_gapx;
  int                m_fc_gapy;
  string             m_tooltip;
public:
  void               Erase(void) {
    m_canvas.Erase();
    OnErase();
  }
  bool               Update(void) {
    Redraw();
    return OnUpdate();
  }
  string             FileName(void) {
    return m_file;
  }
  bool               FileName(string filename, bool update = true) {
    m_file = filename;
    ReCreate();
    if(update)
      return Update();
    return true;
  }
protected:
  virtual bool       OnShow(void);
  virtual bool       OnHide(void);
  virtual bool       OnEnable(void) {
    bool result = CWnd::OnEnable();
    result &= Update();
    return result;
  }
  virtual bool       OnDisable(void) {
    bool result = CWnd::OnDisable();
    result &= Update();
    return result;
  }
  virtual bool       OnActivate() {
    bool result = CWnd::OnActivate();
    result &= Update();
    return result;
  }
  virtual bool       OnDeactivate() {
    bool result = CWnd::OnDeactivate();
    result &= Update();
    return result;
  }
  virtual bool       OnMove(void);
  virtual bool       OnResize(void);
  virtual bool       OnDestroy(void) {
    CWnd::OnDestroy();
    m_canvas.Destroy();
    m_filecanvas.Destroy();
    m_bitmapcreated = false;
    return true;
  }
  virtual bool       OnCreate(void) {
    ReCreate(false);
    __MT_Object_SetVisible(m_chart_id, m_name, false);
    return true;
  }
  virtual bool       OnRecreate(void) {
    return true;
  }
  virtual bool       OnRedraw(void) {
    return true;
  }
  virtual bool       OnErase(void) {
    return true;
  }
  virtual bool       OnUpdate(void);
private:
  bool               ReCreate(bool redraw = true);
protected:
};
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
CWndBmp::CWndBmp(void) {
  m_classname = "CWndBmp";
  m_tooltip = NULL;
  m_bitmapcreated = false;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
CWndBmp::~CWndBmp(void) {
  Destroy();
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::CreateLocal(int x, int y, int x2, int y2) {
  if(x2 < 0)x2 = x - x2;
  if(y2 < 0)y2 = y - y2;
  return CWnd::Create(__CHARTID, __RNDID, __MT_GetCurrentSubWindow(), x, y, x2, y2);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::Size(const int w, const int h) {
  if(w != m_rect.Width() || h != m_rect.Height())
    return CWnd::Size(w, h);
  return true;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::ReCreate(bool redraw = true) {
  if(__EA.Cycle >= EA_CYCLE_DEINIT)
    Print("Bitmap recreation after Deinit");
  if(m_bitmapcreated) {
    m_canvas.Destroy();
    m_filecanvas.Destroy();
  } else {
    __MT_Object_Delete(m_chart_id, m_name);
    __MT_Object_Delete(m_chart_id, m_name + "F");
  }
  int w = MAX(1, Width());
  int h = MAX(1, Height());
  if(!m_canvas.CreateBitmapLabel(m_chart_id, m_subwin, m_name, Left(), Top(), w, h, COLOR_FORMAT_ARGB_NORMALIZE)) {
    string info = "(object: '" + m_name + "' chart: " + (string)m_chart_id + " metrics: " + (string)Left() + "," + (string)Top() + "," + (string)w + "," + (string)h + " cycle: " + EnumToString(__EA.Cycle) + ")";
    Print("Critical/Recreation of bitmap failed:\n " + info, "Internal MetaTrader error");
    ExpertRemove();
    return false;
  }
  if(m_file != NULL) {
    if(!m_filecanvas.CreateBitmapLabel(m_chart_id, m_subwin, m_name + "F", Left(), Top(), w, h, COLOR_FORMAT_ARGB_NORMALIZE)) {
      string info = "(object: '" + m_name + "F' chart: " + (string)m_chart_id + " metrics: " + (string)Left() + "," + (string)Top() + "," + (string)w + "," + (string)h + " cycle: " + EnumToString(__EA.Cycle) + ")";
      Print("Critical/Recreation of bitmap #2 failed:\n" + info, "Internal MetaTrader error");
      ExpertRemove();
      return false;
    }
    if(!m_filecanvas.LoadFromFile(m_file))
      m_file = NULL;
    m_fc_gapy = (Height() - m_filecanvas.Height()) / 2;
    m_fc_gapx = (Width() - m_filecanvas.Width()) / 2;
  }
  ToolTip(m_tooltip);
  if(!m_bitmapcreated) {
    m_bitmapcreated = true;
    return true;
  }
  if(!OnRecreate())
    return false;
  if(!redraw)
    return true;
  return Update();
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::OnUpdate(void) {
  if(!Redraw())
    return false;
  m_canvas.Update();
  if(m_file != NULL)
    m_filecanvas.Update();
  return true;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::OnShow() {
  OnHide();
  if(!CWnd::OnShow())return false;
  return __MT_Object_SetVisible(m_chart_id, m_name + "F", true);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::OnHide() {
  if(!CWnd::OnHide())return false;
  return __MT_Object_SetVisible(m_chart_id, m_name + "F", false);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::OnMove(void) {
  __MT_Object_XY_Move(m_chart_id, m_name, m_rect.left, m_rect.top);
  __MT_Object_XY_Move(m_chart_id, m_name + "F", m_rect.left + m_fc_gapx, m_rect.top + m_fc_gapy);
  return true;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndBmp::OnResize(void) {
  if(!CWnd::OnResize())
    return false;
  if(!m_bitmapcreated)
    return Update();
  if(!m_canvas.Resize(m_rect.Width(), m_rect.Height()))
    return false;
  return Update();
}
