//+------------------------------------------------------------------+
int __MT_Object_DeleteAll(long chartid, string match, int subwin = -1, int type = -1, bool match_pos_begin = true) {
  if(chartid == NULL)chartid = __CHARTID;
  if(match_pos_begin)
    return::ObjectsDeleteAll(chartid, match, subwin, type);
  int n = 0;
  int cnt = ObjectsTotal(chartid);
  for(int i = 0; i < cnt; i++) {
    string name = ObjectName(chartid, i);
    if(_StringIndexOf(name, match) >= 0) {
      ::ObjectDelete(chartid, name);
      i--;
      cnt--;
      n++;
    }
  }
  return n;
}
