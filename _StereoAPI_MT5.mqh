bool __MT_Object_Get4Coordinates(long chartid, string name, datetime&timebegin, double&pricelow, datetime&timeend, double&pricehigh) {
  if(chartid == NULL)chartid = __CHARTID;
  timebegin = (datetime)__Time.ChartToLocal(__MT_Object_GetInteger(chartid, name, OBJPROP_TIME, 0));
  timeend = (datetime)__Time.ChartToLocal(__MT_Object_GetInteger(chartid, name, OBJPROP_TIME, 1));
  pricelow = __MT_Object_GetDouble(chartid, name, OBJPROP_PRICE, 0);
  pricehigh = __MT_Object_GetDouble(chartid, name, OBJPROP_PRICE, 1);
  if(timeend != 0 && timeend < timebegin) {
    SWAP(timebegin, timeend, datetime);
    SWAP(pricelow, pricehigh, double);
  }
  if(__MT_Object_GetType(chartid, name) == OBJ_RECTANGLE) {
    if(pricehigh != 0 && pricehigh < pricelow)
      SWAP(pricelow, pricehigh, double);
  }
  return pricelow != 0;
}
