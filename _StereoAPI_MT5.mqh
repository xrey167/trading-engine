    int n =::ObjectsTotal(m_chart_id, 0, OBJ_RECTANGLE_LABEL);
    int cnt = 0, pos = -1, offset = 0;
    for(int i = n - 1; i >= 0; i--) {
      string name =::ObjectName(m_chart_id, i, 0, OBJ_RECTANGLE_LABEL);
      ENUM_OBJECT type = (ENUM_OBJECT)__MT_Object_GetType(m_chart_id, name);
