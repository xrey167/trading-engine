    if(_StringIsEmpty(id))
      id = "C" + (string)m_obj_id;
    else {
      ::StringReplace(id, "=", "");
      ::StringReplace(id, ";", "");
    }
    m_settingstag = _StringToLower(_StringPack(id));
    return true;
  }
public:
  string             SettingsID(void) {
    return m_settingstag;
  }
public:
  virtual bool       SettingsRead(CFileSettings&settings, string catprefix = NULL) {
    if(m_settingstag == NULL)return false;
    string tag = catprefix == NULL ? m_settingstag : catprefix + ":" + m_settingstag;
    string value = settings.Get(tag);
    if(value == NULL)return LoadDefault();
    return StringValue(value);
  }
public:
  virtual bool       SettingsWrite(CFileSettings&settings, string catprefix = NULL) {
    if(m_settingstag == NULL)return false;
    string tag = catprefix == NULL ? m_settingstag : catprefix + ":" + m_settingstag;
    return settings.Set(tag, StringValue());
  }
