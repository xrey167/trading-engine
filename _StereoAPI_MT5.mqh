enum ENUM_COUNTRY {
  COUNTRY_US = 0,
  COUNTRY_EUROPEAN = 1,
};
ENUM_COUNTRY __e_country = COUNTRY_US;
class CCurrencyService {
private:
  TCurrency          m_value;
private:
  int                m_maxdigits;
public:
                     CCurrencyService() {
    m_maxdigits = (int)MIN(m_value.Digits(), 6);
  }
public:
  void               Digits(int n) {
    m_maxdigits = n;
  }
public:
  int                Digits() {
    return m_maxdigits;
  }
public:
  double             ToCurrency(double value) {
    return::NormalizeDouble(value, m_maxdigits);
  }
public:
  string             ToStringC(double value) {
    return::DoubleToString(value, m_maxdigits) + " " + __Account.Currency();
  }
public:
  string             ToString(double value) {
    return::DoubleToString(value, m_maxdigits);
  }
public:
  int                WithInChars(double value = VALUE_INVALID) {
    double v = value == VALUE_INVALID ? (__Account.Equity() / 10) : value;
    return _StringLen(ToString(v));
  }
public:
  string             ToStringXC(double value, bool plussign = false, bool nodigitsabove1000 = false) {
    return _ToString(value, m_maxdigits, plussign, nodigitsabove1000) + " " + __Account.Currency();
  }
public:
  string             ToStringX(double value, bool plussign = false, bool nodigitsabove1000 = false) {
    return _ToString(value, m_maxdigits, plussign, nodigitsabove1000);
  }
public:
  string             _ToString(double value, int digits = 0, bool plussign = false, bool nodigitsabove1000 = false, int fillzeros = 0, bool div1000 = false, int divdigits = 2) {
    string price;
    string suffix = NULL;
    if(div1000) {
      if(value > 1000000000) {
        value /= 1000000000;
        suffix = "G";
        digits = MAX(digits, divdigits);
      }
      if(value > 1000000) {
        value /= 1000000;
        suffix = "M";
        digits = MAX(digits, divdigits);
      } else if(value > 1000) {
        value /= 1000;
        suffix = "K";
        digits = MAX(digits, divdigits);
      }
      price =::DoubleToString(::NormalizeDouble(value, digits), digits);
    } else
      price =::DoubleToString(::NormalizeDouble(value, digits), digits);
    string dec = ".", kilo = ",";
    if(__e_country == COUNTRY_EUROPEAN) {
      dec = ",";
      kilo = ".";
    }
    int len = _StringLen(price);
    _StringReplaceN(price, ".", dec);
    if(value >= 1000) {
      int dpos = digits == 0 ? len - digits - 3 : len - digits - 4;
      price = _StringSubstr(price, 0, dpos) + kilo + _StringSubstrFrom(price, dpos);
    }
    if(value >= 1000000) {
      int dpos = digits == 0 ? len - digits - 6 : len - digits - 7;
      price = _StringSubstr(price, 0, dpos) + kilo + _StringSubstrFrom(price, dpos);
    }
    if(value > 0 && plussign)
      price = "+" + price;
    if(nodigitsabove1000 && (value >= 1000 || value <= -1000) && digits > 0)
      price = _StringSubstr(price, 0, _StringLen(price) - digits - 1);
    if(fillzeros > 0) {
      int l = _StringLen(price);
      if(l < fillzeros) {
        string f = "000000";
        price = _StringSubstr(f, 0, fillzeros - l) + price;
      }
    }
    return price + suffix;
  }
public:
  double             _FromString(string value) {
    _StringReplaceN(value, ",", "");
    return(double)value;
  }
};
CCurrencyService __CurrencyService;
