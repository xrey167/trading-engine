class CFileSettings: public CObject {
protected:
  string             m_var[];
  string             m_data[];
  int                m_cnt;
  bool               m_validdata;
  bool               m_validsorted;
  bool               m_casesensitive;
  string             m_filename;
  bool               m_common;
  bool               m_redirect_localtocommon;
  bool               m_shared;
  bool               m_sorted;
  bool               m_utf8;
  bool               m_load_firsttime;
  int                m_lastdefinedrequestresult;
  datetime           m_lastchange;
  CFileText          m_file;
  bool               m_uses_header;
  bool               m_unique_content;
public:
  CNamedArgs         Header;
public:
  void               CFileSettings() {
    m_cnt = 0;
    m_validdata = true;
    m_validsorted = false;
    m_common = false;
    m_shared = false;
    m_filename = NULL;
    m_lastdefinedrequestresult = -1;
    m_sorted = false;
    m_lastchange = 0;
    m_redirect_localtocommon = true;
    m_casesensitive = true;
    m_uses_header = true;
    m_utf8 = false;
    Header.Clear();
    m_load_firsttime = true;
    m_unique_content = true;
  }
public:
  void              ~CFileSettings() {
    Close();
  }
public:
  bool               Name(string value, bool common_folder) {
    FlagCommon(common_folder);
    return Name(value);
  }
public:
  bool               Name(string value) {
    if(m_file.IsOpen())m_file.Close();
    m_filename = value;
    return true;
  }
public:
  string             Name(void) {
    return m_filename;
  }
public:
  bool               FlagCommon(bool flag) {
    if(m_file.IsOpen())return false;
    m_common = flag;
    return true;
  }
public:
  bool               FlagCommon(void) {
    return m_common;
  }
public:
  bool               FlagShared(bool flag) {
    if(m_file.IsOpen())return false;
    m_shared = flag;
    return true;
  }
public:
  bool               FlagShared() {
    return m_shared;
  }
public:
  bool               FlagSorted(bool flag) {
    m_sorted = flag;
    m_validsorted = false;
    return true;
  }
public:
  bool               FlagSorted() {
    return m_sorted;
  }
public:
  bool               RedirectLocalToCommon(bool flag) {
    if(m_file.IsOpen())return false;
    m_redirect_localtocommon = flag;
    return true;
  }
public:
  bool               RedirectLocalToCommon(void) {
    return m_redirect_localtocommon;
  }
public:
  bool               FlagIgnoreExistance(bool flag) {
    if(m_file.IsOpen())return false;
    m_file.FlagIgnoreExistance(flag);
    return true;
  }
public:
  bool               FlagIgnoreExistance() {
    return m_file.FlagIgnoreExistance();
  }
public:
  bool               FlagUTF8(bool flag) {
    if(m_file.IsOpen())return false;
    m_utf8 = flag;
    return true;
  }
public:
  bool               FlagUTF8() {
    return m_utf8;
  }
public:
  bool               IsUsingHeader() {
    return m_uses_header;
  }
public:
  bool               CaseSensitive(bool flag) {
    m_casesensitive = flag;
    return true;
  }
public:
  bool               CaseSensitive(void) {
    return m_casesensitive;
  }
public:
  bool               Unique(bool flag) {
    m_unique_content = flag;
    return true;
  }
public:
  bool               Unique() {
    return m_unique_content;
  }
public:
  string             operator[](string id) {
    int index = GetIndex(id);
    if(index < 0)return null;
    return m_data[index];
  }
public:
  string             operator[](int index) {
    if(index < 0 || index >= m_cnt)return null;
    return m_data[index];
  }
public:
  string             PhysicalPath(void) {
    _ApplyParams();
    return m_file.PhysicalPath();
  }
public:
  bool               IsExist(void) {
    _ApplyParams();
    return m_file.IsExist();
  }
public:
  bool               DeleteFile(void) {
    _ApplyParams();
    Close();
    return m_file.Delete();
  }
private:
  void               _ApplyParams() {
    if(!m_file.IsOpen()) {
      m_file.Name(m_filename);
      m_file.FlagCommon(m_common);
      m_file.FlagRedirectLocalToCommon(m_redirect_localtocommon);
      m_file.FlagIgnoreExistance(true);
      m_file.FlagAnsi(!m_utf8);
      m_file.FlagUTF8(m_utf8);
    }
  }
public:
  int                Count(string prefix = NULL) {
    if(!CheckFile(false))return false;
    if(prefix == NULL)return m_cnt;
    int l = _StringLen(prefix);
    if(l == 0)return 0;
    int n = 0;
    for(int i = 0; i < m_cnt; i++) {
      if(_StringSubstr(m_var[i], 0, l) == prefix)
        n++;
    }
    return n;
  }
private:
  int                m_enum_index;
private:
  CNamedArg          m_enum_na;
public:
  void               Enum() {
    if(!CheckFile(false))return;
    m_enum_index = 0;
  }
public:
  bool               EnumGetNext(string&value) {
    if(m_enum_index >= m_cnt) {
      value = null;
      return false;
    }
    value = m_var[m_enum_index];
    m_enum_index++;
    return true;
  }
public:
  bool               EnumGetNext(CNamedArg*&arg) {
    if(m_enum_index >= m_cnt) {
      arg = null;
      return false;
    }
    m_enum_na.Var(m_var[m_enum_index]);
    m_enum_na.Value(m_data[m_enum_index]);
    m_enum_index++;
    return true;
  }
public:
  bool               IsValid() {
    return m_validdata;
  }
public:
  void               Invalidate() {
    if(m_validdata) {
      m_validdata = false;
      OnInvalidate();
    }
  }
public:
  bool               Validate() {
    if(m_validdata)return true;
    return Save();
  }
protected:
  virtual void       OnLoad() {}
protected:
  virtual void       OnSave() {}
protected:
  virtual void       OnInvalidate() {}
public:
  bool               Refresh() {
    if(!CheckFile(true))return false;
    return VerifyModification();
  }
public:
  bool               VerifyModification(bool force = false, bool check_when_time_is_equal = true) {
    if(m_filename == NULL)return force;
    bool modified = force;
    datetime timechanged = 0;
    if(!modified) {
      timechanged = m_file.TimeLastChange();
      modified = timechanged != m_lastchange;
    }
    if(!modified && check_when_time_is_equal)
      modified = OnVerifyModificationEqual();
    if(modified) {
      if(m_file.IsOpen()) {
        m_file.ReOpen();
        m_lastchange = timechanged;
        m_validsorted = true;
        Load();
      }
    }
    return modified;
  }
protected:
  virtual bool       OnVerifyModificationEqual() {
    if(!m_uses_header)return false;
    string tc_writelast = m_tc_write_last;
    if(!RefreshHeader())return false;
    return m_tc_write_last != tc_writelast;
  }
protected:
  bool               CheckFile(bool checkphysical) {
    if(!checkphysical && m_filename == NULL)return true;
    if(m_file.IsOpen())return true;
    _ApplyParams();
    if(!m_file.Open())return false;
    m_lastchange = m_file.TimeLastChange();
    m_validsorted = false;
    Load();
    return true;
  }
public:
  bool               Close() {
    if(!m_file.IsOpen())return false;
    bool result = Save();
    result &= m_file.Close();
    ::ArrayFree(m_var);
    ::ArrayFree(m_data);
    m_validsorted = false;
    m_validdata = true;
    m_cnt = 0;
    Header.Clear();
    return result;
  }
public:
  int                SettingsTotal() {
    return m_cnt;
  }
public:
  void               Clear() {
    ::ArrayFree(m_var);
    ::ArrayFree(m_data);
    m_validsorted = false;
    m_cnt = 0;
    Invalidate();
    Header.Clear();
  }
public:
  bool               Delete(string id) {
    if(!CheckFile(false))return false;
    int i = GetIndex(id);
    if(i < 0)
      return false;
    ::ArrayRemove(m_var, i, 1);
    ::ArrayRemove(m_data, i, 1);
    m_cnt =::ArraySize(m_var);
    Invalidate();
    return true;
  }
public:
  bool               DeleteAll(string id_prefix = NULL) {
    if(!CheckFile(false))return false;
    if(_StringIsEmpty(id_prefix)) {
      Clear();
      return true;
    }
    int l = _StringLen(id_prefix);
    int n = 0;
    for(int i = 0; i < m_cnt; i++) {
      if(_StringSubstr(m_var[i], 0, l) == id_prefix)
        continue;
      m_var[n] = m_var[i];
      m_data[n] = m_data[i];
      n++;
    }
    ArrayResize(m_var, n);
    ArrayResize(m_data, n);
    m_cnt = n;
    Invalidate();
    return true;
  }
public:
  string             Get(string id, string defaultvalue = NULL) {
    if(!CheckFile(false))return NULL;
    int i = GetIndex(id);
    if(i < 0)
      return defaultvalue;
    return m_data[i];
  }
public:
  string             GetAlike(string id) {
    if(!CheckFile(false))return NULL;
    int i = GetAlikeIndex(id);
    if(i < 0)
      return NULL;
    return m_data[i];
  }
public:
  string             Extract(string id) {
    if(!CheckFile(false))return NULL;
    int i = GetIndex(id);
    if(i < 0)
      return NULL;
    string result = m_data[i];
    m_data[i] = "";
    Invalidate();
    return result;
  }
public:
  bool               GetBool(string id, bool defaultvalue = false) {
    return STR_TO_BOOL(Get(id, BOOL_TO_STR(defaultvalue)));
  }
public:
  template<typename T>bool Get(string id, T&var) {
    if(!CheckFile(false))return false;
    int i = GetIndex(id);
    if(i < 0)
      return false;
    if(typename(T) == "bool")
      var = STR_TO_BOOL(m_data[i]);
    else
      var = (T)m_data[i];
    return true;
  }
public:
  string             Get() {
    if(m_lastdefinedrequestresult < 0)
      return NULL;
    return m_data[m_lastdefinedrequestresult];
  }
public:
  bool               IsDefined(string id) {
    if(!CheckFile(false))return false;
    m_lastdefinedrequestresult = GetIndex(id);
    return m_lastdefinedrequestresult >= 0;
  }
public:
  bool               SetBool(string id, bool value) {
    return Set(id, value ? "1" : "0");
  }
public:
  bool               Set(string id, bool value) {
    if(!CheckFile(false))return false;
    if(_StringIndexOf(id, "=") >= 0)
      return false;
    int i = GetIndex(id);
    if(i < 0) {
      AppendRecord();
      i = m_cnt - 1;
    }
    string sdata = value ? "1" : "0";
    if(sdata == m_data[i])
      return true;
    m_var[i] = id;
    m_data[i] = sdata;
    Invalidate();
    return true;
  }
public:
  template<typename T>bool Set(string id, T data) {
    if(!CheckFile(false))return false;
    if(_StringIndexOf(id, "=") >= 0)
      return false;
    int i = m_unique_content ? GetIndex(id) : -1;
    if(i < 0) {
      AppendRecord();
      i = m_cnt - 1;
    }
    string sdata = (string)data;
    if(sdata == m_data[i])
      return true;
    m_var[i] = id;
    m_data[i] = sdata;
    Invalidate();
    return true;
  }
public:
  template<typename T>bool Append(string id, T data) {
    if(!CheckFile(false))return false;
    if(_StringIndexOf(id, "=") >= 0)
      return false;
    int i = GetIndex(id);
    if(i < 0) {
      AppendRecord();
      i = m_cnt - 1;
    }
    string sdata = m_data[i] + (string)data;
    if(sdata == m_data[i])
      return true;
    m_var[i] = id;
    m_data[i] = sdata;
    Invalidate();
    return true;
  }
public:
  string             _GetVar(int index) {
    if(index < 0 || index >= m_cnt)return NULL;
    return m_var[index];
  }
public:
  string             _GetValue(int index) {
    if(index < 0 || index >= m_cnt)return NULL;
    return m_data[index];
  }
protected:
  virtual bool       CreateHeader() {
    m_tc_write_last = (string)__Time.Ticks64();
    Header.Set("cnt", m_cnt);
    Header.Set("sorted", m_sorted && m_validsorted ? "ord" : "0");
    Header.Set("tcw", m_tc_write_last);
    Header.Set("id", __EA.InstanceId());
    return true;
  }
protected:
  string             m_tc_write_last;
public:
  bool               Save() {
    if(m_filename == null) {
      if(m_validdata)return true;
      if(m_sorted && !m_validsorted)
        Sort();
      m_validdata = true;
      return true;
    }
    if(!CheckFile(true))return false;
    if(m_validdata)return true;
    m_file._Seek(0);
    if(m_sorted && !m_validsorted)
      Sort();
    if(CreateHeader())
      m_file.Write(":::sfh=" + Header._Buffer);
    for(int i = 0; i < m_cnt; i++)
      m_file.Write(m_var[i] + "=" + m_data[i]);
    m_file.Write("<e>");
    m_file.Flush();
    m_validdata = true;
    m_lastchange = m_file.TimeLastChange();
    OnSave();
    return true;
  }
public:
  int                CopyTo(CFileSettings&settings, string varprefix = NULL) {
    return CopyTo(PTR(settings), varprefix);
  }
public:
  int                CopyTo(CFileSettings*settings, string varprefix = NULL) {
    for(int i = 0; i < m_cnt; i++) {
      if(varprefix == NULL || _StringIndexOf(m_var[i], varprefix) == 0)
        settings.Set(m_var[i], m_data[i]);
    }
    return settings.SettingsTotal();
  }
public:
  int                CopyFrom(CFileSettings&settings, string varprefix = NULL) {
    return settings.CopyTo(PTR(this), varprefix);
  }
public:
  int                CopyFrom(CFileSettings*settings, string varprefix = NULL) {
    return settings.CopyTo(PTR(this), varprefix);
  }
public:
  bool               RefreshHeader() {
    if(!m_uses_header)return false;
    if(!CheckFile(true))return false;
    _ReadHeader();
    return true;
  }
protected:
  bool               _ReadHeader() {
    m_file.Seek(0);
    string line = m_file.zfu638707147322096631();
    if(line == null) {
      Header.Clear();
      return false;
    }
    if(_StringIndexOf(line, ":::sfh=") != 0)return false;
    Header.AssignByCopy(_StringSubstrFrom(line, 7));
    m_tc_write_last = Header.Get<string>("tcw");
    return true;
  }
protected:
  bool               Load(void) {
    m_file._Seek(0);
    Clear();
    m_validdata = true;
    int elements = -1;
    bool header_said_sorted = false;
    string line = m_file.zfu638707147322096631();
    if(line == NULL)return true;
    if(_StringIndexOf(line, ":::sfh=") == 0) {
      m_uses_header = true;
      Header.AssignByCopy(_StringSubstrFrom(line, 7));
      header_said_sorted = Header.Get<string>("sorted") == "ord";
      elements = Header.GetInt("cnt");
      m_tc_write_last = Header.Get<string>("tcw");
      if(elements > 0) {
        ::ArrayResize(m_var, elements);
        ::ArrayResize(m_data, elements);
      }
    } else {
      Header.Clear();
      m_uses_header = false;
      m_file.Seek(0);
    }
    while(!m_file.IsEnding()) {
      line = m_file.zfu638707147322096631();
      if(line == NULL)
        break;
      if(line == "")
        continue;
      if(line == "<e>")
        break;
      int p = _StringIndexOf(line, "=");
      if(p >= 0) {
        string var_name = _StringSubstr(line, 0, p);
        if(!m_uses_header || m_load_firsttime) {
          if(var_name == ":::sfh")continue;
          line = _StringTrim(line);
          p = _StringIndexOf(line, "=");
          if(line == "" || line == "=")continue;
          if(m_unique_content && GetIndex(var_name) >= 0)continue;
        }
        AppendRecord();
        m_var[m_cnt - 1] = var_name;
        m_data[m_cnt - 1] = _StringSubstrFrom(line, p + 1);
      } else {
        AppendRecord();
        m_var[m_cnt - 1] = line;
        m_data[m_cnt - 1] = "";
      }
    }
    if(elements == m_cnt && header_said_sorted)
      m_validsorted = true;
    if(m_sorted && !m_validsorted)
      Sort();
    else if(!m_uses_header)
      Pack();
    OnLoad();
    m_load_firsttime = false;
    return m_cnt > 0;
  }
protected:
  virtual int        GetIndex(string id) {
    if(m_cnt == 0)
      return -1;
    if(m_sorted && m_validsorted && m_casesensitive) {
      int l = 0, r = m_cnt, m = (l + r) / 2, ml = -1;
      int n_search = 0;
      while(true) {
        if(m == m_cnt || m == ml)return -1;
        int cmp = String_CompareExt(m_var[m], id, String_CompareMethod_Exact);
        if(cmp == 0)
          return m;
        else if(cmp > 0)
          r = m;
        else
          l = m;
        ml = m;
        m = (l + r) / 2;
        n_search++;
        if(n_search > m_cnt) {
          m_validsorted = false;
          Print("Warning: Manually modified settings file detected!");
          return GetIndex(id);
        }
      }
      return -1;
    }
    if(m_casesensitive) {
      for(int i = 0; i < m_cnt; i++)
        if(m_var[i] == id)
          return i;
    } else {
      id = _StringToLower(id);
      for(int i = 0; i < m_cnt; i++)
        if(_StringToLower(m_var[i]) == id)
          return i;
    }
    return -1;
  }
protected:
  virtual int        GetAlikeIndex(string id) {
    id = _StringToLower(id);
    int id_len = _StringLen(id);
    for(int i = 0; i < m_cnt; i++) {
      int l = _StringLen(m_var[i]);
      if(zfu638707147322095863(id, _StringToLower(m_var[i])))return i;
    }
    return -1;
  }
protected:
  bool               AppendRecord() {
    m_cnt++;
    if(ArraySize(m_var) < m_cnt) {
      ArrayResize(m_var, m_cnt, 8);
      ArrayResize(m_data, m_cnt, 8);
    }
    m_var[m_cnt - 1] = null;
    m_data[m_cnt - 1] = null;
    m_validsorted = false;
    return true;
  }
private:
  void               BubbleSort() {
    for(int i = 0; i < m_cnt; i++) {
      for(int k = i + 1; k < m_cnt; k++) {
        int cmp = String_CompareExt(m_var[k], m_var[i], String_CompareMethod_Exact);
        if(cmp < 0) {
          string tmp = m_var[i];
          m_var[i] = m_var[k];
          m_var[k] = tmp;
          tmp = m_data[i];
          m_data[i] = m_data[k];
          m_data[k] = tmp;
        }
      }
    }
  }
protected:
  void               Pack() {
    int cnt =::ArraySize(m_var);
    int n = 0;
    for(int i = 0; i < cnt; i++) {
      if(_StringIsEmpty(m_var[i]))continue;
      if(n != i) {
        m_var[n] = m_var[i];
        m_data[n] = m_data[i];
      }
      n++;
    }
    m_cnt = n;
    if(m_cnt != cnt) {
      ::ArrayResize(m_var, m_cnt);
      ::ArrayResize(m_data, m_cnt);
    }
  }
protected:
  void               Sort() {
    Pack();
    if(m_cnt == 0)return;
    QuickSort(0, m_cnt - 1);
    m_validsorted = true;
  }
private:
  void               QuickSort(int left, int right) {
    if(left < right) {
      int pivot = QSPartition(left, right);
      QuickSort(left, pivot - 1);
      QuickSort(pivot + 1, right);
    }
  }
private:
  int                QSPartition(int left, int right) {
    string pivot = m_var[right];
    int i = left - 1;
    for(int j = left; j < right; j++) {
      int cmp = String_CompareExt(m_var[j], pivot, String_CompareMethod_Exact);
      if(cmp < 0) {
        i++;
        Swap(i, j);
      }
    }
    Swap(i + 1, right);
    return i + 1;
  }
private:
  void               Swap(int indexfrom, int indexto) {
    string tmp = m_var[indexfrom];
    m_var[indexfrom] = m_var[indexto];
    m_var[indexto] = tmp;
    tmp = m_data[indexfrom];
    m_data[indexfrom] = m_data[indexto];
    m_data[indexto] = tmp;
  }
public:
  bool               InitByRessource(CArgs&args, bool is_data_sorted, bool sort_data, string separator = "\r\n") {
    Clear();
    int elements = -1;
    string line;
    args.Separator(separator);
    args.Enum();
    while(true) {
      line = args.GetString();
      if(line == NULL)
        break;
      if(line == "")
        continue;
      if(line == "<e>")
        break;
      int p = _StringIndexOf(line, "=");
      if(p >= 0) {
        string var_name = _StringSubstr(line, 0, p);
        AppendRecord();
        m_var[m_cnt - 1] = var_name;
        m_data[m_cnt - 1] = _StringSubstrFrom(line, p + 1);
      } else {
        AppendRecord();
        m_var[m_cnt - 1] = line;
        m_data[m_cnt - 1] = "";
      }
    }
    if(!is_data_sorted) {
      if(sort_data)
        Sort();
      m_sorted = sort_data;
      m_validsorted = sort_data;
    } else {
      m_sorted = true;
      m_validsorted = true;
    }
    m_validdata = true;
    OnLoad();
    return m_cnt > 0;
  }
};
class CTextResourceFile: public CFileSettings {
public:
  void               CTextResourceFile() {
    FlagCommon(true);
    FlagShared(true);
    FlagSorted(true);
    FlagUTF8(true);
  }
public:
  bool               InitByFile(string filename) {
    Close();
    Name("STMTx\\Init\\" + filename, true);
    Refresh();
    for(int i = 0; i < m_cnt; i++)
      m_var[i] = _StringToLower(m_var[i]);
    Sort();
    return IsValid();
  }
};
