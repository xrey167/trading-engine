  bool               SetPoolPanelValuesByFactor(double factor, double sl = PRICE_INVALID, double tp = PRICE_INVALID, double trailbegin = PRICE_INVALID, double traildistance = PRICE_INVALID, ENUM_SEA_TRAILMODE mode = WRONG_VALUE, int trailperiods = 0) {
    if(factor == 0)
      return false;
    if(sl != PRICE_INVALID)
      sl *= factor;
    if(tp != PRICE_INVALID)
      tp *= factor;
    if(trailbegin != PRICE_INVALID)
      trailbegin *= factor;
    if(traildistance != PRICE_INVALID)
      traildistance *= factor;
    return SetPoolPanelValues(sl, tp, trailbegin, traildistance, mode, trailperiods);
  }
  bool               SetPoolPanelValues(double sl = PRICE_INVALID, double tp = PRICE_INVALID, double trailbegin = PRICE_INVALID, double traildistance = PRICE_INVALID, ENUM_SEA_TRAILMODE mode = WRONG_VALUE, int trailperiods = 0) {
    if(TradeMode() == TRADE_MODE_STEREO_FUTURE) {
      if(sl != PRICE_INVALID) {
        SLBuy(sl);
        SLSell(sl);
      }
      if(tp != PRICE_INVALID) {
        TPBuy(tp);
        TPSell(tp);
      }
      if(mode != WRONG_VALUE) {
        TrailModeBuy(mode, traildistance, trailperiods);
        TrailModeSell(mode, traildistance, trailperiods);
      } else {
        if(trailbegin != PRICE_INVALID) {
          TrailBeginBuy(trailbegin);
          TrailBeginSell(trailbegin);
        }
        if(traildistance != PRICE_INVALID) {
          TrailDistanceBuy(traildistance);
          TrailDistanceSell(traildistance);
        }
      }
    } else {
      if(sl != PRICE_INVALID)
        SL(sl);
      if(tp != PRICE_INVALID)
        TP(tp);
      if(mode != WRONG_VALUE)
        TrailMode(mode, traildistance, trailperiods);
      else {
        if(trailbegin != PRICE_INVALID)
          TrailBegin(trailbegin);
        if(traildistance != PRICE_INVALID)
          TrailDistance(traildistance);
      }
    }
    return true;
  }
