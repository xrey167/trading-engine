protected:
  void               _BuildFlags(void) {
    m_flags = 0;
    if(m_read)
      m_flags |= FILE_READ;
    if(m_write)
      m_flags |= FILE_WRITE;
    if(m_common || m_redirect_localtocommon)
      m_flags |= FILE_COMMON;
    if(m_shared && m_read)
      m_flags |= FILE_SHARE_READ;
    if(m_shared && m_write)
      m_flags |= FILE_SHARE_WRITE;
    if(m_ansi)
      m_flags |= FILE_ANSI;
    if(m_utf8)
      m_flags |= FILE_ANSI;
  }
  void               _UpdateFlags(void) {
    m_read = (m_flags & FILE_READ) > 0;
    m_write = (m_flags & FILE_WRITE) > 0;
    m_common = (m_flags & FILE_COMMON) > 0;
    m_shared = (m_flags & FILE_SHARE_READ) > 0 || (m_flags & FILE_SHARE_WRITE) > 0;
    m_ansi = (m_flags & FILE_ANSI) > 0;
    m_utf8 = (m_flags & FILE_ANSI) > 0;
  }
