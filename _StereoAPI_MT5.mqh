bool __MT_Object_Channel_Create(long chartid, string name, int subwin,
                                const datetime time1, const double price1,
                                const datetime time2, const double price2,
                                const datetime time3, const double price3,
                                bool filled = true, uint flags = MT_OBJ_HIDDEN | MT_OBJ_BACKGROUND) {
  if(chartid == NULL)chartid = __CHARTID;
  bool result = ObjectCreate(chartid, name, OBJ_CHANNEL, subwin, __Time.LocalToChart(time1), price1, __Time.LocalToChart(time2), price2, __Time.LocalToChart(time3), price3);
  if(__MT_Object_TP_hiddencreate)
    result &= __MT_Object_SetVisible(chartid, name, false);
  result &= ObjectSetInteger(chartid, name, OBJPROP_FILL, filled);
  result &= __MT_Object_TP_SetFlags(chartid, name, flags);
  __MT_Object_Line_SetRayL(chartid, name, false);
  __MT_Object_Line_SetRayR(chartid, name, false);
  return result;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool __MT_Object_Panel_Create(long chartid, string name, int subwin,
                              const int x, const int y, const int x2, const int y2,
                              const color back_clr, ENUM_BORDER_TYPE border, const color border_clr, int border_width,
                              uint flags = MT_OBJ_HIDDEN | MT_OBJ_BACKGROUND) {
  if(chartid == NULL)chartid = __CHARTID;
  if(!__MT_Object_XY_Create(chartid, name, subwin, OBJ_RECTANGLE_LABEL, x, y, x2, y2))
    return false;
  ObjectSetInteger(chartid, name, OBJPROP_BGCOLOR, back_clr);
  ObjectSetInteger(chartid, name, OBJPROP_BORDER_TYPE, border);
  ObjectSetInteger(chartid, name, OBJPROP_COLOR, border_clr);
  ObjectSetInteger(chartid, name, OBJPROP_STYLE, STYLE_SOLID);
  ObjectSetInteger(chartid, name, OBJPROP_WIDTH, border_width);
  return(true);
  __MT_Object_TP_SetFlags(chartid, name, flags);
}
