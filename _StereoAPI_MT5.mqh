  }
  bool               AddButton(CSButton&button, string caption, string textoff = "OFF", string texton = "ON", bool defaultvalue = false, int width = 0, int height = 0) {
    if(textoff != "OFF" && texton == "ON")
      texton = textoff;
    string savetag = _StringToLower(_StringPack(caption));
    if(_StringIsEmpty(savetag))
      savetag = _StringToLower(_StringPack(textoff));
    return _AddButton(PTR(button), caption, width, height) && button.DefaultValue(defaultvalue) && button.Text(textoff, texton) && button._SettingsID(savetag);
  }
  bool               _AddButton(CSButton*button, string caption, int width = 0, int height = 0) {
    if(width == 0)
      width = m_itemwidth;
    else
      width = __Scale.Int(width);
    if(height == 0)
      height = m_itemheight;
    else
      height = __Scale.Int(height);
    if(caption == NULL && !m_vertical && m_align != SPANEL_ALIGN_BOTTOM_SMALL) {
      int y = GetY() - m_itemheight;
      height = m_itemheight * 2;
      if(!button.Create(m_chart_id, __RNDID, m_subwin, GetX(), y, GetX() + width - 1, y + height - 1))
        return false;
    } else if(!CreateLabel(caption))
      return false;
    if(!button.Create(m_chart_id, __RNDID, m_subwin, GetX(), GetY(), GetX() + width - 1, GetY() + height - 1))
      return false;
    CWndContainer::Add(button);
    m_items++;
    button.LoadDefault();
    button.AssignDialog(PTR(this));
    Skip(width, height);
    return true;
  }
public:
  bool               AddImage(CWndBmp*image, string filename, int x, int y, int w, int h) {
    int xs = __Scale.Int(x);
    int ys = __Scale.Int(y);
    int ws = __Scale.Int(w);
    int hs = __Scale.Int(h);
    image.CreateLocal(xs, ys, xs + ws - 1, ys + hs - 1);
    CWndContainer::Add(image);
    image.FileName(filename);
    return(image.FileName() != NULL);
  }
};
class CSimpleDialog: public CSDialogContainer {
protected:
  bool               m_changed;
  CRect              m_dragrect;
  bool               m_dragenabled;
  bool               m_gridmodeapplied;
public:
  void               CSimpleDialog(void) {
    m_classname = "CSimpleDialog";
    m_isdialog = true;
    m_gridmodeapplied = false;
    Dragable(false);
    DragRect(0, 0, -1, -1);
    __Chart.EventMouseMove(true);
    m_subwin = __MT_GetCurrentSubWindow();
  }
public:
  bool               CreateAbsolute(int x = 0, int y = 0, int w = 0, int h = 0) {
    static int dialogs_total = 0;
    if(!m_gridmodeapplied)
      GridMode(0);
    if(m_settingstag == NULL)
      m_settingstag = "CSDLG" + (string)dialogs_total;
    dialogs_total++;
    if(m_subwin > 0)
      __Chart.Metrics.Update(m_chart_id, m_subwin, true);
    if(w == 0)
      w = __Chart.Metrics.width;
    if(h == 0)
      h = __Chart.Metrics.height;
    if(!Create(__Chart.ChartId(), __RNDID, __Chart.SubWindow(), x, y, x + w - 1, y + h - 1))
      return false;
    m_panel.MouseEventsPassTo(this);
    return __SD_Master.Add(this);
  }
public:
  virtual bool       CreateEnd(bool adjustwidth = true, bool adjustheight = false) {
    int xmax = 0;
    int ymax = 0;
    FOREACH_VAR_IN(CWnd*, child, m_controls) {
      if(child == PTR(m_panel))
        continue;
      xmax = MAX(xmax, child.Right());
      ymax = MAX(ymax, child.Bottom());
    }
    xmax += SPANEL_GAP;
    ymax += SPANEL_GAP;
    if(!adjustwidth)
      xmax = Right();
    if(!adjustheight)
      ymax = Bottom();
    Size(xmax - Left() + 1, ymax - Top() + 1);
    ApplyDesign();
    return true;
  }
public:
  void               DragRect(int x, int y, int w, int h) {
    m_dragrect.left = x;
    m_dragrect.top = y;
    m_dragrect.right = x + w - 1;;
    m_dragrect.bottom = y + h - 1;
  }
public:
  void               DragBy(CWnd*wnd) {
    DragRect(wnd.Left() - Left(), wnd.Top() - Top(), wnd.Width(), wnd.Height());
    wnd.MouseEventsPassTo(this);
  }
public:
  void               DragRect(CRect&rect) {
    m_dragrect = rect;
  }
public:
  void               Dragable(bool flag) {
    m_dragenabled = flag;
  }
public:
  bool               IsDragable() {
    return m_dragenabled;
  }
protected:
  virtual bool       OnMouseMove() {
    static bool isdragging = false;
    static int mx, my;
    if(!IsDragable() && !isdragging)
      return false;
    if(zfu638707147322095783.zfu638707147322096165()) {
      if((m_dragrect.Width() < 0 && m_dragrect.Height() < 0 && m_rect.Contains(zfu638707147322095783.x, zfu638707147322095783.y)) || m_dragrect.Contains(zfu638707147322095783.x - m_rect.left, zfu638707147322095783.y - m_rect.top)) {
        mx = zfu638707147322095783.x - Left();
        my = zfu638707147322095783.y - Top();
        isdragging = true;
        return true;
      }
    }
    if(zfu638707147322095783.zfu638707147322096169() && isdragging) {
      Move(zfu638707147322095783.x - mx, zfu638707147322095783.y - my);
      __Chart.Invalidate();
      return true;
    }
    if(zfu638707147322095783.zfu638707147322096166() && isdragging) {
      isdragging = false;
      return true;
    }
    return false;
  }
public:
  bool               GridMode(bool verticalmode, int defaultwidth = 48, int defaultheight = 16) {
    m_gridmodeapplied = true;
    m_vertical = verticalmode;
    m_itemwidth = __Scale.Int(defaultwidth);
    m_itemheight = __Scale.Int(defaultheight);
    return true;
  }
  bool               ItemWidth(int w) {
    m_itemwidth = __Scale.Int(w);
    return true;
  }
  int                ItemWidth(void) {
    return m_itemwidth;
  }
  bool               ItemHeight(int h) {
    m_itemheight = __Scale.Int(h);
    return true;
  }
  int                ItemHeight(void) {
    return m_itemheight;
  }
public:
  string             Text(int index) {
    if(index < 0 || index >= ControlsTotal())
      return NULL;
    CSEdit*edit = Control(index);
    return edit.Text();
  }
public:
  bool               Text(int index, string newtext) {
    if(index < 0 || index >= ControlsTotal())
      return false;
    CSEdit*edit = Control(index);
    return edit.Text(newtext);
  }
public:
  void               _SetChanged(bool flag) {
    m_changed = flag;
    __SD_Master._SetChanged(flag);
    OnUser();
  }
protected:
  virtual void       OnUser(void) {}
public:
  bool               IsChanged(bool reset = true) {
    bool temp = m_changed;
    m_changed = reset ? false : m_changed;
    return temp;
  }
protected:
  CFileSettings      m_settings_backup;
public:
  void               BufferSettings() {
    m_settings_backup.Clear();
    m_settings_backup.CopyFrom(__SD_Master.GetSettingsFile(), m_settingstag + ":");
  }
public:
  void               RestoreSettings() {
    if(m_settings_backup.SettingsTotal() < 2)
      CWndContainer::SettingsRead(__SD_Master.GetSettingsFile());
    else
      CWndContainer::SettingsRead(m_settings_backup);
    _SetChanged(false);
  }
protected:
  virtual void       OnSettingsRead() {
    _SetChanged(false);
  }
protected:
  virtual void       OnSettingsWrite() {}
public:
  bool               SettingsRead(void) {
    CFileSettings*settings = __SD_Master.GetSettingsFile();
    return CWndContainer::SettingsRead(settings);
  }
public:
  bool               SettingsWrite(void) {
    CFileSettings*settings = __SD_Master.GetSettingsFile();
    return CWndContainer::SettingsWrite(settings);
  }
public:
  virtual bool       zfu638707147322095835(CEAChartEventParams*ce) {
    m_changed = false;
    if(ce.Id == CHARTEVENT_CHART_CHANGE) {
      OnChartChange();
      return false;
    } else if(ce.Id == CHARTEVENT_OBJECT_CLICK || ce.Id == CHARTEVENT_OBJECT_ENDEDIT) {
      FOREACH_VAR_IN_DESC(CWnd*, child, m_controls) {
        if(ce.SParam == child.Name()) {
          child.ProcessChartEvent(ce);
          return true;
        }
      }
    }
    return false;
  }
protected:
  virtual bool       OnResize(void) {
    if(!CSDialogContainer::OnResize())
      return false;
    if(m_subwin != 0)
      ::IndicatorSetInteger(INDICATOR_HEIGHT, Height() + 1);
    return true;
  }
protected:
  virtual bool       OnDestroy(void) {
    __SD_Master.Delete(this);
    return CWndContainer::OnDestroy();
  }
protected:
  virtual bool       OnCreate(void) {
    static int panel_num = 0;
    if(!CWndContainer::OnCreate())
      return false;
    string id = __RNDID;
    if(m_isdialog)
      id = id + "#SEAPANEL#s" + (string)__SD_Master.SEASlot() + "#p" + (string)panel_num;
    if(!m_panel.Create(m_chart_id, id, m_subwin, 0, 0, Width() - 1, Height() - 1))
      return false;
    __MT_Object_SetToolTip(m_chart_id, m_name, NULL);
    Add(m_panel);
    panel_num++;
    return true;
  }
};
class CSEAPanel: public CSimpleDialog {
protected:
  int                m_titlewidth;
  CSButtonClose      m_closebutton;
  CSButtonActivity   m_activity;
  CWndBmp            m_logo;
public:
  void               CSEAPanel() {
    m_classname = "CSEAPanel";
    m_isdialog = true;
    m_titlewidth = __Scale.Int(140);
    Dragable(false);
    DragRect(0, 0, -1, -1);
    SubscribeTo(zfu638707147322095782);
    __EA.SubscribeToMessages(this);
  }
public:
  void              ~CSEAPanel(void) {
    UnsubscribeFrom(zfu638707147322095782);
    __EA.UnsubscribeFromMessages(this);
  }
public:
  bool               CreateInSubWindow(string title, bool small) {
    if(small)
      return CreateDynamic(SPANEL_ALIGN_BOTTOM_SMALL) && AddTitle(title);
    return CreateDynamic(SPANEL_ALIGN_BOTTOM) && AddTitle(title);
  }
public:
  bool               CreateDynamic(ENUM_SPANEL_ALIGN pos = SPANEL_ALIGN_BOTTOM, int w = 0, int h = 0) {
    if(m_subwin > 0) {
      int h1 = pos == SPANEL_ALIGN_BOTTOM_SMALL ? 26 : 42;
      ::IndicatorSetInteger(INDICATOR_HEIGHT, __Scale.Int(h1));
      m_align = pos;
      return CreateAbsolute(0, 0, 0, 0);
    }
    m_align = pos;
    switch(pos) {
    case SPANEL_ALIGN_LEFT:
      return CreateAbsolute(0, __Scale.Int(200), w, h);
    case SPANEL_ALIGN_BOTTOM:
    case SPANEL_ALIGN_BOTTOM_FULLSIZE:
      if(h == 0)
        h = __Scale.Int(42);
      return CreateAbsolute(0, __Chart.Metrics.height, __Chart.Metrics.width, h);
    case SPANEL_ALIGN_BOTTOM_SMALL:
      if(h == 0)
        h = __Scale.Int(24);
      return CreateAbsolute(0, __Chart.Metrics.height, __Chart.Metrics.width, h);
    }
    return false;
  }
public:
  bool               CreateEnd(bool adjustwidth = true, bool adjustheight = false) {
    CSimpleDialog::CreateEnd(adjustwidth, adjustheight);
    _UpdatePos();
    return true;
  }
public:
  virtual void       OnEAMessage(int msg, CNamedArgs*params) {
    if(msg != zfu638707147322096505)return;
    switch(m_align) {
    case WRONG_VALUE:
      return;
    case SPANEL_ALIGN_LEFT:
      return;
    case SPANEL_ALIGN_BOTTOM_FULLSIZE:
      Size(__Chart.Metrics.width, m_rect.Height());
    case SPANEL_ALIGN_BOTTOM_SMALL:
    case SPANEL_ALIGN_BOTTOM:
      _UpdatePos();
    }
  }
public:
  virtual void       OnSubEvent(CObject*sender, int eventid, CNamedArgs*params) {
    if(!IsCreated())return;
    if(sender == PTR(zfu638707147322095782) && eventid == SUBEVENT_INSTANCE_CLIENTSTRUCT)
      _UpdatePos();
    else
      Print(__FUNCTION__, " > ", m_name, " Event: ", eventid, " Params: ", params.ToString());
  }
public:
  virtual void       _UpdatePos() {
    if(m_subwin == 0) {
      Move(0, __Chart.Metrics.height - _GetYOffset() - 1);
    }
  }
public:
  bool               AddTitle(string text, int width = 170) {
    m_items++;
    if(width == 170 && m_align == SPANEL_ALIGN_BOTTOM_SMALL)
      width = 85;
    m_titlewidth = __Scale.Int(width);
    int y = ((Height() - SPANEL_GAP - SPANEL_FONTSIZE_TITLE) / 2) - 2;
    if(m_align == SPANEL_ALIGN_LEFT)
      y = SPANEL_GAP;
    if(!m_title.Create(m_chart_id, __RNDID, m_subwin, SPANEL_SYBUTONWIDTH + (SPANEL_GAP * 2), y, m_titlewidth, __Scale.Int(20)))
      return false;
    m_title.Color(__m_clr_title);
    m_title.Text(text);
    __MT_Object_SetToolTip(m_chart_id, m_title.Name(), NULL);
    m_title.Font(SPANEL_FONTNAME);
    m_title.FontSize(SPANEL_FONTSIZE_TITLE);
    CWndContainer::Add(m_title);
    if(m_align == WRONG_VALUE || m_align == SPANEL_ALIGN_BOTTOM || SPANEL_ALIGN_BOTTOM_FULLSIZE)
      m_x_last = m_titlewidth + SPANEL_GAP;
    else
      m_y_last = (m_itemheight * 2) + SPANEL_GAP;
    __MT_Object_SetToolTip(m_chart_id, m_name, NULL);
    return true;
  }
public:
  bool               AddLogo(string filename, int width = -1) {
    Title("");
    if(width != -1) {
      m_titlewidth = __Scale.Int(width);
      m_x_last = m_titlewidth + SPANEL_GAP;
    }
    int x = __Scale.Int(170 - 90) / 2;
    int y = __Scale.Int(4) / 2;
    if(m_logo.Name() == NULL) {
      if(m_align != SPANEL_ALIGN_BOTTOM_SMALL)
        m_logo.CreateLocal(x, y, __Scale.Int(-90), __Scale.Int(-40));
      else
        m_logo.CreateLocal(x / 2, y, __Scale.Int(-48), __Scale.Int(-24));
      CWndContainer::Add(m_logo);
    }
    m_logo.FileName(filename);
    return(m_logo.FileName() != NULL);
  }
public:
