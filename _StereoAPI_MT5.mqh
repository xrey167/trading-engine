  CHART_PROPERTIES_METHOD_NONE = 0,
  CHART_PROPERTIES_METHOD_NATIVE = 1,
  CHART_PROPERTIES_METHOD_SEA = 2,
};
#define CChartBase CChart
class CChartExt: public CChartBase {
protected:
  int                m_subwin;
  bool               m_cleanup;
  int                m_hwndchart;
