  ARROW_ARROW2_SE = 238,
  ARROW_ARROW3_LEFT = 239,
  ARROW_ARROW3_RIGHT = 240,
  ARROW_ARROW3_UP = 241,
  ARROW_ARROW3_DOWN = 242,
  ARROW_ARROW3_NW = 243,
