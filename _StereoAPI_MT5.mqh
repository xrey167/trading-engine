    chart.TraceLineInit(1, m_sea_base.zfu638707147322096757.clr_bull, 2, STYLE_SOLID, "TP long @%price");
    chart.TraceLineInit(2, m_sea_base.zfu638707147322096757.clr_bear, 2, STYLE_SOLID, "SL short @%price");
    chart.TraceLineInit(3, m_sea_base.zfu638707147322096757.clr_bull, 2, STYLE_SOLID, "TP short @%price");
    chart.TraceLineInit(4, m_sea_base.zfu638707147322096757.clr_bull, 1, STYLE_DASH, "BE long @%price");
    chart.TraceLineInit(5, m_sea_base.zfu638707147322096757.clr_bear, 1, STYLE_DASH, "BE short @%price");
