class CIndicatorValueBuffers: public CObjectList {
protected:
  ENUM_INDICATOR     m_scantype;
  int                m_scanpos;
  string             m_symbolname;
  ENUM_TIMEFRAMES    m_timeframe;
  CIndicatorValueBuffer*buffer_last;
  ENUM_INDICATOR     type_last;
  string             idparams_last;
  ENUM_TIMEFRAMES    timeframe_last;
public:
                     CIndicatorValueBuffers() {
    Reset();
  }
                    ~CIndicatorValueBuffers() {
    FOREACH_VAR_IN(CObject*, object, this) {
      PTR_DELETE(object);
    }
    ArrayFree(Object);
  }
  void               Reset(void) {
    CIndicatorValueBuffer*buffer = FindFirst(WRONG_VALUE);
    while(buffer != NULL) {
      buffer.Reset();
      buffer = FindNext();
    }
    CObjectList::Reset();
    buffer_last = NULL;
    idparams_last = NULL;
    type_last = WRONG_VALUE;
    timeframe_last = WRONG_VALUE;
    DeleteOnDestruct(true);
  }
  void               SymbolNameGlobal(string name) {
    m_symbolname = name;
  }
  string             SymbolNameGlobal(void) {
    return m_symbolname;
  }
  void               TimeFrameGlobal(ENUM_TIMEFRAMES tf) {
    m_timeframe = tf;
  }
  ENUM_TIMEFRAMES    TimeFrameGlobal(void) {
    return m_timeframe;
  }
                     CIndicatorValueBuffer*_Create(ENUM_INDICATOR type, double p1 = VALUE_INVALID, double p2 = VALUE_INVALID, double p3 = VALUE_INVALID, double p4 = VALUE_INVALID, double p5 = VALUE_INVALID) {
    CIndicatorValueBuffer*buffer = new CIndicatorValueBuffer();
    if(!buffer._Create(type, p1, p2, p3, p4, p5)) {
      delete buffer;
      return NULL;
    }
    Add(buffer);
    return buffer;
  }
                     CIndicatorValueBuffer*_Find(ENUM_INDICATOR type, string idparams) {
    FOREACH_VAR_IN(CIndicatorValueBuffer*, buffer, this) {
      if(buffer.Type == type && buffer.TimeFrameRO == m_timeframe && buffer.IdParams == idparams)
        return buffer;
    }
    return NULL;
  }
                     CIndicatorValueBuffer*Find(ENUM_INDICATOR type, double p1 = VALUE_INVALID, double p2 = VALUE_INVALID, double p3 = VALUE_INVALID, double p4 = VALUE_INVALID, double p5 = VALUE_INVALID) {
    string idparams = MakeParams(p1, p2, p3, p4, p5);
    if(type == type_last && timeframe_last == m_timeframe && idparams == idparams_last)
      return buffer_last;
    buffer_last = _Find(type, idparams);
    if(buffer_last != NULL) {
      idparams_last = idparams;
      type_last = type;
      timeframe_last = m_timeframe;
    }
    return buffer_last;
  }
                     CIndicatorValueBuffer*FindFirst(ENUM_INDICATOR type) {
    m_scanpos = 0;
    m_scantype = type;
    return FindNext();
  }
                     CIndicatorValueBuffer*FindNext(void) {
    CIndicatorValueBuffer*buffer = NULL;
    while(m_scanpos < m_data_total) {
      m_scanpos++;
      if(PTR_VALID(Object[m_scanpos - 1])) {
        buffer = Object[m_scanpos - 1];
        if(buffer.Type == m_scantype || m_scantype == WRONG_VALUE)
          return buffer;
      }
    }
    return NULL;
  }
protected:
  string             MakeParams(double p1 = VALUE_INVALID, double p2 = VALUE_INVALID, double p3 = VALUE_INVALID, double p4 = VALUE_INVALID, double p5 = VALUE_INVALID) {
    if(p1 == VALUE_INVALID)
      return NULL;
    else if(p2 == VALUE_INVALID)
      return(string)p1;
    else if(p3 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2;
    else if(p4 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3;
    else if(p5 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3 + "#" + (string)p4;
    else
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3 + "#" + (string)p4 + "#" + (string)p5;
  }
};
