class CRandomObjectName {
private:
  string             m_next;
  string             m_last;
  string             m_prefix;
  long               m_chartid;
  int                m_chartsubwin;
  long               m_id;
  string             m_baseid;
public:
                     CRandomObjectName() {
    m_next = NULL;
    m_last = NULL;
    m_id = -1;
    Init();
  }
                     CRandomObjectName(string prefix) {
    m_next = NULL;
    m_last = NULL;
    m_id = -1;
    Init(prefix);
  }
  string             GetId(string prefix = NULL) {
    if(m_next != NULL) {
      string v = m_next;
      m_next = NULL;
      return v;
    }
    while(true) {
      m_id++;
      m_last = m_baseid + (string)m_id + "#";
      if(!__MT_Object_Exists(__CHARTID, m_last))
        return m_last;
      if(::IsStopped())
        break;
    }
    return NULL;
  }
  string             GetPrev() {
    return m_last;
  }
  string             Prefix() {
    return m_prefix;
  }
  bool               IsRandomId(string id, string prefix, long chartid, int subwin) {
    if(prefix == NULL)prefix = m_prefix;
    if(chartid == NULL)chartid = __CHARTID;
    if(subwin == NULL)subwin = __MT_GetCurrentSubWindow();
    string baseid = CreateBaseId(prefix, chartid, subwin);
    return(_StringIndexOf(id, baseid) == 0);
  }
  bool               IsRandomId(string id) {
    return _StringIndexOf(id, "#VO#") > 0;
  }
  void               Init(string prefix = NULL, long chartid = 0, int subwin = -1) {
    m_prefix = prefix == NULL ? "DH" : prefix;
    m_chartid = chartid == 0 ? __CHARTID : chartid;
    m_chartsubwin = subwin == -1 ? __MT_GetCurrentSubWindow() : subwin;
    m_baseid = CreateBaseId(m_prefix, m_chartid, m_chartsubwin);
  }
  void               SetNextId(string id) {
    m_next = id;
  }
  void               DeleteAll() {
    ::ObjectsDeleteAll(m_chartid, m_baseid, __MT_GetCurrentSubWindow());
  }
  void               DeleteAll(ulong id) {
    string match = "#" + (string)id + "#";
    __MT_Object_DeleteAll(m_chartid, match, __MT_GetCurrentSubWindow(), -1, false);
  }
private:
  string             CreateBaseId(string prefix, long chartid, int chartsubwin) {
    string instanceidstr = (string)__EA.InstanceId();
    return prefix + "#" + instanceidstr + "#" + (string)chartsubwin + "#VO#";
  }
};
CRandomObjectName __RndID;
#define __RNDID __RndID.GetId()
