bool _FileDelete(string filename, bool commonfolder = false) {
  if(commonfolder)
    return::FileDelete(filename, FILE_COMMON);
  return::FileDelete(filename, 0);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool _FileDeleteAll(string path, string mask = "*.*", bool commonfolder = false, bool ignore_is_stopped = false) {
  string filename = NULL;
  long handle =::FileFindFirst(path + "\\" + mask, filename, commonfolder ? FILE_COMMON : 0);
  if(handle == INVALID_HANDLE)
    handle =::FileFindFirst(path + mask, filename, commonfolder ? FILE_COMMON : 0);
  if(handle == INVALID_HANDLE)
    return false;
  while(!::IsStopped() || ignore_is_stopped) {
    _FileDelete(path + "\\" + filename, commonfolder);
    if(!::FileFindNext(handle, filename))
      break;
  }
  return true;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool _FileExists(string filename, bool commonfolder = false) {
  return::FileIsExist(filename, commonfolder ? FILE_COMMON : 0);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool _FileNameSplit(string path, string&subdir, string&filename) {
  int p = _StringIndexOf(path, "\\");
  int plast = p;
  while(p >= 0) {
    plast = p;
    p = _StringIndexOfFrom(path, "\\", plast + 1);
  }
  if(plast < 0) {
    subdir = ".";
    filename = path;
  } else {
    subdir = _StringSubstr(path, 0, plast);
    filename = _StringSubstrFrom(path, plast + 1);
  }
  return true;
}
