    return m_title.Text();
  }
public:
  bool               _AddSysButtons(bool closebutton, bool atbutton) {
    int w = __Scale.Int(SPANEL_SYBUTONWIDTH);
    int gap = __Scale.Int(1);
    if(closebutton) {
