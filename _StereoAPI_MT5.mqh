    gmtlocal = -(TimeGMTOffset()) / 3600;
    if(gmtlocal > -1 && gmtlocal < 3)
      srlocal = SUMMERTIMERULE_EU;
    else if(gmtlocal >= 3)
      srlocal = SUMMERTIMERULE_RU;
    else if(gmtlocal < -1)
