    if(!m_active)return -1;
    double level = low + (fibomult * (high - low));
    if(tooltip == NULL)
      tooltip = text;
    string levelstring = DoubleToString(fibomult * 100, 1);
    StringReplace(text, "%level", levelstring);
    StringReplace(tooltip, "%level", levelstring);
    return LineTrend(text, timebegin, level, timeend, level, clr, width, style, tooltip);
