public:
  int                PriceToY(double price) {
    double pricerange = Metrics.price_max - Metrics.price_min;
    if(pricerange == 0)return -1;
    return Metrics.height - (int)((price - Metrics.price_min) * Metrics.height / pricerange);
  }
public:
  double             YToPrice(int y) {
    if(Metrics.height == 0)return PRICE_INVALID;
    return Metrics.price_max - ((y * (Metrics.price_max - Metrics.price_min) / Metrics.height));
  }
public:
  int                TimeToX(datetime time) {
    int x = -1;
    int bar_shift = m_bars.GetBarShift(time, 0, BARSHIFT_EXACT);
    if(bar_shift > -1) {
      int pix_between_bars = Metrics.PixBetweenBars();
      int xdiff = LastBarX() - (Metrics.firstbar_shift * pix_between_bars);
      x = LastBarX() - (bar_shift * pix_between_bars);
      x -= xdiff;
    }
    return x;
  }
public:
  bool               PriceTimeToXY(double price, datetime time, int&x, int&y, int subwin = 0) {
    x = TimeToX(time);
    y = PriceToY(price);
    return(x > -1 && y > -1) ? true : false;
  }
public:
  datetime           XToTime(int x) {
    int pix_between_bars = Metrics.PixBetweenBars();
    double bar_number =::MathRound(Metrics.firstbar_shift - x / (double)pix_between_bars);
    return(bar_number < 0) ? m_bars.Time(0) - (datetime)(bar_number * m_bars.TimeFrameSeconds())
          : m_bars.Time((int)bar_number);
  }
public:
  bool               XYToPriceTime(int x, int y, double&price, datetime&time) {
    time = XToTime(x);
    price = YToPrice(y);
    return((long)time > 0 && price != PRICE_INVALID);
  }
public:
  int                MaxY(void) {
    return Metrics.height - Metrics.max_y - 1;
  }
public:
  bool               MaxYSub(int y) {
    Metrics.max_y = y;
    return true;
  }
