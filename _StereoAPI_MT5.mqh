#import
#define WS_EX_NOPARENTNOTIFY 0x00000004
#define WS_EX_NOREDIRECTIONBITMAP 0x00200000
#define WS_EX_TRANSPARENT 0x00000020
HWND User32_CreateEmptyWindow(string classname = NULL) {
  DWORD styleex = WS_EX_NOPARENTNOTIFY | WS_EX_NOREDIRECTIONBITMAP | WS_EX_TRANSPARENT;
  DWORD style = 0;
  HWND hwndparent = 0;
  int hinstance = 0;
  if(classname == NULL)classname = "Button";
  HWND hwnd = CreateWindowExW(styleex, classname, "", style, -101, 0, 100, 50, hwndparent, NULL, hinstance, NULL);
  return hwnd;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
HWND User32_GetParent(HWND hwnd, int level = 1) {
  if(level == 0)
    return hwnd;
  for(int i = 0; i < level; i++)
    hwnd = user32::GetParent(hwnd);
  return hwnd;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string User32_GetClassName(HWND hwnd) {
  char chars[256];
  int n =::user32::GetClassNameA(hwnd, chars, 255);
  return CharArrayToString(chars, 0, n);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string User32_GetWindowText(HWND hwnd) {
  char chars[1024];
  int n =::user32::GetWindowTextA(hwnd, chars, 1024);
  return CharArrayToString(chars, 0, n);
}
