    uint b = (uint)(uchar((rgb1) >> 0) * mix + uchar((rgb2) >> 0) * mix);
    uint a = (uint)(uchar((rgb1) >> 24) * mix + uchar((rgb2) >> 24) * mix);
    c = ((uchar(a) << 24) | (uchar(r) << 16)) | (uchar(g) << 8) | (uchar(b));
    return(zfu638707147322095968)c;
  }
};
