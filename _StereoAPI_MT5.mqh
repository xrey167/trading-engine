/* ******* File: Bars.mqh:0 ******* [C:\Users\Developer\AppData\Roaming\MetaQuotes\Terminal\947D1F23CFC70D75721C3B799EAB444A\MQL5\include\StereoTrader_API\Bars.mqh]*/
/* ******* File: Bars.mqh:12 ******* */
/* ******* File: Indicators.mqh:0 ******* [C:\Users\Developer\AppData\Roaming\MetaQuotes\Terminal\947D1F23CFC70D75721C3B799EAB444A\MQL5\include\StereoTrader_API\Indicators.mqh]*/
#define __DH_INDICATORS_CLASS
#define SHIFTTOINDEX(shift) (_Count()-shift-1)
class CIndicatorValueBuffers;
class CIndicatorValueBuffer: public CObject {
public:
  ENUM_INDICATOR     Type;
  string             IdParams;
  double             Param[];
  int                CntParams;
  ENUM_TIMEFRAMES    TimeFrameRO;
protected:
  CIndicatorValueBuffers*m_buffers;
  int                m_minindex;
  int                m_maxindex;
  double             m_value[];
  string             m_symbolname;
  ENUM_TIMEFRAMES    m_timeframe;
public:
  void               CIndicatorValueBuffer() {
    Assign(NULL);
    Reset();
  }
public:
  void              ~CIndicatorValueBuffer() {
    Reset();
  }
public:
  void               Reset() {
    _Reset(true);
  }
private:
  void               _Reset(bool reassignfromglobal) {
    Type = WRONG_VALUE;
    m_minindex = -1;
    m_maxindex = -1;
    IdParams = NULL;
    CntParams = 0;
    ArrayFree(Param);
    ArrayFree(m_value);
    if(reassignfromglobal)
      Assign(m_buffers);
    OnReset();
  }
public:
  void               Assign(CIndicatorValueBuffers*buffers) {
    m_buffers = buffers;
    if(PTR_VALID(buffers)) {
      m_symbolname = m_buffers.SymbolNameGlobal();
      m_timeframe = m_buffers.TimeFrameGlobal();
      TimeFrameRO = m_timeframe;
    }
  }
  void               TimeFrame(ENUM_TIMEFRAMES tf) {
    m_timeframe = tf;
    TimeFrameRO = tf;
    _Reset(false);
  }
  ENUM_TIMEFRAMES    TimeFrame(void) {
    return m_timeframe;
  }
  void               SymbolName(string name) {
    m_symbolname = name;
    _Reset(false);
  }
  string             SymbolName(void) {
    return m_symbolname;
  }
public:
  bool               _Create(ENUM_INDICATOR type, double p1 = VALUE_INVALID, double p2 = VALUE_INVALID, double p3 = VALUE_INVALID, double p4 = VALUE_INVALID, double p5 = VALUE_INVALID) {
    if(Type != WRONG_VALUE)
      return false;
    Type = type;
    m_minindex = -1;
    m_maxindex = -1;
    CntParams = 0;
    ArrayResize(Param, 5);
    Param[0] = p1;
    Param[1] = p2;
    Param[2] = p3;
    Param[3] = p4;
    Param[4] = p5;
    if(p1 != VALUE_INVALID) {
      CntParams++;
    }
    if(p2 != VALUE_INVALID) {
      CntParams++;
    }
    if(p3 != VALUE_INVALID) {
      CntParams++;
    }
    if(p4 != VALUE_INVALID) {
      CntParams++;
    }
    if(p5 != VALUE_INVALID) {
      CntParams++;
    }
    IdParams = MakeParams(p1, p2, p3, p4, p5);
    if(PTR_VALID(m_buffers))
      m_buffers.Add(PTR(this));
    return true;
  }
public:
  double             Value(int shift) {
    int pos = SHIFTTOINDEX(shift);
    double value = Get(pos);
    if(value != PRICE_INVALID)
      return value;
    value = OnGetValue(shift, pos);
    Set(pos, value);
    return value;
  }
protected:
  virtual double     OnGetValue(int shift, int pos) {
    return PRICE_INVALID;
  }
protected:
  bool               Set(int pos, double value, int index = 0) {
    if(pos < 0)
      return false;
    if(m_minindex == -1) {
      m_minindex = pos;
      m_maxindex = pos;
      ArrayResize(m_value, 1, 32);
    } else if(pos < m_minindex) {
      int shiftleft = m_minindex - pos;
      ArrayResize(m_value, m_maxindex + 1 + shiftleft);
      ArrayCopy(m_value, m_value, 0, shiftleft, m_maxindex - m_minindex + 1);
      m_minindex = pos;
    }
    if(m_maxindex < pos) {
      if(!ArrayResize(m_value, pos + 1 - m_minindex, 32))
        return false;
      int cnt = (pos - m_minindex) - (m_maxindex - m_minindex) - 1;
      ArrayFill(m_value, m_maxindex + 1 - m_minindex, cnt, PRICE_INVALID);
      m_maxindex = pos;
    }
    m_value[pos - m_minindex] = value;
    return true;
  }
protected:
  double             Get(int pos, int index = 0) {
    if(pos < 0 || pos > m_maxindex || pos < m_minindex)return PRICE_INVALID;
    return m_value[pos - m_minindex];
  }
public:
  virtual bool       Compare(CIndicatorValueBuffer*buffer) {
    return buffer.Type == Type && buffer.IdParams == IdParams;
  }
protected:
  string             MakeParams(double p1 = VALUE_INVALID, double p2 = VALUE_INVALID, double p3 = VALUE_INVALID, double p4 = VALUE_INVALID, double p5 = VALUE_INVALID) {
    if(p1 == VALUE_INVALID)
      return NULL;
    else if(p2 == VALUE_INVALID)
      return(string)p1;
    else if(p3 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2;
    else if(p4 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3;
    else if(p5 == VALUE_INVALID)
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3 + "#" + (string)p4;
    else
      return(string)p1 + "#" + (string)p2 + "#" + (string)p3 + "#" + (string)p4 + "#" + (string)p5;
  }
  int                _Count() {
    return::Bars(m_symbolname, m_timeframe);
  }
  double             _Open(int shift = 0) {
    double p[];
    if(::CopyOpen(m_symbolname, m_timeframe, shift, 1, p) <= 0)return PRICE_INVALID;
    return p[0];
  }
  double             _Close(int shift = 0) {
    double p[];
    if(::CopyClose(m_symbolname, m_timeframe, shift, 1, p) <= 0)return PRICE_INVALID;
    return p[0];
  }
  double             _Low(int shift = 0) {
    double p[];
    if(::CopyLow(m_symbolname, m_timeframe, shift, 1, p) <= 0)return PRICE_INVALID;
    return p[0];
  }
  double             _High(int shift = 0) {
    double p[];
    if(::CopyHigh(m_symbolname, m_timeframe, shift, 1, p) <= 0)return PRICE_INVALID;
    return p[0];
  }
  double             _Range(int shift = 0) {
    return _High(shift) - _Low(shift);
  }
  double             _TrueRange(int shift = 0) {
    double tr = 0;
    MqlRates r = _Rates(shift);
    MqlRates r1 = _Rates(shift + 1);
    if(r1.close <= 0 || r.close <= 0)
      return 0;
    tr = MAX(MAX(r.high - r.low, r.high - r1.close), r.low - r1.close);
    return tr;
  }
  MqlRates           _Rates(int shift = 0) {
    MqlRates r[];
    if(::CopyRates(m_symbolname, m_timeframe, shift, 1, r) <= 0) {
      MqlRates f;
      f.close = PRICE_INVALID;
      f.open = PRICE_INVALID;
      f.low = PRICE_INVALID;
      f.high = PRICE_INVALID;
      return f;
    }
    return r[0];
  }
  bool               _Rates(int shift, int cnt, MqlRates&rates[]) {
    return(::CopyRates(m_symbolname, m_timeframe, shift, cnt, rates) == cnt);
  }
  bool               _OLHC(double&o, double&l, double&h, double&c, int shift = 0) {
    MqlRates r = _Rates(shift);
    if(r.close <= 0)
      return false;
    c = r.close;
    o = r.open;
    l = r.low;
    h = r.high;
    return true;
  }
protected:
  virtual void       OnReset() {}
};
