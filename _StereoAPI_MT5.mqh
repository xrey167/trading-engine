class CMTTerminal: public CTerminalInfo {
public:
  bool               IsDLLsAllowed() {
    return(bool)::TerminalInfoInteger(TERMINAL_DLLS_ALLOWED);
  }
  bool               IsConnected() {
    return(bool)::TerminalInfoInteger(TERMINAL_CONNECTED);
  }
  bool               IsStopped() {
    return::IsStopped();
  }
  bool               IsTesting() {
    return::MQLInfoInteger(MQL_TESTER) != 0;
  }
  bool               IsTradeAllowed() {
    return::MQLInfoInteger(MQL_TRADE_ALLOWED) && (bool)::TerminalInfoInteger(TERMINAL_TRADE_ALLOWED);
  }
  bool               IsTestingVisual() {
    return::MQLInfoInteger(MQL_VISUAL_MODE) != 0;
  }
  string             Path() {
    return::TerminalInfoString(TERMINAL_PATH);
  }
  string             DataPath() {
    return::TerminalInfoString(TERMINAL_DATA_PATH);
  }
  string             FilesPath() {
    return DataPath() + "\\MQL5\\Files";
  }
  string             DataId() {
    string id = DataPath();
    while(_StringIndexOf(id, "\\") >= 0)
      id = _StringSubstrFrom(id, _StringIndexOf(id, "\\") + 1);
    return id;
  }
  string             DataPathCommon() {
    return::TerminalInfoString(TERMINAL_COMMONDATA_PATH);
  }
  string             FilesPathCommon() {
    return DataPathCommon() + "\\Files";
  }
  int                ScreenDPI() {
    return(int)::TerminalInfoInteger(TERMINAL_SCREEN_DPI);
  }
  int                ScaleToScreen(int size) {
    double f = (double)ScreenDPI() / 96.0;
    return(int)(double(size) * f);
  }
  double             ScaleToScreen(double size) {
    double f = (double)ScreenDPI() / 96.0;
    return size * f;
  }
  bool               IsExpert(void) {
    return::MQLInfoInteger(MQL_PROGRAM_TYPE) == PROGRAM_EXPERT;
  }
  bool               IsIndicator(void) {
    return::MQLInfoInteger(MQL_PROGRAM_TYPE) == PROGRAM_INDICATOR;
  }
  bool               IsScript(void) {
    return::MQLInfoInteger(MQL_PROGRAM_TYPE) == PROGRAM_SCRIPT;
  }
};
