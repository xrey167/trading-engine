int chartmetrics_pix_between_bars = 1;
bool chartmetrics_pix_between_bars_valid = false;
struct SChartMetrics {
  int                width;
  int                height;
  int                offset_y;
  bool               shift_status;
  double             shift_size;
  double             price_min;
  double             price_max;
  int                firstbar_shift;
  int                cntbars;
  int                scale;
  int                lastbar_x;
  datetime           time_min;
  datetime           time_max;
  int                max_x;
  int                max_y;
  void               Update(long chart_id = NULL, int subwin = -1, bool subwin_related_only = false) {
    if(chart_id == NULL)chart_id = __MT_GetCurrentChartID();
    if(subwin == -1)subwin = __MT_GetCurrentSubWindow();
    __MT_GetChartMetrics(chart_id, subwin, this, subwin_related_only);
  }
  void               UpdatePixBetweenBars() {
    int x_first, x_next, y;
    string symbolname =::Symbol();
    long chartid =::ChartID();
    ENUM_TIMEFRAMES tf = __MT_GetCurrentTimeframe();
    MqlRates rates[2];
    if(::CopyRates(symbolname, tf, 1, 2, rates) != 2) {
      chartmetrics_pix_between_bars = 1;
      chartmetrics_pix_between_bars_valid = false;
      return;
    }
    ::ChartTimePriceToXY(chartid, 0, rates[1].time, price_min, x_first, y);
    ::ChartTimePriceToXY(chartid, 0, rates[0].time, price_min, x_next, y);
    chartmetrics_pix_between_bars = x_first - x_next;
    chartmetrics_pix_between_bars_valid = chartmetrics_pix_between_bars > 0;
    if(!chartmetrics_pix_between_bars_valid)
      chartmetrics_pix_between_bars = 1;
  }
  int                PixBetweenBars() {
    if(!chartmetrics_pix_between_bars_valid)UpdatePixBetweenBars();
    return chartmetrics_pix_between_bars;
  }
  string             ToString() {
    string result = "";
    string sep = "|";
    _StringAddN(result, (string)width);
    _StringAddN(result, sep);
    _StringAddN(result, (string)height);
    _StringAddN(result, sep);
    _StringAddN(result, (string)offset_y);
    _StringAddN(result, sep);
    _StringAddN(result, BOOL_TO_STR(shift_status));
    _StringAddN(result, sep);
    _StringAddN(result, DoubleToString(shift_size, 2));
    _StringAddN(result, sep);
    _StringAddN(result, DoubleToString(price_min));
    _StringAddN(result, sep);
    _StringAddN(result, DoubleToString(price_max));
    _StringAddN(result, sep);
    _StringAddN(result, (string)firstbar_shift);
    _StringAddN(result, sep);
    _StringAddN(result, (string)cntbars);
    _StringAddN(result, sep);
    _StringAddN(result, (string)scale);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)time_min);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)time_max);
    _StringAddN(result, sep);
    _StringAddN(result, (string)max_x);
    _StringAddN(result, sep);
    _StringAddN(result, (string)max_y);
    _StringAddN(result, sep);
    _StringAddN(result, (string)chartmetrics_pix_between_bars);
    return result;
  }
  bool               FromString(string value) {
    string data[];
    ushort sep = StringGetCharacter("|", 0);
    int n = StringSplit(value, sep, data);
    if(n != 15)return false;
    width = (int)data[0];
    height = (int)data[1];
    offset_y = (int)data[2];
    shift_status = STR_TO_BOOL(data[3]);
    shift_size = StringToDouble(data[4]);
    price_min = StringToDouble(data[5]);
    price_max = StringToDouble(data[6]);
    firstbar_shift = (int)data[7];
    cntbars = (int)data[8];
    scale = (int)data[9];
    time_min = (datetime)(long)data[10];
    time_max = (datetime)(long)data[11];
    max_x = (int)data[12];
    max_y = (int)data[13];
    chartmetrics_pix_between_bars = (int)data[14];
    chartmetrics_pix_between_bars_valid = true;
    return true;
  }
};
double schartcolors_brightness = 0;
bool schartcolors_adaptivebarcolors = false;
struct SChartColors {
  color              Background;
  color              Foreground;
  color              Grid;
  color              BarUp;
  color              BarDown;
  color              CandleBull;
  color              CandleBear;
  color              LineChart;
  color              Volumes;
  color              LinePriceBid;
  color              LinePriceAsk;
  color              LinePriceLast;
  color              StopLevels;
  double             Brightness() {
    return schartcolors_brightness;
  }
  void               AdaptiveBarColors(bool flag) {
    if(flag == schartcolors_adaptivebarcolors)return;
    schartcolors_adaptivebarcolors = flag;
    AdaptBarColors();
  }
  bool               AdaptiveBarColors() {
    return schartcolors_adaptivebarcolors;
  }
  bool               Update(long chartid = NULL) {
    long l_value;
    bool changed = false;
    if(chartid == NULL)chartid = __MT_GetCurrentChartID();
    schartcolors_brightness = zfu638707147322095794(Background);
    if(!::ChartGetInteger(chartid, CHART_COLOR_BACKGROUND, 0, l_value))return false;
    changed |= l_value != (long)Background;
    Background = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_FOREGROUND, 0, l_value))return false;
    changed |= l_value != (long)Foreground;
    Foreground = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_GRID, 0, l_value))return false;
    changed |= l_value != (long)Grid;
    Grid = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_CHART_UP, 0, l_value))return false;
    changed |= l_value != (long)BarUp;
    BarUp = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_CHART_DOWN, 0, l_value))return false;
    changed |= l_value != (long)BarDown;
    BarDown = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_CANDLE_BULL, 0, l_value))return false;
    changed |= l_value != (long)CandleBull;
    CandleBull = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_CANDLE_BEAR, 0, l_value))return false;
    changed |= l_value != (long)CandleBear;
    CandleBear = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_CHART_LINE, 0, l_value))return false;
    changed |= l_value != (long)LineChart;
    LineChart = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_VOLUME, 0, l_value))return false;
    changed |= l_value != (long)Volumes;
    Volumes = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_BID, 0, l_value))return false;
    changed |= l_value != (long)LinePriceBid;
    LinePriceBid = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_ASK, 0, l_value))return false;
    changed |= l_value != (long)LinePriceAsk;
    LinePriceAsk = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_STOP_LEVEL, 0, l_value))return false;
    changed |= l_value != (long)StopLevels;
    StopLevels = (color)l_value;
    if(!::ChartGetInteger(chartid, CHART_COLOR_LAST, 0, l_value))return false;
    changed |= l_value != (long)LinePriceLast;
    LinePriceLast = (color)l_value;
    schartcolors_brightness = zfu638707147322095794(Background);
    return changed;
  }
  void               AdaptBarColors(long chartid = NULL) {
    if(chartid == NULL)chartid = __MT_GetCurrentChartID();
    if(::ChartGetInteger(chartid, CHART_MODE) == CHART_BARS) {
      BarUp = CandleBull;
      BarDown = CandleBear;
    } else if(schartcolors_adaptivebarcolors) {
      int scale = (int)::ChartGetInteger(chartid, CHART_SCALE);
      int percentage = scale * 100 / 5;
      if(schartcolors_brightness < 0.5)
        percentage = scale * 67 / 5;
      color clrMix = schartcolors_brightness < 0.5 ? clrLightGray : clrBlack;
      BarUp = zfu638707147322095800(CandleBull, clrMix, percentage);
      BarDown = zfu638707147322095800(CandleBear, clrMix, percentage);
      if(chartmetrics_pix_between_bars < 4) {
        double contrast = zfu638707147322095795(BarUp, Background);
        if(contrast < 0.03) {
          BarUp = clrMix;
        }
        contrast = zfu638707147322095795(BarDown, Background);
        if(contrast < 0.02) {
          BarDown = clrMix;
        }
      }
    }
    ::ChartSetInteger(chartid, CHART_COLOR_CHART_UP, 0, (long)BarUp);
    ::ChartSetInteger(chartid, CHART_COLOR_CHART_DOWN, 0, (long)BarDown);
  }
  bool               Apply(long chartid = NULL) {
    bool success = false;
    if(chartid == NULL)chartid = __MT_GetCurrentChartID();
    success |=::ChartSetInteger(chartid, CHART_COLOR_BACKGROUND, 0, (long)Background);
    success |=::ChartSetInteger(chartid, CHART_COLOR_FOREGROUND, 0, (long)Foreground);
    success |=::ChartSetInteger(chartid, CHART_COLOR_GRID, 0, (long)Grid);
    success |=::ChartSetInteger(chartid, CHART_COLOR_CANDLE_BULL, 0, (long)CandleBull);
    success |=::ChartSetInteger(chartid, CHART_COLOR_CANDLE_BEAR, 0, (long)CandleBear);
    AdaptBarColors(chartid);
    success |=::ChartSetInteger(chartid, CHART_COLOR_CHART_LINE, 0, (long)LineChart);
    success |=::ChartSetInteger(chartid, CHART_COLOR_VOLUME, 0, (long)Volumes);
    success |=::ChartSetInteger(chartid, CHART_COLOR_BID, 0, (long)LinePriceBid);
    success |=::ChartSetInteger(chartid, CHART_COLOR_ASK, 0, (long)LinePriceAsk);
    success |=::ChartSetInteger(chartid, CHART_COLOR_STOP_LEVEL, 0, (long)StopLevels);
    success |=::ChartSetInteger(chartid, CHART_COLOR_LAST, 0, (long)LinePriceLast);
    schartcolors_brightness = zfu638707147322095794(Background);
    return success;
  }
  string             ToString() {
    string result = "", sep = "|";
    _StringAddN(result, (string)(long)Background);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)Foreground);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)Grid);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)BarUp);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)BarDown);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)CandleBull);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)CandleBear);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)LineChart);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)Volumes);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)LinePriceBid);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)LinePriceAsk);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)StopLevels);
    _StringAddN(result, sep);
    _StringAddN(result, (string)(long)LinePriceLast);
    return result;
  }
  bool               FromString(string value) {
    string data[];
    ushort sep = StringGetCharacter("|", 0);
    int n = StringSplit(value, sep, data);
    if(n != 13)return false;
    Background = (color)(long)data[0];
    Foreground = (color)(long)data[1];
    Grid = (color)(long)data[2];
    BarUp = (color)(long)data[3];
    BarDown = (color)(long)data[4];
    CandleBull = (color)(long)data[5];
    CandleBear = (color)(long)data[6];
    LineChart = (color)(long)data[7];
    Volumes = (color)(long)data[8];
    LinePriceBid = (color)(long)data[9];
    LinePriceAsk = (color)(long)data[10];
    StopLevels = (color)(long)data[11];
    LinePriceLast = (color)(long)data[12];
    schartcolors_brightness = zfu638707147322095794(Background);
    return true;
  }
};
