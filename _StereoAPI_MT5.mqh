uint __MT_Object_GetFlags(long chartid, string name) {
  if(chartid == NULL)chartid = __CHARTID;
  uint flags = 0;
  flags |= (bool)__MT_Object_GetInteger(chartid, name, OBJPROP_SELECTABLE) ? MT_OBJ_SELECTABLE : 0;
  flags |= (bool)__MT_Object_GetInteger(chartid, name, OBJPROP_HIDDEN) ? MT_OBJ_HIDDEN : 0;
  flags |= (bool)__MT_Object_GetInteger(chartid, name, OBJPROP_BACK) ? MT_OBJ_BACKGROUND : 0;
  return flags;
}
