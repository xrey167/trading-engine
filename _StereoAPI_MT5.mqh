CTimeNative __Time;
class CTime {
private:
  MqlDateTime        data;
public:
  int                hour;
  int                minute;
public:
                     CTime() {}
                     CTime(int hh, int mm) {
    hour = hh;
    minute = mm;
  }
                     CTime(datetime d) {
    ::TimeToStruct(d, data);
    hour = data.hour;
    minute = data.min;
  }
                     CTime(string d) {
    ::TimeToStruct(::StringToTime(d), data);
    hour = data.hour;
    minute = data.min;
  }
                    ~CTime() {}
public:
  void               Set(int h, int m) {
    hour = h;
    minute = m;
  }
  bool               IsInRange(int beginh, int beginm, int endh, int endm) {
    int begintime = (beginh * 60) + beginm;
    int endtime = (endh * 60) + endm;
    int curtime = (this.hour * 60) + this.minute;
    if(endh < beginh) {
      endtime += 1440;
      if(this.hour < beginh)
        curtime += 1440;
    }
    return(curtime >= begintime && curtime < endtime);
  }
}
