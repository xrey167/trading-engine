//+------------------------------------------------------------------+
bool CSymbolInfoBase::CheckMarketWatch(void) {
  if(!Select()) {
    if(GetLastError() == ERR_MARKET_UNKNOWN_SYMBOL) {
      printf(__FUNCTION__ + ": Unknown symbol '%s'", m_name);
      return(false);
    }
    if(!Select(true)) {
      printf(__FUNCTION__ + ": Error adding symbol %d", GetLastError());
      return(false);
    }
  }
  return(true);
}
