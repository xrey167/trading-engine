//+------------------------------------------------------------------+
class CIndMA: public CIndicatorValueBuffer {
public:
  void               CIndMA(CIndicatorValueBuffers*buffers = NULL) {
    Assign(buffers);
  }
public:
  bool               Create(int period, ENUM_MA_METHOD method) {
    return _Create(IND_MA, period, method);
  }
protected:
  virtual double     OnGetValue(int shift, int pos) {
    double prevvalue = Get(pos - 1);
    int periods = (int)Param[0];
    int method = (int)Param[1];
    double value = 0;
    switch(method) {
    case MODE_SMA:
      value = _MA_Simple(periods, shift, prevvalue);
      break;
    case MODE_EMA:
      value = _MA_Exp(periods, shift, prevvalue);
      break;
    case MODE_SMMA:
      value = _MA_Smooth(periods, shift, prevvalue);
      break;
    case MODE_LWMA:
      value = _MA_LW(periods, shift);
      break;
    }
    return value;
  }
private:
  double             _MA_Simple(const int period, int shift, double prevvalue = PRICE_INVALID) {
    if(shift < 0 || shift > _Count() - period - 1 || period <= 0)
      return PRICE_INVALID;
    double result = 0.0;
    if(prevvalue == PRICE_INVALID) {
      for(int i = 0; i < period; i++) {
        result += _Close(shift + i);
      }
      result /= period;
    } else {
      result = prevvalue + (_Close(shift) - _Close(shift + period)) / period;
    }
    return result;
  }
private:
  double             _MA_Exp(const int period, int shift, const double prevvalue = PRICE_INVALID) {
    if(shift < 0 || period <= 0)
      return PRICE_INVALID;
    double result = 0.0;
    double price;
    if(prevvalue == PRICE_INVALID) {
      int begin = shift + (period * 7);
      if(begin > _Count() - 2)
        begin = (int)_Count() - 2;
      price = _Close(begin);
      if(price == PRICE_INVALID)
        return PRICE_INVALID;
      result = price;
      for(int i = begin - 1; i >= shift; i--) {
        result = _MA_Exp(period, i, result);
        if(result == PRICE_INVALID)
          return PRICE_INVALID;
      }
      return result;
    }
    price = _Close(shift);
    if(price == VALUE_INVALID)
      return VALUE_INVALID;
    double pr = 2.0 / (period + 1.0);
    result = price * pr + prevvalue * (1 - pr);
    return result;
  }
private:
  double             _MA_Smooth(int period, int shift, double prevvalue = PRICE_INVALID) {
    if(shift < 0 || shift > _Count() - period - 1 || period <= 0)
      return PRICE_INVALID;
    double result = 0;
    if(prevvalue == PRICE_INVALID) {
      for(int i = 0; i < period; i++)
        result += _Close(shift + i);
      result /= period;
    } else {
      result = (prevvalue * (period - 1) + _Close(shift)) / period;
    }
    return result;
  }
private:
  double             _MA_LW(int period, int shift) {
    if(shift < 0 || shift > _Count() - period - 1 || period <= 0)
      return PRICE_INVALID;
    double result = 0, sum = 0;
    int wsum = 0;
    for(int i = period; i > 0; i--) {
      wsum += i;
      sum += _Close(shift + i - 1) * (period - i + 1);
    }
    result = sum / wsum;
    return result;
  }
};
enum ENUM_ATR_METHOD {
  ATR_METHOD_SMA = 0,
  ATR_METHOD_EMA = 1,
};
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
class CIndATR: public CIndicatorValueBuffer {
public:
  void               CIndATR(CIndicatorValueBuffers*buffers) {
    Assign(buffers);
  }
public:
  bool               Create(int periods, ENUM_ATR_METHOD method = ATR_METHOD_SMA) {
    if(periods < 0)
      method = ATR_METHOD_EMA;
    return _Create(IND_ATR, ABS(periods), method);
  }
public:
  virtual double     OnGetValue(int shift, int pos) {
    int periods = (int)Param[0];
    ENUM_ATR_METHOD method = (ENUM_ATR_METHOD)Param[1];
    if(pos < periods + 1)
      return PRICE_INVALID;
    double value = 0;
    double prevvalue = Get(pos - 1);
    if(method == ATR_METHOD_SMA)
      return _MA_Simple(periods, shift);
    else
      return _MA_Exp(periods, shift, prevvalue);
    return value;
  }
  double             _MA_Simple(const int period, int shift, const double prevvalue = VALUE_INVALID) {
    if(shift < 0 || shift > _Count() - period - 1 || period <= 0)
      return VALUE_INVALID;
    double result = 0.0;
    if(prevvalue == VALUE_INVALID) {
      for(int i = 0; i < period; i++)
        result += _TrueRange(shift + i);
      result /= period;
    } else {
      result = prevvalue + (_TrueRange(shift) - _TrueRange(shift + period)) / period;
    }
    return result;
  }
private:
  double             _MA_Exp(const int period, int shift, const double prevvalue = VALUE_INVALID) {
    if(shift < 0 || shift > _Count() - period - 1 || period <= 0)
      return VALUE_INVALID;
    double result = 0.0;
    if(prevvalue == VALUE_INVALID) {
      int begin = shift + (period * 7);
      if(begin > _Count() - 2)
        begin = (int)_Count() - 2;
      result = _TrueRange(begin);
      if(result == VALUE_INVALID)
        return VALUE_INVALID;
      for(int i = begin - 1; i >= shift; i--) {
        result = _MA_Exp(period, i, result);
        if(result == PRICE_INVALID)
          return PRICE_INVALID;
      }
      return result;
    }
    result = _Close(shift);
    if(result == VALUE_INVALID)
      return VALUE_INVALID;
    double pr = 2.0 / (period + 1.0);
    result = result * pr + prevvalue * (1 - pr);
    return result;
  }
};
