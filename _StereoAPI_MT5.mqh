  bool               IsBullish(int shift = 0) {
    return this.Open(shift) < this.Close(shift);
  }
  bool               IsBearish(int shift = 0) {
    return this.Open(shift) > this.Close(shift);
  }
  bool               IsDoji(double tolerance = 0, int shift = 0) {
    return ABS(this.Open(shift) - this.Close(shift)) <= tolerance;
  }
  double             Range(int shift = 0) {
    return this.High(shift) - this.Low(shift);
  }
  double             TrueRange(int shift = 0) {
    double h = this.High(shift);
    double l = m_bar.low;
    double c1 = this.Close(shift + 1);
    if(c1 > 0)return MAX(h - l, MAX(h - c1, c1 - l));
    return(h - l);
  }
  bool               IsInTimeRange(int beginh, int beginm, int endh, int endm, int shift = 0) {
