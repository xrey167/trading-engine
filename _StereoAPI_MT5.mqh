struct _TDecimal {
protected:
  uint               index;
protected:
  double             value_minchange;
  uint               value_digits;
  double             value_mcmult;
public:
  long               value_base;
  void               _TDecimal() {
    index = 0;
  }
  void               AssignDefault(uint indx) {
    index =::MathMin(DECIMAL_DEFAULT_MAX, indx);
  }
  void               Digits(uint digits) {
    value_digits =::MathMin(digits, 8);
    value_minchange = __DecimalDefault[index]._CalcMinChange(value_digits);
    value_mcmult = value_minchange / DECIMAL_BASE;
  }
  uint               Digits(void) {
    return value_digits;
  }
protected:
  long               _Base(double v) {
    return DECIMAL_TOBASE(v);
  }
  void               _SetMinChg(double value) {
    value_minchange =::MathMax(DECIMAL_BASE, value);
    value_mcmult = value_minchange / DECIMAL_BASE;
    value_digits = __DecimalDefault[index]._CalcDigits(value_minchange);
  }
  double             _ToDouble(long value) {
    long l = (long)::MathRound(value / value_mcmult);
    return(double)l * value_minchange;
  }
public:
  double             ToDouble() {
    long l = (long)::MathRound(value_base / value_mcmult);
    return(double)l * value_minchange;
  }
  string             ToString() {
    return::DoubleToString(ToDouble(), value_digits);
  }
  string             ToString(double value) {
    return::DoubleToString(value, value_digits);
  }
  void               operator=(_TDecimal&dec) {
    value_base = dec.value_base;
  }
  void               operator=(double v) {
    value_base = DECIMAL_TOBASE(v);
  }
  bool               operator==(_TDecimal&dec) {
    return(value_base == dec.value_base);
  }
  bool               operator==(double v) {
    return(value_base == DECIMAL_TOBASE(v));
  }
  bool               operator!=(_TDecimal&dec) {
    return(value_base != dec.value_base);
  }
  bool               operator!=(double v) {
    return(value_base != DECIMAL_TOBASE(v));
  }
  bool               operator>=(_TDecimal&dec) {
    return(value_base >= dec.value_base);
  }
  bool               operator>=(double v) {
    return(value_base >= DECIMAL_TOBASE(v));
  }
  bool               operator<=(_TDecimal&dec) {
    return(value_base <= dec.value_base);
  }
  bool               operator<=(double v) {
    return(value_base <= DECIMAL_TOBASE(v));
  }
  bool               operator>(_TDecimal&dec) {
    return(value_base > dec.value_base);
  }
  bool               operator>(double v) {
    return(value_base > DECIMAL_TOBASE(v));
  }
  bool               operator<(_TDecimal&dec) {
    return(value_base < dec.value_base);
  }
  bool               operator<(double v) {
    return(value_base < DECIMAL_TOBASE(v));
  }
  void               operator-=(_TDecimal&dec) {
    value_base -= DECIMAL_TOBASE(dec.ToDouble());
  }
  void               operator-=(double v) {
    value_base -= DECIMAL_TOBASE(v);
  }
  void               operator+=(_TDecimal&dec) {
    value_base += DECIMAL_TOBASE(dec.ToDouble());
  }
  void               operator+=(double v) {
    value_base += DECIMAL_TOBASE(v);
  }
  void               operator*=(_TDecimal&dec) {
    value_base *= DECIMAL_TOBASE(dec.ToDouble());
  }
  void               operator*=(double v) {
    value_base *= DECIMAL_TOBASE(v);
  }
  void               operator/=(_TDecimal&dec) {
    value_base /= DECIMAL_TOBASE(dec.ToDouble());
  }
  void               operator/=(double v) {
    value_base /= DECIMAL_TOBASE(v);
  }
  void               operator++(void) {
    value_base += DECIMAL_TOBASE(value_minchange);
  }
  void               operator--(void) {
    value_base -= DECIMAL_TOBASE(value_minchange);
  }
  void               operator++(int) {
    value_base += DECIMAL_TOBASE(value_minchange);
  }
  void               operator--(int) {
    value_base -= DECIMAL_TOBASE(value_minchange);
  }
  double             operator+(_TDecimal&dec) {
    return _ToDouble(value_base + dec.value_base);
  }
  double             operator+(double v) {
    return ToDouble() + v;
  }
  double             operator-(_TDecimal&dec) {
    return _ToDouble(value_base - dec.value_base);
  }
  double             operator-(double v) {
    return ToDouble() - v;
  }
  double             operator*(_TDecimal&dec) {
    return _ToDouble(value_base * dec.value_base);
  }
  double             operator*(double v) {
    return ToDouble() * v;
  }
  double             operator/(_TDecimal&dec) {
    return _ToDouble(value_base / dec.value_base);
  }
  double             operator/(double v) {
