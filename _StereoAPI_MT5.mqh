    tlast = t;
    bool result = _GetSummerTimeDev(srlocal, t, stlocal);
    result |= _GetSummerTimeDev(srserver, t, stserver);
    return result;
  }
public:
  bool               _GetSummerTimeDev(ENUM_SUMMERTIMERULE sr, datetime t, int&deviation) {
    int dev = 0;
    switch(sr) {
    case SUMMERTIMERULE_EU: {
      if((t >= D'2010.03.28 03:00:00' && t < D'2010.10.31 03:00:00') ||
          (t >= D'2011.03.27 03:00:00' && t < D'2011.10.30 03:00:00') ||
          (t >= D'2012.03.25 03:00:00' && t < D'2012.10.28 03:00:00') ||
          (t >= D'2013.03.31 03:00:00' && t < D'2013.10.27 03:00:00') ||
          (t >= D'2014.03.30 03:00:00' && t < D'2014.10.26 03:00:00') ||
          (t >= D'2015.03.29 03:00:00' && t < D'2015.10.25 03:00:00') ||
          (t >= D'2016.03.27 03:00:00' && t < D'2016.10.30 03:00:00') ||
          (t >= D'2017.03.26 03:00:00' && t < D'2017.10.29 03:00:00') ||
          (t >= D'2018.03.25 03:00:00' && t < D'2018.10.28 03:00:00') ||
          (t >= D'2019.03.31 03:00:00' && t < D'2019.10.27 03:00:00') ||
          (t >= D'2020.03.29 03:00:00' && t < D'2020.10.25 03:00:00') ||
          (t >= D'2021.03.28 03:00:00' && t < D'2021.10.25 03:00:00') ||
          (t >= D'2022.03.27 03:00:00' && t < D'2022.10.30 03:00:00') ||
          (t >= D'2023.03.26 03:00:00' && t < D'2023.10.29 03:00:00') ||
          (t >= D'2024.03.31 03:00:00' && t < D'2024.10.27 03:00:00'))
        dev = 1;
      break;
    }
    case SUMMERTIMERULE_USA: {
      if((t >= D'2010.03.14 02:00:00' && t < D'2010.11.07 02:00:00') ||
          (t >= D'2011.03.13 02:00:00' && t < D'2011.11.06 02:00:00') ||
          (t >= D'2012.03.11 02:00:00' && t < D'2012.11.04 02:00:00') ||
          (t >= D'2013.03.10 02:00:00' && t < D'2013.11.03 02:00:00') ||
          (t >= D'2014.03.09 02:00:00' && t < D'2014.11.02 02:00:00') ||
          (t >= D'2015.03.08 02:00:00' && t < D'2015.11.01 02:00:00') ||
          (t >= D'2016.03.13 02:00:00' && t < D'2016.11.06 02:00:00') ||
          (t >= D'2017.03.12 02:00:00' && t < D'2017.11.05 02:00:00') ||
          (t >= D'2018.03.11 02:00:00' && t < D'2018.11.04 02:00:00') ||
          (t >= D'2019.03.10 02:00:00' && t < D'2019.11.03 02:00:00') ||
          (t >= D'2020.03.08 02:00:00' && t < D'2020.11.01 02:00:00') ||
          (t >= D'2021.03.14 02:00:00' && t < D'2021.11.07 02:00:00') ||
          (t >= D'2022.03.13 02:00:00' && t < D'2022.11.06 02:00:00') ||
          (t >= D'2023.03.12 02:00:00' && t < D'2023.11.05 02:00:00') ||
          (t >= D'2024.03.10 02:00:00' && t < D'2024.11.03 02:00:00'))
        dev = 1;
      break;
    }
    case SUMMERTIMERULE_RU: {
      dev = 0;
      break;
    }
    }
    bool result = deviation != dev;
    deviation = dev;
    return result;
  }
