  }
public:
  int                MaxX(void) {
    if(!Metrics.shift_status)
      return Metrics.width - 1;
    int w = m_fixedshift < 0 ? 0 : m_fixedshift;
    return Metrics.width - w - Metrics.max_x - 1;
  }
