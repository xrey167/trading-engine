  void               Attach(const long chart) {
    CChartBase::Attach(chart);
    if(m_chart_id == __CHARTID)
      m_subwin = __MT_GetCurrentSubWindow();
    else
      m_subwin = 0;
    _HwndInit();
    m_metrics_init = false;
    m_colors_init = false;
  }
