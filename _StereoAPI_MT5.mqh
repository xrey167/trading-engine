    if(!m_active)return -1;
    double price = m_bars.PivotPrice(low, high, close, p);
    if(tooltip == NULL)
      tooltip = text;
    string levelstring = DoubleToString(price, m_sea_base.Digits());
    StringReplace(text, "%level", levelstring);
    StringReplace(tooltip, "%level", levelstring);
    return LineTrend(text, timebegin, price, timeend, price, clr, width, style, tooltip);
  }
