  virtual bool       OnApplyDesign(void) {
    if(!m_clrchk_ind) {
      m_clrchkbg = __m_clr_chkbgon;
      m_clrchkbrd = __m_clr_chkbrd;
      m_clrchkfg = __m_clr_chkfgon;
    }
    if(!m_clruchk_ind) {
      m_clruchkbg = __m_clr_chkbgoff;
      m_clruchkbrd = __m_clr_chkbrd;
      m_clruchkfg = __m_clr_chkfgoff;
    }
    ApplyStatus();
    return true;
  }
  virtual void       OnMouseHOver(void) {
    if(IsMouseHOver()) {
      color clrbg, clrfg;
      if(Pressed()) {
        clrbg = ColorMix(m_clrchkbg, m_clruchkbg, 0.5);
        clrfg = m_clruchkfg;
      } else {
        clrbg = ColorMix(m_clrchkbg, m_clruchkbg, 0.5);
        clrfg = m_clrchkfg;
      }
      ColorBackground(clrbg);
      Color(clrfg);
    } else
      ApplyStatus();
    __Chart.Invalidate();
  }
private:
  color              ColorMix(color rgb2, color rgb1, double mix = 0.5) {
