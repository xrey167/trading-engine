//|                                                                  |
//+------------------------------------------------------------------+
ENUM_TIMEFRAMES __MT_TimeFrameFromName(string timeframename) {
  if(timeframename == NULL)return WRONG_VALUE;
  if(timeframename == "M1")return PERIOD_M1;
  if(timeframename == "M5")return PERIOD_M5;
  if(timeframename == "M15")return PERIOD_M15;
  if(timeframename == "M30")return PERIOD_M30;
  if(timeframename == "H1")return PERIOD_H1;
  if(timeframename == "H4")return PERIOD_H4;
  if(timeframename == "D1")return PERIOD_D1;
  if(timeframename == "W1")return PERIOD_W1;
  if(timeframename == "MN1")return PERIOD_MN1;
  if(timeframename == "M2")return PERIOD_M2;
  if(timeframename == "M3")return PERIOD_M3;
  if(timeframename == "M4")return PERIOD_M4;
  if(timeframename == "M6")return PERIOD_M6;
  if(timeframename == "M10")return PERIOD_M10;
  if(timeframename == "M12")return PERIOD_M12;
  if(timeframename == "H2")return PERIOD_H2;
  if(timeframename == "H3")return PERIOD_H3;
  if(timeframename == "H6")return PERIOD_H6;
  if(timeframename == "H12")return PERIOD_H12;
  return WRONG_VALUE;
}
