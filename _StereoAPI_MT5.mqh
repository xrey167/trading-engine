                     IMPLEMENT_MEMBER_FWD_SET_GET(TranslateTime, bool, __Time.ConvertAuto, void, void)
                     IMPLEMENT_MEMBER_SET_GET(UpdateMetricsMethod, ENUM_CHART_PROPERTIES_METHOD, m_metrics_method, void, void)
                     IMPLEMENT_MEMBER_SET_GET(UpdateColorsMethod, ENUM_CHART_PROPERTIES_METHOD, m_colors_method, void, void)
public:
  void               UpdateMetrics(bool force = false) {
    if(m_metrics_method != CHART_PROPERTIES_METHOD_NATIVE)return;
    if(force)
      Metrics.width = -1;
    if(__MT_GetChartMetrics(m_chart_id, m_subwin, Metrics)) {
      Metrics.UpdatePixBetweenBars();
      Metrics.time_min = XToTime(0);
      Metrics.time_max = XToTime(MaxX());
      m_metrics_init = true;
      m_metrics_changes++;
      m_bars.TimeFrame(__TIMEFRAME);
      m_buffered_scalefix = CChartBase::ScaleFix();
      if(Colors.AdaptiveBarColors())
        Colors.AdaptBarColors(m_chart_id);
    }
  }
public:
  bool               GetMetrics(int&changes, int&subwin, SChartMetrics&metrics_out) {
    if(!m_metrics_init || m_metrics_method != CHART_PROPERTIES_METHOD_NATIVE)return false;
    metrics_out = Metrics;
    changes = m_metrics_changes;
    subwin = m_subwin;
    return true;
  }
public:
  int                GetMetricsChanges() {
    return m_metrics_changes;
  }
public:
  bool               ApplyMetrics(int&changes, int subwin, SChartMetrics&metrics_in) {
    if(m_metrics_method != CHART_PROPERTIES_METHOD_SEA)return false;
    if(changes == m_metrics_changes)return false;
    m_metrics_changes = changes;
    Metrics = metrics_in;
    if(subwin != m_subwin)
      __MT_GetChartMetrics(m_chart_id, m_subwin, Metrics, true);
    Metrics.UpdatePixBetweenBars();
    m_bars.TimeFrame(__TIMEFRAME);
    m_metrics_init = true;
    return true;
  }
public:
  bool               ApplyMetrics(int changes_in, int subwin_in, string metrics_string_in) {
    if(m_metrics_method != CHART_PROPERTIES_METHOD_SEA)return false;
    if(changes_in == m_metrics_changes)return true;
    m_metrics_changes = changes_in;
    if(!Metrics.FromString(metrics_string_in))
      return false;
    if(subwin_in != m_subwin) {
      __MT_GetChartMetrics(m_chart_id, m_subwin, Metrics, true);
    }
    m_bars.TimeFrame(__TIMEFRAME);
    m_metrics_init = true;
    return true;
  }
public:
  void               UpdateColors(bool force = false) {
    if(m_colors_method != CHART_PROPERTIES_METHOD_NATIVE)return;
    if(Colors.Update(m_chart_id) || force) {
      m_colors_init = true;
      m_colors_changes++;
    }
  }
public:
  bool               GetColors(int&changes, SChartColors&colors_out) {
    if(!m_colors_init || m_colors_method != CHART_PROPERTIES_METHOD_NATIVE)return false;
    colors_out = Colors;
    return true;
  }
