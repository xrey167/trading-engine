    return m_bar.IsSolid(wickmax, tailmax);
  }
  bool               IsSolidBullish(int shift = 0, double wickmax = 0.15) {
    UpdateCurrentBar(shift);
    return m_bar.IsSolidBullish(wickmax);
  }
  bool               IsSolidBearish(int shift = 0, double tailmax = 0.15) {
    UpdateCurrentBar(shift);
    return m_bar.IsSolidBearish(tailmax);
  }
  int                TimeCompareToLocal(int h, int m, int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.TimeCompareToLocal(h, m);
  }
public:
  bool               IsEngulfingLong(int shift = 0) {
    return(this.Low(shift) < this.Low(shift + 1) && this.Close(shift) > this.High(shift + 1));
  }
  bool               IsEngulfingShort(int shift = 0) {
    return(this.High(shift) > this.High(shift + 1) && this.Close(shift) < this.Low(shift + 1));
  }
  bool               IsReversingLong(int shift = 0) {
    return(this.High(shift) > this.High(shift + 1) && this.Close(shift) > this.Close(shift + 1) && this.Close(shift) > this.Open(shift + 1) && IsBullish(shift));
  }
  bool               IsReversingShort(int shift = 0) {
    return(this.Low(shift) < this.Low(shift + 1) && this.Close(shift) < this.Close(shift + 1) && this.Close(shift) < this.Open(shift + 1) && IsBearish(shift));
  }
public:
  bool               FindOutsideBar(CBar&bar, int shift = 1, int scanbarsmax = 100) {
    bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
    shift = MAX(1, shift);
    if(scanbarsmax == -1)
      scanbarsmax = Count();
    else
      scanbarsmax += shift;
    for(int i = scanbarsmax; i > shift; i--) {
      if(IsBullish(i)) {
        if(bar.low == 0 || (this.Close(i) > bar.high))
          BarUpdate(bar, i);
      } else if(IsBearish(i)) {
        if(bar.low == 0 || (this.Close(i) < bar.low))
          BarUpdate(bar, i);
      }
    }
    return bar.low != 0;
  }
public:
  virtual bool       GetOLHC(double&o, double&l, double&h, double&c, int shift = 0) {
    shift = SHIFTADJUST(shift);
    if(shift < 0 || shift >= Count()) {
      c = 0;
      o = 0;
      l = 0;
      h = 0;
      return false;
    }
    MqlRates rates[];
    CopyRates(m_symbolname, m_timeframe, shift, 1, rates);
    c = rates[0].close;
    o = rates[0].open;
    l = rates[0].low;
    h = rates[0].high;
    return true;
  }
public:
  virtual            CBar*BarGet(int shift = 0) {
    CBar*bar = new CBar(m_symbolname, m_timeframe);
    BarUpdate(bar, shift);
    return bar;
  }
  bool               BarGetSeries(CBar&bars[], int cntbars, int shift = 0) {
    ArrayResize(bars, cntbars);
    for(int i = 0; i < cntbars; i++)
      BarUpdate(PTR(bars[i]), i);
    return true;
  }
  virtual bool       BarUpdate(CBar&bar, int shift = 0) {
    return BarUpdate(PTR(bar), shift);
  }
  virtual bool       BarUpdate(CBar*bar, int shift = 0) {
    int shiftoriginal = shift;
    shift = SHIFTADJUST(shift);
    int bars = Count();
    if(shift < 0 || shift >= bars) {
      bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
      return false;
    }
    if(m_custom) {
      int i = INDEX(shiftoriginal);
      return bar.Update(m_rates[i]);
    }
    MqlRates rates[];
    if(m_tr_mode == TRUERANGE_MODE_NONE) {
      if(shift < bars - 1) {
        bool result = _CopyRates(m_symbolname, m_timeframe, shift, 2, rates);
        if(!result) {
          bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
          return false;
        }
        return bar.Update(rates[1].close, rates[1].open, rates[1].high, rates[1].low, rates[1].time, rates[1].tick_volume, rates[1].real_volume, rates[1].open - rates[0].close);
      } else {
        bool result = _CopyRates(m_symbolname, m_timeframe, shift, 1, rates);
        if(!result) {
          bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
          return false;
        }
        return bar.Update(rates[0].close, rates[0].open, rates[0].high, rates[0].low, rates[0].time, rates[0].tick_volume, rates[0].real_volume, 0);
      }
    }
    if(m_tr_mode == TRUERANGE_MODE_NORMAL && shift + 1 < bars) {
      bool result = _CopyRates(m_symbolname, m_timeframe, shift, 2, rates);
      if(!result) {
        bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
        return false;
      }
      return bar.Update(rates[1].close, rates[0].close, MAX(rates[1].high, rates[0].close), MIN(rates[1].low, rates[0].close), rates[1].time, rates[1].tick_volume, rates[1].real_volume, rates[1].open - rates[0].close);
    } else if(m_tr_mode == TRUERANGE_MODE_FORWARD) {
      bool result = _CopyRates(m_symbolname, m_timeframe, shift - 1, 2, rates);
      if(!result) {
        bar.Update(0, 0, 0, 0, 0, 0, 0, 0);
        return false;
      }
      return bar.Update(rates[0].open, rates[1].open, MAX(rates[0].high, rates[1].open), MIN(rates[0].low, rates[1].open), rates[0].time, rates[0].tick_volume, rates[0].real_volume, 0);
    }
    return false;
  }
public:
  bool               UpdateCurrentBar(int shift) {
    int barscount = Count();
    int s = SHIFTADJUST(shift);
    if(s == 0 || m_lastshift != shift || barscount != m_lastbars || m_forcerequest) {
      m_lastshift = shift;
      m_lastbars = barscount;
      return BarUpdate(PTR(m_bar), shift);
    }
    return true;
  }
  bool               UpdateCurrentBar(datetime dt) {
    int shift = _iBarShift(m_symbolname, m_timeframe, dt);
    if(shift < 0)
      return BarUpdate(PTR(m_bar), -1);
    shift = SHIFTUNADJUST(shift);
    m_lastshift = shift;
    m_lastbars = Count();
    return BarUpdate(PTR(m_bar), shift);
  }
public:
  int                IndexOfCurrentBar(void) {
    return Count() - 1 - SHIFTADJUST(0);
  }
  int                IndexOfFinalBar(void) {
    return Count() - 1 - m_defaultbarshift;
  }
  double             FiboPrice(double low, double high, double fibomult) {
    return low + (fibomult * (high - low));
  }
  double             PivotPrice(double plow, double phigh, double pclose, ENUM_PIVOT_POINT p) {
    double pmain = (plow + phigh + pclose) / 3;
    switch(p) {
    case PIVOT_POINT_MAIN:
      return pmain;
    case PIVOT_POINT_R1:
      return(pmain * 2) - plow;
    case PIVOT_POINT_R2:
      return pmain + (phigh - plow);
    case PIVOT_POINT_S1:
      return(pmain * 2) - phigh;
    case PIVOT_POINT_S2:
      return pmain - (phigh - plow);
    default:
      return 0;
    }
  }
  int                GetBarShift(datetime time, int shift, ENUM_BARSHIFT_EXACT exact) {
    shift = SHIFTADJUST(shift);
    datetime t = this.Time(time);
    shift = _iBarShift(m_symbolname, m_timeframe, t, exact == BARSHIFT_EXACT);
    if(shift >= 0 && exact == BARSHIFT_BEHIND) {
      datetime tfound = this.Time(shift);
      if(tfound == t)
        return shift;
      shift = MAX(0, shift - 1);
    }
    return shift;
  }
public:
  int                GetBarShift(int hh, int mm, int daysback, int shift, ENUM_BARSHIFT_EXACT exact, bool ignoreweekends = true) {
    shift = SHIFTADJUST(shift);
    datetime t = this.Time(shift);
    if(t <= 0)
      return -1;
    long spd = 24 * 60 * 60;
    if(ignoreweekends) {
      for(int i = 0; i < daysback; i++) {
        t = (datetime)((long)t - spd);
        int dow = __Time.DayOfWeek(t);
        if(dow == 0 || dow == 6)
          i--;
      }
    } else
      t = (datetime)((long)t - (spd * daysback));
    MqlDateTime dt;
    TimeToStruct(t, dt);
    MINMAX(hh, 0, 23);
    MINMAX(mm, 0, 59);
    dt.hour = hh;
    dt.min = mm;
    t = StructToTime(dt);
    shift = _iBarShift(m_symbolname, m_timeframe, t, exact == BARSHIFT_EXACT);
    if(shift >= 0 && exact == BARSHIFT_BEHIND) {
      datetime tfound = this.Time(shift);
      if(tfound == t)
        return shift;
      shift = MAX(0, shift - 1);
      t = Time(shift);
      t = t;
    }
    return shift;
  }
  bool               IsCrossingUp(double&series[], int shift = 0) {
    double value = Series(series, SHIFTADJUST(shift));
    return Close(shift) > value && Open(shift) <= value;
  }
  bool               IsCrossingUp(double&seriescrossing[], double&seriescrossed[], int shift = 0) {
    double valuecrossing = Series(seriescrossing, shift);
    double valuecrossing1 = Series(seriescrossing, shift + 1);
    double valuecrossed = Series(seriescrossed, shift);
    return valuecrossing > valuecrossed && valuecrossing1 <= valuecrossed;
  }
  bool               IsCrossingDown(double&series[], int shift = 0) {
    double value = Series(series, SHIFTADJUST(shift));
    return Close(shift) < value && Open(shift) >= value;
  }
  bool               IsCrossingDown(double&seriescrossing[], double&seriescrossed[], int shift = 0) {
    double valuecrossing = Series(seriescrossing, shift);
    double valuecrossing1 = Series(seriescrossing, shift + 1);
    double valuecrossed = Series(seriescrossed, shift);
    return valuecrossing < valuecrossed && valuecrossing1 >= valuecrossed;
  }
  double             Series(double&series[], int shift = 0) {
    int seriesshift = SHIFTADJUST(shift);
    if(shift >= ArraySize(series) || seriesshift < 0)
      return 0;
    bool flag = ArrayGetAsSeries(series);
    ArraySetAsSeries(series, true);
    double seriesvalue = series[seriesshift];
    ArraySetAsSeries(series, flag);
    return seriesvalue;
  }
  bool               Series(double&series[], double value, int shift = 0) {
    int seriesshift = SHIFTADJUST(shift);
    if(seriesshift >= ArraySize(series) || seriesshift < 0)
      return false;
    bool flag = ArrayGetAsSeries(series);
    ArraySetAsSeries(series, true);
    series[seriesshift] = value;
    ArraySetAsSeries(series, flag);
    return true;
  }
public:
  double             ATR(int periods, int shift = 0, ENUM_ATR_METHOD method = ATR_METHOD_SMA) {
    CIndATR*indicator = (CIndATR*)m_ind_buffers.Find(IND_ATR, periods, method);
    if(indicator == NULL) {
      indicator = new CIndATR(PTR(m_ind_buffers));
      indicator.Create(periods, method);
    }
    shift = SHIFTADJUST(shift);
    return indicator.Value(shift);
  }
public:
  double             AverageRange(int periods, int shift = 0, ENUM_ATR_MODE mode = AR_MODE_NORMAL, ENUM_CANDLE_BASE base = WRONG_VALUE) {
    double avgrange = 0;
    double o, l, h, c;
    int candles = 0;
    if(base == WRONG_VALUE)
      base = m_candlebase;
    while(candles < periods) {
      GetOLHC(o, l, h, c, shift);
      shift++;
      if(mode == AR_MODE_NORMAL || (mode == AR_MODE_BEARISH && c < o) || (mode == AR_MODE_BULLISH && c > o)) {
        if(base == CANDLE_BASE_HILO)
          avgrange += (h - l);
        else
          avgrange += ABS(o - c);
        candles++;
      }
    }
    avgrange /= periods;
    return avgrange;
  }
public:
  double             HighestHigh(int span, int shift = 0) {
    shift = SHIFTADJUST(shift);
    MqlRates rates[];
    int cnt = CopyRates(m_symbolname, m_timeframe, shift, span, rates);
    double max = 0;
    for(int i = 0; i < cnt; i++)
      max = MAX(rates[i].high, max);
    return max;
  }
  double             LowestLow(int span, int shift = 0) {
    shift = SHIFTADJUST(shift);
    MqlRates rates[];
    int cnt = CopyRates(m_symbolname, m_timeframe, shift, span, rates);
    double max = 999999999;
    for(int i = 0; i < cnt; i++)
      max = MIN(rates[i].low, max);
    return max;
  }
  int                HighestHighShift(int span, int shift = 0) {
    shift = SHIFTADJUST(shift);
    MqlRates rates[];
    int cnt = CopyRates(m_symbolname, m_timeframe, shift, span, rates);
    int s = 0;
    for(int i = 0; i < cnt; i++) {
      if(rates[i].high > rates[s].high)
        s = i;
    }
    return s;
  }
  int                LowestLowShift(int span, int shift = 0) {
    shift = SHIFTADJUST(shift);
    MqlRates rates[];
    int cnt = CopyRates(m_symbolname, m_timeframe, shift, span, rates);
    int s = 0;
    for(int i = 0; i < cnt; i++) {
      if(rates[i].low < rates[s].low)
        s = i;
    }
    return s;
  }
public:
  bool               IsAccessible() {
    return(this.Close(0) > 0 && this.Close(Count() - 1) > 0);
  }
public:
  double             SMA(int periods, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MA(periods, MODE_SMA, shift);
  }
  double             EMA(int periods, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MA(periods, MODE_EMA, shift);
  }
  double             LWMA(int periods, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MA(periods, MODE_LWMA, shift);
  }
  double             SMMA(int periods, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MA(periods, MODE_SMMA, shift);
  }
  double             MA(int periods, ENUM_MA_METHOD method, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MA(periods, method, shift);
  }
private:
  double             _MA(int periods, ENUM_MA_METHOD method, int shift) {
    if(method == MODE_SMA && periods < 0)
      method = MODE_EMA;
    periods = ABS(periods);
    if(periods == 0)
      return PRICE_INVALID;
    CIndMA*indicator = (CIndMA*)m_ind_buffers.Find(IND_MA, periods, method);
    if(indicator == NULL) {
      indicator = new CIndMA(PTR(m_ind_buffers));
      indicator.Create(periods, method);
    }
    return indicator.Value(shift);
  }
public:
  bool               IsSMASlopingUp(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_SMA, true);
  }
  bool               IsEMASlopingUp(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_EMA, true);
  }
  bool               IsLWMASlopingUp(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_LWMA, true);
  }
  bool               IsSMMASlopingUp(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_SMMA, true);
  }
  bool               IsSMASlopingDown(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_SMA, false);
  }
  bool               IsEMASlopingDown(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_EMA, false);
  }
  bool               IsLWMASlopingDown(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_LWMA, false);
  }
  bool               IsSMMASlopingDown(int period, int span = 2, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _MASloping(period, span, shift, MODE_SMMA, false);
  }
private:
  bool               _MASloping(int period, int span, int shift, ENUM_MA_METHOD method, bool upwards) {
    if(span < 2)
      return false;
    if(period < 0)
      method = MODE_EMA;
    double rates[];
    ArrayResize(rates, span);
    for(int i = span - 1; i >= 0; i--)
      rates[span - i - 1] = _MA(ABS(period), method, shift + i);
    if(rates[0] <= 0)
      return false;
    if(upwards)
      return RatesSlopingUp(rates);
    else
      return RatesSlopingDown(rates);
  }
public:
  long               TickVolumeAverage(int periods = 14, int shift = 0) {
    long vol[], avg = 0;
    periods = MAX(1, periods);
    shift = SHIFTADJUST(shift);
    ArrayResize(vol, periods);
    int cnt = CopyTickVolume(m_symbolname, m_timeframe, shift, periods, vol);
    for(int i = 0; i < cnt; i++)
      avg += vol[i];
    avg /= periods;
    return avg;
  }
public:
  long               RealVolumeAverage(int periods = 14, int shift = 0) {
    long vol[], avg = 0;
    periods = MAX(1, periods);
    shift = SHIFTADJUST(shift);
    ArrayResize(vol, periods);
    int cnt = CopyRealVolume(m_symbolname, m_timeframe, shift, periods, vol);
    for(int i = 0; i < cnt; i++)
      avg += vol[i];
    avg /= periods;
    return avg;
  }
public:
  double             StochasticMain(int period_k = 5, int period_d = 3, int slowing = 3, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _iStochastic(m_symbolname, m_timeframe, period_k, period_d, slowing, MODE_SMA, STO_LOWHIGH, 0, shift);
  }
  double             StochasticSignal(int period_k = 5, int period_d = 3, int slowing = 3, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _iStochastic(m_symbolname, m_timeframe, period_k, period_d, slowing, MODE_SMA, STO_LOWHIGH, 1, shift);
  }
  SIGNAL             Stochastic(int period_k, int period_d, int slowing, double signallinedistance = 20, int shift = 0) {
    double smain = StochasticMain(period_k, period_d, slowing, shift);
    double ssignal = StochasticSignal(period_k, period_d, slowing, shift);
    if(ssignal >= 100 - signallinedistance && smain < ssignal)
      return SIGNAL_SELL;
    else if(ssignal <= signallinedistance && smain > ssignal)
      return SIGNAL_BUY;
    return SIGNAL_NONE;
  }
public:
  double             RSI(int periods = 14, int shift = 0) {
    shift = SHIFTADJUST(shift);
    return _iRSI(m_symbolname, m_timeframe, periods, PRICE_CLOSE, shift);
  }
public:
  bool               IsLocalHigh(int bars, int shift = 0, double tolerance = 0) {
    double highesthigh = this.High(shift);
    for(int i = shift + 1; i < shift + bars; i++) {
      if(this.High(i) + tolerance > highesthigh)
        return false;
    }
    return true;
  }
  bool               IsLocalLow(int bars, int shift = 0, double tolerance = 0) {
    double lowestlow = this.Low(shift);
    for(int i = shift + 1; i < shift + bars; i++) {
      if(this.Low(i) - tolerance < lowestlow)
        return false;
    }
    return true;
  }
protected:
  bool               RatesSlopingUp(double&rates[]) {
    int cnt = ArraySize(rates);
    if(cnt < 2)
      return false;
    double rate = rates[0];
    for(int i = 1; i < cnt; i++) {
      if(rates[i] < rate)
        return false;
      rate = rates[i];
    }
    return true;
  }
  bool               RatesSlopingDown(double&rates[]) {
    int cnt = ArraySize(rates);
    if(cnt < 2)
      return false;
    double rate = rates[0];
    for(int i = 1; i < cnt; i++) {
      if(rates[i] > rate)
        return false;
      rate = rates[i];
    }
    return true;
  }
  int                GetShiftRel(ENUM_TIMEFRAMES timeframe, int daysback, int minute, int timezoneshifthours = 0) {
    ENUM_TIMEFRAMES p = timeframe;
    if(p > PERIOD_H1)
      return -1;
    datetime timenow = _iTime(m_symbolname, timeframe, 0);
    int daynow = int(_StringSubstr_c(TimeToString(timenow, TIME_DATE), 8, 2));
    int shifteddays = 0;
    int shift_to_day_begin = -1;
    for(int i = 1; i < 4800; i++) {
      if(shifteddays > daysback) {
        shift_to_day_begin = i - 2;
        datetime testdgb = _iTime(m_symbolname, p, shift_to_day_begin);
        break;
      }
      datetime timethis = _iTime(m_symbolname, p, i);
      int daythis = int(_StringSubstr_c(TimeToString(timethis, TIME_DATE), 8, 2));
      if(daythis != daynow) {
        shifteddays++;
        daynow = daythis;
      }
    }
    if(shift_to_day_begin == -1)
      return -1;
    if(minute >= 0) {
      int servertimeshift = timezoneshifthours * 60 / timeframe;
      return shift_to_day_begin - (minute / p) + servertimeshift;
    }
    timenow = _iTime(m_symbolname, timeframe, shift_to_day_begin);
    daynow = int(_StringSubstr_c(TimeToString(timenow, TIME_DATE), 8, 2));
    for(int i = shift_to_day_begin; i >= 0; i--) {
      datetime timethis = _iTime(m_symbolname, p, i);
      int daythis = int(_StringSubstr_c(TimeToString(timethis, TIME_DATE), 8, 2));
      if(daythis != daynow) {
        return i + 1;
      }
    }
    return -1;
  }
};
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
class CBars: public _CBarsGeneric {
public:
                     CBars(ENUM_TIMEFRAMES timeframe = PERIOD_CURRENT, string symbolname = NULL, int gmth = 0) {
    _Init(timeframe, symbolname, gmth);
  }
  bool               TimeFrame(ENUM_TIMEFRAMES tf) {
    if(m_custom)
      return false;
    if(tf == WRONG_VALUE)
      tf = __TIMEFRAME;
    if(tf == m_timeframe)
      return true;
    m_timeframe = tf;
    Reset(m_resetbuffersontfchange);
    return true;
  }
  ENUM_TIMEFRAMES    TimeFrame(void) {
    return m_timeframe;
  }
  void               Custom(ENUM_TIMEFRAMES tf = WRONG_VALUE, string symbolname = NULL) {
    m_custom = true;
    m_symbolname = symbolname == NULL ? __SYMBOLNAME : symbolname;
    TimeFrame(tf);
    ArrayFree(m_rates);
    m_ratescount = 0;
  }
};
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
class _CBarsService: public CBars {
public:
                     _CBarsService() {
    _Init(__TIMEFRAME, __SYMBOLNAME, 0);
    m_resetbuffersontfchange = true;
  }
public:
  double             DayLow(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? l : PRICE_INVALID;
  }
public:
  double             DayHigh(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? h : PRICE_INVALID;
  }
public:
  double             DayOpen(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? o : PRICE_INVALID;
  }
public:
  double             DayClose(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? c : PRICE_INVALID;
  }
public:
  datetime           DayTimeBegin(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? tb : 0;
  }
public:
  datetime           DayTimeEnd(int shiftdays = 0) {
    double o, l, h, c;
    datetime tb, te;
    return GetDayOLHC(o, l, h, c, tb, te, shiftdays) ? te : 0;
  }
public:
  bool               GetDayOLHC(double&o, double&l, double&h, double&c, datetime&tb, datetime&te, int shiftdays = 0) {
    int shiftbegin = -1;
    int shiftend = -1;
    ENUM_TIMEFRAMES tfold = m_timeframe;
    TimeFrame(PERIOD_M5);
    if(m_timebegin_hh >= 0 && m_timeend_hh >= 0) {
      shiftbegin = GetBarShift(m_timebegin_hh, m_timebegin_mm, shiftdays, 0, BARSHIFT_BEHIND);
      shiftend = GetBarShift(m_timeend_hh, m_timeend_mm, shiftdays, 0, BARSHIFT_BEFORE);
    } else {
      shiftbegin = GetBarShift(0, 0, shiftdays, 0, BARSHIFT_BEHIND);
      shiftend = GetBarShift(23, 55, shiftdays, 0, BARSHIFT_BEFORE);
    }
    if(shiftbegin < 0 || shiftend < 0) {
      o = 0;
      l = 0;
      h = 0;
      c = 0;
      tb = 0;
      TimeFrame(tfold);
      return false;
    }
    o = this.Open(shiftbegin);
    h = this.High(shiftbegin);
    l = this.Low(shiftbegin);
    c = this.Close(shiftend);
    tb = this.Time(shiftbegin);
    te = this.Time(shiftend);
    for(int i = shiftbegin; i >= shiftend; i--) {
      l = MIN(l, this.Low(i));
      h = MAX(h, this.High(i));
    }
    TimeFrame(tfold);
    return true;
  }
};
