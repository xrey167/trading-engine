  xx[0] = xx[2] = zfu638707147322096191;
  yy[0] = yy[1] = iy;
  if(dx < 0.0)
    xx[1] = xx[3] = zfu638707147322096191 - 1;
  if(dx == 0.0)
    xx[1] = xx[3] = zfu638707147322096191;
  if(dx > 0.0)
    xx[1] = xx[3] = zfu638707147322096191 + 1;
  if(dy < 0.0)
    yy[2] = yy[3] = iy - 1;
  if(dy == 0.0)
    yy[2] = yy[3] = iy;
  if(dy > 0.0)
    yy[2] = yy[3] = iy + 1;
  for(int i = 0; i < 4; i++) {
    dx = xx[i] - x;
    dy = yy[i] - y;
    rr[i] = 1 / (dx * dx + dy * dy);
    rrr += rr[i];
  }
  for(int i = 0; i < 4; i++) {
    k = rr[i] / rrr;
    c = PixelGet(xx[i], yy[i]);
    a = (uchar)(k * GETRGBA(clr) + (1 - k) * GETRGBA(c));
    r = (uchar)(k * GETRGBR(clr) + (1 - k) * GETRGBR(c));
    g = (uchar)(k * GETRGBG(clr) + (1 - k) * GETRGBG(c));
    b = (uchar)(k * GETRGBB(clr) + (1 - k) * GETRGBB(c));
    PixelSet(xx[i], yy[i], ARGB(a, r, g, b));
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
uint CCanvas::LineStyleGet(void)const {
  switch(m_style) {
  case 0xFFFFFF:
    return(STYLE_SOLID);
    break;
  case 0x3FFFF:
    return(STYLE_DASH);
    break;
  case 0x1C71C7:
    return(STYLE_DOT);
    break;
  case 0x381FF:
    return(STYLE_DASHDOT);
    break;
  case 0x1C71FF:
    return(STYLE_DASHDOTDOT);
    break;
  default:
    return(m_style);
    break;
  }
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineStyleSet(const uint style) {
  switch(style) {
  case STYLE_SOLID:
    m_style = 0xFFFFFF;
    break;
  case STYLE_DASH:
    m_style = 0x3FFFF;
    break;
  case STYLE_DOT:
    m_style = 0x1C71C7;
    break;
  case STYLE_DASHDOT:
    m_style = 0x381FF;
    break;
  case STYLE_DASHDOTDOT:
    m_style = 0x1C71FF;
    break;
  default:
    if((style & 0x80000000) != 0) {
      m_style = style;
    }
    break;
  }
  m_style_idx = 0;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::LineAA(const int x1, const int y1, const int x2, const int y2, const uint clr, const uint style) {
  if((x1 < 0 && x2 < 0) || (y1 < 0 && y2 < 0))
    return;
  if(x1 >= m_width && x2 >= m_width)
    return;
  if(y1 >= m_height && y2 >= m_height)
    return;
  if(x1 == x2 && y1 == y2) {
    PixelSet(x1, y1, clr);
    return;
  }
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  double dx = x2 - x1;
  double dy = y2 - y1;
  double xy = sqrt(dx * dx + dy * dy);
  double xx = x1;
  double yy = y1;
  uint mask = 1 << m_style_idx;
  dx /= xy;
  dy /= xy;
  do {
    if((m_style & mask) == mask) {
      PixelSetAA(xx, yy, clr);
    }
    xx += dx;
    yy += dy;
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  } while(fabs(x2 - xx) >= fabs(dx) && fabs(y2 - yy) >= fabs(dy));
  if((m_style & mask) == mask) {
    PixelSetAA(x2, y2, clr);
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolylineAA(int&x[], int&y[], const uint clr, const uint style) {
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  total--;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int i = 0; i < total; i++) {
    int x1 = x[i];
    int y1 = y[i];
    int x2 = x[i + 1];
    int y2 = y[i + 1];
    if((x1 < 0 && x2 < 0) || (y1 < 0 && y2 < 0)) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(x1 >= m_width && x2 >= m_width) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(y1 >= m_height && y2 >= m_height) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(x1 == x2 && y1 == y2) {
      PixelSet(x1, y1, clr);
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    double dx = x2 - x1;
    double dy = y2 - y1;
    double xy = sqrt(dx * dx + dy * dy);
    double xx = x1;
    double yy = y1;
    dx /= xy;
    dy /= xy;
    do {
      if((m_style & mask) == mask) {
        PixelSetAA(xx, yy, clr);
      }
      xx += dx;
      yy += dy;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    } while(fabs(x2 - xx) >= fabs(dx) && fabs(y2 - yy) >= fabs(dy));
    if((m_style & mask) == mask) {
      PixelSetAA(x2, y2, clr);
    }
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::PolygonAA(int&x[], int&y[], const uint clr, const uint style) {
  int total = ArraySize(x);
  if(total > ArraySize(y))
    total = ArraySize(y);
  if(total < 2)
    return;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  for(int i = 0; i < total; i++) {
    int x1 = x[i];
    int y1 = y[i];
    int x2 = (i + 1 != total) ? x[i + 1] : x[0];
    int y2 = (i + 1 != total) ? y[i + 1] : y[0];
    if((x1 < 0 && x2 < 0) || (y1 < 0 && y2 < 0)) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(x1 >= m_width && x2 >= m_width) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(y1 >= m_height && y2 >= m_height) {
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    if(x1 == x2 && y1 == y2) {
      PixelSet(x1, y1, clr);
      if(style != UINT_MAX)
        m_style = prev_style;
      return;
    }
    double dx = x2 - x1;
    double dy = y2 - y1;
    double xy = sqrt(dx * dx + dy * dy);
    double xx = x1;
    double yy = y1;
    dx /= xy;
    dy /= xy;
    do {
      if((m_style & mask) == mask) {
        PixelSetAA(xx, yy, clr);
      }
      xx += dx;
      yy += dy;
      mask <<= 1;
      if(mask == 0x1000000)
        mask = 1;
    } while(fabs(x2 - xx) >= fabs(dx) && fabs(y2 - yy) >= fabs(dy));
    if((m_style & mask) == mask) {
      PixelSetAA(x2, y2, clr);
    }
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::TriangleAA(const int x1, const int y1, const int x2, const int y2, const int x3, const int y3, const uint clr, const uint style) {
  int x[3];
  int y[3];
  x[0] = x1;
  x[1] = x2;
  x[2] = x3;
  y[0] = y1;
  y[1] = y2;
  y[2] = y3;
  PolygonAA(x, y, clr, style);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::CircleAA(const int x, const int y, const double r, const uint clr, const uint style = UINT_MAX) {
  if(r <= 0)
    return;
  double xx = x + r;
  double yy = y;
  double fi = 0;
  double df = M_PI_2 / MathCeil(r);
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  if(r > M_PI)
    df /= 2;
  do {
    xx = x + r * cos(fi);
    yy = y - r * sin(fi);
    if((m_style & mask) == mask)
      PixelSetAA(xx, yy, clr);
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
    fi += df;
  } while(fabs(2 * M_PI - fi) >= df / 2);
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::EllipseAA(const double x1, const double y1, const double x2, const double y2, const uint clr, const uint style = UINT_MAX) {
  double rx = (x2 - x1) / 2;
  double ry = (y2 - y1) / 2;
  double x = (x2 > x1) ? x1 + rx : x2 + rx;
  double y = (y2 > y1) ? y1 + ry : y2 + ry;
  double rx2 = rx * rx;
  double ry2 = ry * ry;
  uint prev_style = m_style;
  if(style != UINT_MAX)
    LineStyleSet(style);
  uint mask = 1 << m_style_idx;
  double quarter = round(rx2 / sqrt(rx2 + ry2));
  for(double dx = 0; dx <= quarter; dx++) {
    double dy = ry * sqrt(1 - dx * dx / rx2);
    if((m_style & mask) == mask)
      PixelSet4AA(x, y, dx, dy, clr);
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  quarter = round(ry2 / sqrt(rx2 + ry2));
  for(double dy = 0; dy <= quarter; dy++) {
    double dx = rx * sqrt(1 - dy * dy / ry2);
    if((m_style & mask) == mask)
      PixelSet4AA(x, y, dx, dy, clr);
    mask <<= 1;
    if(mask == 0x1000000)
      mask = 1;
  }
  if(style != UINT_MAX)
    m_style = prev_style;
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
static uint CCanvas::GetDefaultColor(const int i) {
  if(i < 0)
    return(0);
  if(i < ArraySize(m_default_colors))
    return(m_default_colors[i]);
  return(XRGB((i % 3) * 60 + i * 50, ((i + 1) % 3) * 60 + i * 60, ((i + 2) % 3) * 60 + i * 50));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CCanvas::TransparentLevelSet(const uchar value) {
  int total = ArraySize(m_pixels);
  uint value24 = (uint)value << 24;
  for(int i = 0; i < total; i++)
    m_pixels[i] = value24 | (m_pixels[i] & 0xFFFFFF);
}
