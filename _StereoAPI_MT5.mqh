      __MT_Object_SetWidth(m_chart_id, name, width);
      __MT_Object_SetColor(m_chart_id, name, clr);
      __MT_Object_SetBackground(m_chart_id, name, true);
      __MT_Object_SetToolTip(m_chart_id, name, tooltip);
      __MT_Object_SetVisible(m_chart_id, name, true);
      return m_cnt_objects - 1;
    }
    return -1;
  }
  CHARTDRAW_ID       Line(string text, double pricebegin, color clr = clrBlue, datetime timebegin = 0, datetime timeend = TIME_INFINITE, int width = 1, ENUM_LINE_STYLE style = STYLE_SOLID, string tooltip = NULL) {
    if(!m_active)return -1;
    return LineTrend(text, timebegin, pricebegin, timeend, 0, clr, width, style, tooltip);
  }
  CHARTDRAW_ID       LineTrend(string text, datetime timebegin, double pricebegin, datetime timeend, double priceend, color clr, int width = 1, ENUM_LINE_STYLE style = STYLE_SOLID, string tooltip = NULL, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    if(pricebegin <= 0) {
      int shift = m_bars._GetShiftSync(0);
      pricebegin = _iClose(NULL, __TIMEFRAME, shift);
    }
    if(priceend <= 0)
      priceend = pricebegin;
    if(timebegin <= 0) {
      int shift = m_bars._GetShiftSync(0);
      timebegin = _iTime(NULL, __TIMEFRAME, shift);
    }
    TIMEENDCONVERT(timeend, timebegin);
    TIMECHECK(timebegin, timeend);
    string name;
    bool isnew = id < 0;
    if(isnew) {
      name = GetNewObjectName(SCOBJECT_TYPE_LINE);
      id = m_cnt_objects - 1;
    } else
      name = IdToObjectName(id);
    if(name == NULL)return -1;
    ReplaceTextMacros(text, tooltip, pricebegin, timebegin);
    if(isnew || !__MT_Object_Exists(m_chart_id, name)) {
      if(!__MT_Object_Line_CreateTrend(m_chart_id, name, 0, timebegin, pricebegin, timeend, priceend))
        return -1;
      __MT_Object_SetBackground(m_chart_id, name, true);
      __MT_Object_Line_SetRayV(m_chart_id, name, false);
      __MT_Object_Line_SetRayL(m_chart_id, name, false);
      __MT_Object_Line_SetRayR(m_chart_id, name, false);
      __MT_Object_SetText(m_chart_id, name, " ");
      __MT_Object_SetToolTip(m_chart_id, name, tooltip);
      __MT_Object_SetVisible(m_chart_id, name, true);
    } else
      LineMove(id, pricebegin, priceend, timebegin, timeend, text, tooltip);
    __MT_Object_Line_SetStyle(m_chart_id, name, style);
    if(m_autodpi_width)width = __Scale.Int(width);
    __MT_Object_SetWidth(m_chart_id, name, width);
    __MT_Object_SetColor(m_chart_id, name, clr);
    name = IdToObjectName(id, 1);
    if(isnew || !__MT_Object_Exists(m_chart_id, name)) {
      if(text == NULL || text == "")
        return id;
      __MT_Object_Text_Create(m_chart_id, name, 0, timebegin, pricebegin);
    } else if(text == NULL)
      text = "";
    __MT_Object_SetAnchor(m_chart_id, name, ANCHOR_LEFT_LOWER);
    __MT_Object_SetText(m_chart_id, name, text);
    __MT_Object_SetColor(m_chart_id, name, clr);
    __MT_Object_SetFont(m_chart_id, name, m_line_fontname, __Scale.Font(m_line_fontsize));
    __MT_Object_SetToolTip(m_chart_id, name, tooltip);
    __MT_Object_SetVisible(m_chart_id, name, true);
    return id;
  }
  void               ReplaceTextMacros(string&text, string&tooltip, double price, datetime time) {
    if(text != NULL) {
      StringReplace(text, "%price", DoubleToString(price, m_digits));
      StringReplace(text, "%time", (string)time);
    }
    if(tooltip == NULL)
      tooltip = text;
    else {
      StringReplace(tooltip, "%price", DoubleToString(price, m_digits));
      StringReplace(tooltip, "%time", (string)time);
    }
  }
  bool               LineMove(CHARTDRAW_ID id, double newprice, string text = NULL, string tooltip = NULL, datetime newbegin = -1) {
    if(!m_active)return false;
    string nameline = IdToObjectName(id);
    string namelabel = IdToObjectName(id, 1);
    if(newbegin == -1)
      newbegin = __MT_Object_GetTime(m_chart_id, nameline, 0);
    ReplaceTextMacros(text, tooltip, newprice, newbegin);
    if(text != NULL)
      __MT_Object_SetText(m_chart_id, namelabel, text);
    if(tooltip != NULL)
      __MT_Object_SetToolTip(m_chart_id, namelabel, tooltip);
    if(newbegin == -1) {
      bool result = __MT_Object_SetPrice(m_chart_id, nameline, 0, newprice);
      result &= __MT_Object_SetPrice(m_chart_id, nameline, 1, newprice);
      result &= __MT_Object_SetPrice(m_chart_id, namelabel, 0, newprice);
      return result;
    } else {
      bool result = __MT_Object_SetPrice(m_chart_id, nameline, 0, newprice);
      result &= __MT_Object_SetPrice(m_chart_id, nameline, 1, newprice);
      result &= __MT_Object_SetPrice(m_chart_id, namelabel, 0, newprice);
      result &= __MT_Object_SetTime(m_chart_id, nameline, 0, newbegin);
      result &= __MT_Object_SetTime(m_chart_id, namelabel, 0, newbegin);
      return result;
    }
  }
  bool               LineMove(CHARTDRAW_ID id, double newpricebegin, double newpriceend, datetime newtimebegin, datetime newtimeend, string text = NULL, string tooltip = NULL) {
    if(!m_active)return false;
    string nameline = IdToObjectName(id);
    string namelabel = IdToObjectName(id, 1);
    ReplaceTextMacros(text, tooltip, newpricebegin, newtimebegin);
    if(text != NULL)
      __MT_Object_SetText(m_chart_id, namelabel, text);
    if(tooltip != NULL)
      __MT_Object_SetToolTip(m_chart_id, namelabel, tooltip);
    bool result = true;
    if(newpricebegin >= 0)
      result &= __MT_Object_SetPrice(m_chart_id, nameline, 0, newpricebegin)&
                __MT_Object_SetPrice(m_chart_id, namelabel, 0, newpricebegin);
    if(newpriceend >= 0)
      result &= __MT_Object_SetPrice(m_chart_id, nameline, 1, newpriceend);
    if(newtimebegin >= 0)
      result &= __MT_Object_SetTime(m_chart_id, nameline, 0, newtimebegin)&
                __MT_Object_SetTime(m_chart_id, namelabel, 0, newtimebegin);
    if(newtimeend >= 0)
      result &= __MT_Object_SetTime(m_chart_id, nameline, 1, newtimeend);
    return result;
  }
  bool               LineText(CHARTDRAW_ID id, string text) {
    string namelabel = IdToObjectName(id, 1);
    if(namelabel == NULL)
      return false;
    return __MT_Object_SetText(m_chart_id, namelabel, text);
  }
  bool               LineFont(CHARTDRAW_ID id, int fontsize, string fontname = NULL) {
    string namelabel = IdToObjectName(id, 1);
    if(namelabel == NULL)
      return false;
    return __MT_Object_SetFont(m_chart_id, namelabel, (fontname == NULL ? m_line_fontname : fontname), __Scale.Font(fontsize));
  }
  bool               LineColor(CHARTDRAW_ID id, color clr) {
    string nameline = IdToObjectName(id);
    string namelabel = IdToObjectName(id, 1);
    bool result = __MT_Object_SetColor(m_chart_id, nameline, clr);
    result &= __MT_Object_SetColor(m_chart_id, namelabel, clr);
    return result;
  }
  bool               LineDelete(CHARTDRAW_ID id) {
    if(!m_active)return false;
    if(id == -1)
      return LineDeleteAll();
    return Delete(id);
  }
public:
  void               ClusterFontDefault(int fontsize, string fontname = NULL) {
    if(fontname != NULL)
      m_cluster_fontname = fontname;
    m_cluster_fontsize = fontsize;
  }
  CHARTDRAW_ID       ClusterLong(string text, datetime timebegin, double pricebegin, datetime timeend, double priceend, string tooltip = NULL, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    color clrcluster = GetColor(1, m_mix);
    color clrframe = GetColor(1, m_mix * 2);
    color clrtext = clrWhite;
    return _Cluster(text, tooltip, timebegin, pricebegin, timeend, priceend, clrcluster, clrframe, clrtext, id);
  }
  CHARTDRAW_ID       ClusterShort(string text, datetime timebegin, double pricebegin, datetime timeend, double priceend, string tooltip = NULL, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    color clrcluster = GetColor(-1, m_mix);
    color clrframe = GetColor(-1, m_mix * 2);
    color clrtext = clrWhite;
    return _Cluster(text, tooltip, timebegin, pricebegin, timeend, priceend, clrcluster, clrframe, clrtext, id);
  }
  CHARTDRAW_ID       Cluster(string text, datetime timebegin, double pricebegin, datetime timeend, double priceend, color clr_cluster, color clrtext, string tooltip = NULL, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    color clrcluster = GetColor(clr_cluster, m_mix);
    color clrframe = GetColor(clr_cluster, m_mix * 2);
    return _Cluster(text, tooltip, timebegin, pricebegin, timeend, priceend, clrcluster, clrframe, clrtext, id);
  }
  void               ClusterType(bool fillcluster, int linethickness) {
    m_clusterfill = fillcluster;
    m_clusterlinewidth = linethickness;
  }
  CHARTDRAW_ID       Rectangle(datetime timebegin, double pricebegin, datetime timeend, double priceend, color clr, string text = NULL, string tooltip = NULL, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    return _Cluster(text, tooltip, timebegin, pricebegin, timeend, priceend, clr, clrNONE, clrNONE, id);
  }
private:
  CHARTDRAW_ID       _Cluster(string text, string tooltip, datetime timebegin, double pricebegin, datetime timeend, double priceend, color clrcluster, color clrframe, color clrtext, CHARTDRAW_ID id = -1) {
    if(!m_active)return -1;
    TIMEENDCONVERT(timeend, timebegin);
    TIMECHECK(timebegin, timeend);
    if(priceend < 0)
      priceend = pricebegin + m_sea_base.PointsToPrice(-priceend);
    string name;
    bool isnew = id == -1;
    if(isnew) {
      name = GetNewObjectName(SCOBJECT_TYPE_CLUSTER);
      id = m_cnt_objects - 1;
    } else
      name = IdToObjectName(id);
    if(name == NULL)
      return -1;
    if(tooltip == NULL) {
      tooltip = text + "\n" + TimeToString(timebegin) + " - " + TimeToString(timeend) + "\n(" + (string)pricebegin + " - " + (string)priceend + ")";
    }
    if(clrcluster != clrNONE && m_clusterfill) {
      if(isnew || !__MT_Object_Exists(m_chart_id, name))
        __MT_Object_Rect_Create(m_chart_id, name, 0, timebegin, pricebegin, timeend, priceend);
      else {
        __MT_Object_SetPrice(m_chart_id, name, 0, pricebegin);
        __MT_Object_SetPrice(m_chart_id, name, 1, priceend);
        __MT_Object_SetTime(m_chart_id, name, 0, timebegin);
        __MT_Object_SetTime(m_chart_id, name, 1, timeend);
      }
      __MT_Object_SetColor(m_chart_id, name, clrcluster);
      __MT_Object_SetBackground(m_chart_id, name, true);
      __MT_Object_SetToolTip(m_chart_id, name, tooltip);
      __MT_Object_SetText(m_chart_id, name, text);
      __MT_Object_SetAnchor(m_chart_id, name, ANCHOR_LEFT);
      __MT_Object_SetVisible(m_chart_id, name, true);
    }
    if(clrframe != clrNONE) {
      string nameL = IdToObjectName(id, 1);
      if(isnew || !__MT_Object_Exists(m_chart_id, nameL))
        __MT_Object_Line_CreateTrend(m_chart_id, nameL, 0, timebegin, pricebegin, timeend, pricebegin);
      else {
        __MT_Object_SetPrice(m_chart_id, nameL, 0, pricebegin);
        __MT_Object_SetPrice(m_chart_id, nameL, 1, pricebegin);
        __MT_Object_SetTime(m_chart_id, nameL, 0, timebegin);
        __MT_Object_SetTime(m_chart_id, nameL, 1, timeend);
      }
      __MT_Object_Line_SetStyle(m_chart_id, nameL, STYLE_SOLID);
      int width = m_autodpi_width ? m_clusterlinewidth : __Scale.Int(m_clusterlinewidth);
      __MT_Object_SetWidth(m_chart_id, nameL, width);
      __MT_Object_SetColor(m_chart_id, nameL, clrframe);
      __MT_Object_SetBackground(m_chart_id, nameL, true);
      __MT_Object_Line_SetRayL(m_chart_id, nameL, false);
      __MT_Object_Line_SetRayR(m_chart_id, nameL, false);
      __MT_Object_SetText(m_chart_id, nameL, text);
      __MT_Object_SetToolTip(m_chart_id, nameL, tooltip);
      __MT_Object_SetVisible(m_chart_id, nameL, true);
      nameL = IdToObjectName(id, 2);
      if(isnew || !__MT_Object_Exists(m_chart_id, nameL))
        __MT_Object_Line_CreateTrend(m_chart_id, nameL, 0, timebegin, priceend, timeend, priceend);
      else {
        __MT_Object_SetPrice(m_chart_id, nameL, 0, priceend);
        __MT_Object_SetPrice(m_chart_id, nameL, 1, priceend);
        __MT_Object_SetTime(m_chart_id, nameL, 0, timebegin);
        __MT_Object_SetTime(m_chart_id, nameL, 1, timeend);
      }
      __MT_Object_Line_SetStyle(m_chart_id, nameL, STYLE_SOLID);
      __MT_Object_SetWidth(m_chart_id, nameL, width);
      __MT_Object_SetColor(m_chart_id, nameL, clrframe);
      __MT_Object_SetBackground(m_chart_id, nameL, true);
      __MT_Object_Line_SetRayL(m_chart_id, nameL, false);
      __MT_Object_Line_SetRayR(m_chart_id, nameL, false);
      __MT_Object_SetText(m_chart_id, nameL, text);
      __MT_Object_SetToolTip(m_chart_id, nameL, tooltip);
      __MT_Object_SetVisible(m_chart_id, nameL, true);
    }
    if(clrtext != clrNONE) {
      string nameL = IdToObjectName(id, 3);
      if(isnew || !__MT_Object_Exists(m_chart_id, name))
        __MT_Object_Text_Create(m_chart_id, nameL, 0, timebegin, MAX(priceend, pricebegin));
      __MT_Object_SetAnchor(m_chart_id, nameL, ANCHOR_LEFT_UPPER);
      __MT_Object_SetText(m_chart_id, nameL, text);
      __MT_Object_SetColor(m_chart_id, nameL, clrtext);
      __MT_Object_SetFont(m_chart_id, nameL, m_cluster_fontname, __Scale.Font(m_cluster_fontsize));
      __MT_Object_SetToolTip(m_chart_id, nameL, tooltip);
      __MT_Object_SetVisible(m_chart_id, nameL, true);
    }
    return id;
  }
public:
  bool               ClusterText(CHARTDRAW_ID id, string text) {
    string namelabel = IdToObjectName(id, 3);
    if(namelabel == NULL)return false;
    return __MT_Object_SetText(m_chart_id, namelabel, text);
  }
  bool               ClusterFont(CHARTDRAW_ID id, int fontsize, string fontname = NULL) {
    string namelabel = IdToObjectName(id, 3);
    if(namelabel == NULL)
      return false;
    return __MT_Object_SetFont(m_chart_id, namelabel, (fontname == NULL ? m_line_fontname : fontname), __Scale.Font(fontsize));
  }
public:
  bool               ClusterDelete(CHARTDRAW_ID id) {
    if(!m_active)return false;
    if(id == -1)
      return ClusterDeleteAll();
    return Delete(id);
  }
public:
  CHARTDRAW_ID       ArrowLong(string text = NULL, int size = 2, int shift = 0) {
    if(!m_active)return -1;
    shift = m_bars._GetShiftSync(shift);
    double price;
    price = m_bars.Open(shift);
    return Arrow(+1, m_bars.Time(shift), price, text, size, ANCHOR_TOP);
  }
  CHARTDRAW_ID       ArrowShort(string text = NULL, int size = 2, int shift = 0) {
    if(!m_active)return -1;
    shift = m_bars._GetShiftSync(shift);
    double price;
    price = m_bars.Open(shift);
    return Arrow(-1, m_bars.Time(shift), price, text, size, ANCHOR_BOTTOM);
  }
  CHARTDRAW_ID       ArrowLong(double price, string text = NULL, int size = 2, int shift = 0) {
    shift = m_bars._GetShiftSync(shift);
    return Arrow(+1, _iTime(NULL, __TIMEFRAME, shift), price, text, size);
  }
  CHARTDRAW_ID       ArrowShort(double price, string text = NULL, int size = 2, int shift = 0) {
    shift = m_bars._GetShiftSync(shift);
    return Arrow(-1, _iTime(NULL, __TIMEFRAME, shift), price, text, size);
  }
  CHARTDRAW_ID       Arrow(int filter, datetime timebegin, double pricebegin, string text = NULL, int size = 3, ENUM_ARROW_ANCHOR anchor = WRONG_VALUE) {
    if(!m_active)return -1;
    if(filter == 0)
      return -1;
    color clr = m_clrbear;
    if(filter > 0)
      clr = m_clrbull;
    if(anchor == WRONG_VALUE)
      anchor = filter > 0 ? ANCHOR_TOP : ANCHOR_BOTTOM;
    string name = GetNewObjectName(SCOBJECT_TYPE_ARROW);
    if(name == NULL)return -1;
    if(filter > 0)
      __MT_Object_ArrowUp_Create(m_chart_id, name, 0, timebegin, pricebegin);
    else
      __MT_Object_ArrowDown_Create(m_chart_id, name, 0, timebegin, pricebegin);
    __MT_Object_SetColor(m_chart_id, name, clr);
    if(text == NULL)
      text = "\n";
    __MT_Object_SetToolTip(m_chart_id, name, text);
    if(m_autodpi_width)size = __Scale.Int(size);
    __MT_Object_SetWidth(m_chart_id, name, size);
    __MT_Object_SetBackground(m_chart_id, name, true);
    if(anchor != WRONG_VALUE)
      __MT_Object_SetAnchor(m_chart_id, name, anchor);
    __MT_Object_SetVisible(m_chart_id, name, true);
    return m_cnt_objects - 1;
  }
  bool               ArrowDelete(CHARTDRAW_ID id) {
    if(!m_active)return false;
    if(id == -1)
      ArrowDeleteAll();
    return Delete(id);
  }
public:
  CHARTDRAW_ID       HighlightLong(int shift = 0, int minutes = -1) {
    return Highlight(m_clrbull, shift, minutes);
  }
  CHARTDRAW_ID       HighlightShort(int shift = 0, int minutes = -1) {
    return Highlight(m_clrbear, shift, minutes);
  }
  CHARTDRAW_ID       HighlightLong(datetime timebegin, int minutes = -1) {
    return Highlight(timebegin, m_clrbull, minutes);
  }
  CHARTDRAW_ID       HighlightShort(datetime timebegin, int minutes = -1) {
    return Highlight(timebegin, m_clrbull, minutes);
  }
  CHARTDRAW_ID       Highlight(color clr = clrNONE, int shift = 0, int minutes = -1) {
    shift = m_bars._GetShiftSync(shift);
    return Highlight(_iTime(NULL, __TIMEFRAME, shift), clr, minutes);
  }
  CHARTDRAW_ID       Highlight(datetime timebegin, color clr = clrNONE, int durationminutes = -1) {
    if(!m_active)return -1;
    string name = GetNewObjectName(SCOBJECT_TYPE_HIGHLIGHT);
    if(name == NULL)return -1;
    datetime timeend;
    if(durationminutes == -1) {
      timeend = timebegin + (__TIMEFRAME * 60);
      timebegin -= (__TIMEFRAME * 60);
    } else
      timeend = timebegin + (60 * durationminutes);
    clr = ColorMix(clr, m_clrback, m_mix);
    __MT_Object_Rect_Create(m_chart_id, name, 0, timebegin, 0, timeend, 999999);
    __MT_Object_SetColor(m_chart_id, name, clr);
    __MT_Object_SetBackground(m_chart_id, name, true);
    __MT_Object_SetVisible(m_chart_id, name, true);
    return m_cnt_objects - 1;
  }
  bool               HighlightDelete(CHARTDRAW_ID id) {
    if(!m_active)return false;
    if(id == -1)
      return HighlightDeleteAll();
    return Delete(id);
  }
  bool               HighlightMove(CHARTDRAW_ID id, datetime time) {
    if(!m_active)return false;
    string name = IdToObjectName(id);
    datetime begintime = __MT_Object_GetTime(m_chart_id, name, 0);
    datetime endtime = __MT_Object_GetTime(m_chart_id, name, 1);
    endtime = time + (endtime - begintime);
    __MT_Object_SetTime(m_chart_id, name, 0, time);
    return __MT_Object_SetTime(m_chart_id, name, 1, endtime);
  }
  bool               HighlightShift(CHARTDRAW_ID id, int bars = 1) {
    if(!m_active)return false;
    string name = IdToObjectName(id);
    datetime begintime = __MT_Object_GetTime(m_chart_id, name, 0) - (m_bars.TimeFrame() * 60 * bars);
    datetime endtime = begintime + (m_bars.TimeFrame() * 60);
    __MT_Object_SetTime(m_chart_id, name, 0, begintime);
    return __MT_Object_SetTime(m_chart_id, name, 1, endtime);
  }
  bool               HighlightToolTip(CHARTDRAW_ID id, string text) {
    if(!m_active)return false;
    string name = IdToObjectName(id);
    return __MT_Object_SetToolTip(m_chart_id, name, text);
  }
public:
  bool               FilterLong(int shift = 0) {
    return Filter(+1, 0, 0, shift);
  }
  bool               FilterShort(int shift = 0) {
    return Filter(-1, 0, 0, shift);
  }
  bool               FilterNone(int shift = 0) {
    return Filter(0, 0, 0, shift);
  }
public:
  bool               Filter(int filter, datetime timebegin = 0, datetime timeend = 0, int shift = 0) {
    if(!m_active)return false;
    shift = m_bars._GetShiftSync(shift);
    if(filter != m_filter) {
      m_filter = filter;
      if(m_filter == 0)
        return true;
      if(timebegin == 0)
        timebegin = _iTime(NULL, PERIOD_CURRENT, shift);
      m_timebegin = timebegin;
      m_name_filter = GetNewObjectName(SCOBJECT_TYPE_FILTER);
      if(m_name_filter == NULL)return false;
      color clr = GetColor(m_filter, m_mix);
      if(timeend == 0) {
        timeend = _iTime(NULL, PERIOD_CURRENT, shift - 1);
      }
      double price = _iClose(NULL, PERIOD_CURRENT, shift);
      __MT_Object_Rect_Create(m_chart_id, m_name_filter, 0, m_timebegin, 0, timeend, price * 10);
      __MT_Object_SetColor(m_chart_id, m_name_filter, clr);
      __MT_Object_SetBackground(m_chart_id, m_name_filter, true);
      __MT_Object_SetVisible(m_chart_id, m_name_filter, true);
    } else {
      m_filter = filter;
      if(filter == 0)
        return true;
      if(timeend == 0) {
        timeend = _iTime(NULL, PERIOD_CURRENT, shift - 1);
        if(timeend == 0)
          timeend = _iTime(NULL, __TIMEFRAME, shift);
      }
      __MT_Object_SetTime(m_chart_id, m_name_filter, 1, timeend);
    }
    return true;
  }
  CHARTDRAW_ID       Candle(CBar*bar, datetime timebegin, datetime timeend = 1) {
    if(!m_active)return -1;
    if(PTR_INVALID(bar))
      return -1;
    if(!m_active)return false;
    TIMEENDCONVERT(timeend, timebegin);
    string name = GetNewObjectName(SCOBJECT_TYPE_CANDLE);
    CHARTDRAW_ID id = m_cnt_objects;
    if(name == NULL)return -1;
    string tooltip = "\n";
    color clr = (bar.IsBearish()) ? m_sea_base.zfu638707147322096757.clr_bear : m_sea_base.zfu638707147322096757.clr_bull;
    __MT_Object_Rect_Create(m_chart_id, name, 0, timebegin, bar.open, timeend, bar.close);
    __MT_Object_SetColor(m_chart_id, name, clr);
    __MT_Object_SetBackground(m_chart_id, name, true);
    __MT_Object_SetVisible(m_chart_id, name, true);
    string namewick = IdToObjectName(id, 1);
    timebegin = (timebegin + timeend - 180) / 2;
    timeend = timebegin + __TIMEFRAME * 120;
    __MT_Object_Rect_Create(m_chart_id, namewick, 0, timebegin, MAX(bar.open, bar.close), timeend, bar.high);
    __MT_Object_SetColor(m_chart_id, namewick, clr);
    __MT_Object_SetBackground(m_chart_id, namewick, true);
    __MT_Object_SetVisible(m_chart_id, namewick, true);
    string nametail = IdToObjectName(id, 2);
    __MT_Object_Rect_Create(m_chart_id, nametail, 0, timebegin, MIN(bar.open, bar.close), timeend, bar.low);
    __MT_Object_SetColor(m_chart_id, nametail, clr);
    __MT_Object_SetBackground(m_chart_id, nametail, true);
    __MT_Object_SetVisible(m_chart_id, nametail, true);
    return m_cnt_objects - 1;
  }
  bool               CandleUpdate(CHARTDRAW_ID id, CBar*bar) {
    if(!m_active)return false;
    if(PTR_INVALID(bar))
      return false;
    string name = IdToObjectName(id);
    string namewick = IdToObjectName(id, 1);
    string nametail = IdToObjectName(id, 2);
    color clr = (bar.IsBearish()) ? m_sea_base.zfu638707147322096757.clr_bear : m_sea_base.zfu638707147322096757.clr_bull;
    __MT_Object_SetColor(m_chart_id, name, clr);
    __MT_Object_SetColor(m_chart_id, namewick, clr);
    __MT_Object_SetPrice(m_chart_id, name, 0, bar.open);
    __MT_Object_SetPrice(m_chart_id, name, 1, bar.close);
    __MT_Object_SetPrice(m_chart_id, namewick, 0, MAX(bar.close, bar.open));
    __MT_Object_SetPrice(m_chart_id, namewick, 1, bar.high);
    __MT_Object_SetPrice(m_chart_id, nametail, 0, MIN(bar.close, bar.open));
    __MT_Object_SetPrice(m_chart_id, nametail, 1, bar.low);
    return true;
  }
  bool               CandleDelete(CHARTDRAW_ID id) {
    if(!m_active)return false;
    if(id == -1)
      return CandleDeleteAll();
    return Delete(id);
  }
private:
  double             linepricebegin[8];
  double             linepriceend[8];
  datetime           linetimebegin[8];
  datetime           linetimeend[8];
  color              linecolor[8];
  int                linewidth[8];
  uint               linestyle[8];
  int                linecnt[8];
  string             linetooltip[8];
public:
  bool               TraceLineInit(CHARTDRAW_ID id = -1, color clr = clrBlue, int width = 1, ENUM_LINE_STYLE style = STYLE_SOLID, string tooltip = NULL) {
    if(id < 0) {
      for(int i = 0; i < 8; i++)
        TraceLineInit(i);
      return true;
    }
    linepricebegin[id] = 0;
    linepriceend[id] = 0;
    linetimebegin[id] = 0;
    linetimeend[id] = 0;
    if(tooltip == NULL)
      tooltip = "\n";
    linetooltip[id] = tooltip;
    linecolor[id] = clr;
    linewidth[id] = width;
    linestyle[id] = style;
    linecnt[id] = 0;
    return false;
  }
  bool               TraceLineBegin(CHARTDRAW_ID id, double price, color clr = clrNONE, int shift = 0) {
    if(!m_active)return false;
    shift = m_bars._GetShiftSync(shift);
    datetime timebegin = _iTime(NULL, __TIMEFRAME, shift);
    return TraceLineBegin(id, price, timebegin, clr);
  }
  bool               TraceLineBegin(CHARTDRAW_ID id, double price, datetime timebegin, color clr = clrNONE) {
    if(!m_active)return false;
    if(id < 0 || id > 7 || price <= 0)
      return false;
    linecnt[id]++;
    linetimebegin[id] = timebegin;
    linetimeend[id] = timebegin;
    linepricebegin[id] = price;
    linepriceend[id] = price;
    string name = GetNewObjectName(SCOBJECT_TYPE_TRACELINE);
    if(name == NULL)return false;
    name += "#" + (string)linecnt[id];
    __MT_Object_Line_CreateTrend(m_chart_id, name, 0, linetimebegin[id], linepricebegin[id], linetimeend[id], linepriceend[id]);
    if(clr != clrNONE)
      linecolor[id] = clr;
    __MT_Object_SetColor(m_chart_id, name, linecolor[id]);
    int width = m_autodpi_width ? __Scale.Int(linewidth[id]) : linewidth[id];
    __MT_Object_SetWidth(m_chart_id, name, width);
    __MT_Object_Line_SetStyle(m_chart_id, name, (ENUM_LINE_STYLE)linestyle[id]);
    __MT_Object_Line_SetRayL(m_chart_id, name, false);
    __MT_Object_Line_SetRayR(m_chart_id, name, false);
    string tt = linetooltip[id];
    StringReplace(tt, "%price", (string)linepricebegin[id]);
    __MT_Object_SetToolTip(m_chart_id, name, tt);
    __MT_Object_SetVisible(m_chart_id, name, true);
    return true;
  }
  bool               TraceLineUpdate(CHARTDRAW_ID id, double price, color clr = clrNONE, int shift = 0) {
    if(!m_active)return false;
    shift = m_bars._GetShiftSync(shift);
    datetime timeend = _iTime(NULL, __TIMEFRAME, shift);
    return TraceLineUpdate(id, price, timeend, clr);
  }
  bool               TraceLineUpdate(CHARTDRAW_ID id, double price, datetime time, color clr = clrNONE) {
    if(!m_active)return false;
    if(id < 0 || id > 7)
      return false;
    if(price <= 0) {
      if(linepriceend[id] > 0 && price < 0)
        TraceLineUpdate(id, linepriceend[id], time, clr);
      linepriceend[id] = 0;
      linetimeend[id] = 0;
      return true;
    }
    if(time == 0) {
      int shift = m_bars._GetShiftSync(0);
      time = _iTime(NULL, __TIMEFRAME, shift);
    }
    if(price == linepriceend[id] && time == linetimeend[id])
      return true;
    string name = GetNewObjectName(SCOBJECT_TYPE_TRACELINE);
    if(name == NULL)return false;
    name += "#" + (string)linecnt[id];
    if(price == linepricebegin[id] && price == linepriceend[id] && time != linetimeend[id]) {
      __MT_Object_SetTime(m_chart_id, name, 1, time);
    } else {
      double priceold = linepriceend[id];
      datetime timeold = linetimeend[id];
      TraceLineBegin(id, price, time, clr);
      name = IdToObjectName(id) + "#" + (string)linecnt[id];
      if(priceold > 0) {
        __MT_Object_SetTime(m_chart_id, name, 0, timeold);
        __MT_Object_SetPrice(m_chart_id, name, 0, priceold);
        linepricebegin[id] = priceold;
        linetimebegin[id] = timeold;
      }
    }
    linepriceend[id] = price;
    linetimeend[id] = time;
    return true;
  }
private:
  color              GetColor(int filter, double mix) {
    if(filter == 0)
      return m_clrback;
    return ColorMix(filter > 0 ? m_clrbull : m_clrbear, m_clrback, mix);
  }
  color              GetColor(color clr, double mix) {
    return ColorMix(clr, m_clrback, mix);
  }
private:
  color              ColorMix(color rgb2, color rgb1, double mixfactor = 0.5) {
    zfu638707147322095969 c;
    if(mixfactor == 0)
      return rgb1;
    else if(mixfactor >= 1)
      return rgb2;
    else {
      MINMAX(mixfactor, 0, 1);
      double mix2 = mixfactor;
      double mix1 = 1 - mix2;
      uint r = (uint)(uchar((rgb1) >> 16) * mix1 + uchar((rgb2) >> 16) * mix2);
      uint g = (uint)(uchar((rgb1) >> 8) * mix1 + uchar((rgb2) >> 8) * mix2);
      uint b = (uint)(uchar((rgb1) >> 0) * mix1 + uchar((rgb2) >> 0) * mix2);
      uint a = (uint)(uchar((rgb1) >> 24) * mix1 + uchar((rgb2) >> 24) * mix2);
      c = ((uchar(a) << 24) | (uchar(r) << 16)) | (uchar(g) << 8) | (uchar(b));
    }
    return(zfu638707147322095968)c;
  }
};
