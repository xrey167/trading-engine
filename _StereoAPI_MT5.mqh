//+------------------------------------------------------------------+
bool __MT_GetChartMetrics(long chartid, int subwin, SChartMetrics&metrics, bool subwinrelated_only = false) {
  bool changed = false;
  long l_value = 0;
  double d_value = 0;
  if(chartid == NULL)
    chartid = __MT_GetCurrentChartID();
  if(!subwinrelated_only) {
    if(!::ChartGetInteger(chartid, CHART_WIDTH_IN_PIXELS, subwin, l_value))return false;
    changed |= (int)l_value != metrics.width;
    metrics.width = (int)l_value;
    if(!::ChartGetInteger(chartid, CHART_SHIFT, subwin, l_value))return false;
    changed |= (bool)l_value != metrics.shift_status;
    metrics.shift_status = (bool)l_value;
    if(!::ChartGetDouble(chartid, CHART_SHIFT_SIZE, subwin, d_value))return false;
    changed |= (bool)d_value != metrics.shift_size;
    metrics.shift_size = (double)d_value;
    if(!::ChartGetInteger(chartid, CHART_FIRST_VISIBLE_BAR, subwin, l_value))return false;
    changed |= (int)l_value != metrics.firstbar_shift;
    metrics.firstbar_shift = (int)l_value;
    if(!::ChartGetInteger(chartid, CHART_VISIBLE_BARS, subwin, l_value))return false;
    changed |= (int)l_value != metrics.cntbars;
    metrics.cntbars = (int)l_value;
    if(!::ChartGetInteger(chartid, CHART_SCALE, subwin, l_value))return false;
    changed |= (int)l_value != metrics.scale;
    metrics.scale = (int)l_value;
  }
  if(subwin == 0)
    metrics.offset_y = 0;
  else {
    if(!::ChartGetInteger(chartid, CHART_WINDOW_YDISTANCE, subwin, l_value))return false;
    changed |= (int)l_value != metrics.offset_y;
    metrics.offset_y = (int)l_value;
  }
  if(!::ChartGetDouble(chartid, CHART_PRICE_MIN, subwin, d_value))return false;
  changed |= (bool)d_value != metrics.price_min;
  metrics.price_min = (double)d_value;
  if(!::ChartGetDouble(chartid, CHART_PRICE_MAX, subwin, d_value))return false;
  changed |= (bool)d_value != metrics.price_max;
  metrics.price_max = (double)d_value;
  if(!::ChartGetInteger(chartid, CHART_HEIGHT_IN_PIXELS, subwin, l_value))return false;
  changed |= (int)l_value != metrics.height;
  metrics.height = (int)l_value;
  int sub = (int)((double)metrics.width * metrics.shift_size / 100.0);
  metrics.lastbar_x = metrics.width - sub;
  return changed;
}
