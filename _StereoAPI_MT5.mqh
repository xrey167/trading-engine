  PIVOT_TIME_INTRADAY = 1,
  PIVOT_TIME_PREVDAY = 2,
  PIVOT_TIME_INTRAWEEK = 3,
  PIVOT_TIME_PREVWEEK = 4,
  PIVOT_TIME_INTRAMONTH = 5,
  PIVOT_TIME_PREVMONTH = 6,
  PIVOT_TIME_PREVHOUR = 7,
};
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
class CBar {
public:
  double             open;
  double             close;
  double             high;
  double             low;
  long               realvolume;
  long               tickvolume;
  datetime           time;
  datetime           timeend;
  double             gap;
  int                year;
  int                month;
  int                day;
  int                hour;
  int                minute;
  int                second;
  int                dayofweek;
  int                dayofyear;
  MqlDateTime        t;
protected:
  ENUM_CANDLE_BASE   m_base;
  ENUM_TIMEFRAMES    m_timeframe;
  string             m_symbolname;
  int                m_gmth;
public:
                     CBar(string symbolname = NULL, ENUM_TIMEFRAMES timeframe = WRONG_VALUE, ENUM_CANDLE_BASE base = CANDLE_BASE_HILO, int gmth = 0) {
    if(timeframe == WRONG_VALUE)
      timeframe = __Chart.TimeFrame();
    m_timeframe = timeframe;
    if(symbolname == NULL)
      symbolname = Symbol();
    m_symbolname = symbolname;
    m_base = base;
    m_gmth = gmth;
  }
                     CBar(CBar*bar) {
    Update(bar);
  }
  void               operator=(CBar*src) {
    Update(src);
  }
  void               operator=(CBar&src) {
    Update(src);
  }
  bool               GMTShift(int hours) {
    m_gmth = hours;
    return true;
  }
  int                GMTShift(void) {
    return m_gmth;
  }
  bool               TimeFrame(ENUM_TIMEFRAMES tf) {
    m_timeframe = tf == WRONG_VALUE ? __TIMEFRAME : tf;
    return true;
  }
  ENUM_TIMEFRAMES    TimeFrame(void) {
    return m_timeframe;
  }
  int                TimeFrameSeconds(ENUM_TIMEFRAMES tf = WRONG_VALUE) {
    return tf == WRONG_VALUE ? (PeriodSeconds(m_timeframe)) : (PeriodSeconds(tf));
  }
  int                TimeFrameMinutes(ENUM_TIMEFRAMES tf = WRONG_VALUE) {
    return TimeFrameSeconds(tf) * 60;
  }
  bool               Update(double c, double o, double h, double l, datetime dattim, long tickvol, long realvol, double g) {
    this.open = o;
    this.close = c;
    this.high = h;
    this.low = l;
    this.time = dattim;
    this.timeend = dattim + (m_timeframe * 60) + 60;
    this.tickvolume = tickvol;
    this.realvolume = realvol;
    if(c == 0) {
      this.year = -1;
      this.month = -1;
      this.day = -1;
      this.hour = -1;
      this.minute = -1;
      this.second = -1;
      this.dayofweek = -1;
      this.dayofyear = -1;
      return true;
    }
    TimeToStruct(this.time, t);
    this.gap = g;
    this.year = t.year;
    this.month = t.mon;
    this.day = t.day;
    this.hour = t.hour;
    this.minute = t.min;
    this.second = t.sec;
    this.dayofweek = t.day_of_week;
    this.dayofyear = t.day_of_year;
    return true;
  }
  bool               Init(ENUM_TIMEFRAMES tf) {
    this.m_timeframe = tf;
    return this.Update(PRICE_INVALID, PRICE_INVALID, PRICE_INVALID, PRICE_INVALID, 0, 0, 0, 0);
  }
  bool               Update(CBar&bar) {
    return Update(PTR(bar));
  }
  bool               Update(CBar*bar) {
    if(PTR_INVALID(bar))
      return false;
    return Update(bar.close, bar.open, bar.high, bar.low, bar.time, bar.tickvolume, bar.realvolume, bar.gap);
  }
  string             TimeString(void) {
    string hstr = this.hour < 10 ? "0" + (string)this.hour : (string)this.hour;
    string mstr = this.minute < 10 ? "0" + (string)this.minute : (string)this.minute;
    return hstr + ":" + mstr;
  }
  string             DateString(void) {
    string mstr = this.month < 10 ? "0" + (string)this.month : (string)this.month;
    string dstr = this.day < 10 ? "0" + (string)this.day : (string)this.day;
    return(string)this.year + "." + mstr + "." + dstr;
  }
  string             OHLCString(void) {
    return "O: " + DoubleToString(this.open) +
           " H: " + DoubleToString(this.high) +
           " L: " + DoubleToString(this.low) +
           " C: " + DoubleToString(this.close);
  }
  bool               IsBullish(void) {
    return this.close > this.open;
  }
  bool               IsBearish(void) {
    return this.open > this.close;
  }
  bool               IsDoji(double tolerance = 0) {
    return ABS(this.open - this.close) <= tolerance;
  }
  double             Range(void) {
    return m_base == CANDLE_BASE_HILO ? ABS(this.high - this.low) : ABS(this.open - this.close);
  }
  double             WickRange(void) {
    return this.high - MAX(this.open, this.close);
  }
  double             TailRange(void) {
    return MIN(this.open, this.close) - this.low;
  }
  double             BodyRange(void) {
    return ABS(this.open - this.close);
  }
  double             BodyPart(void) {
    double size = Range();
    if(size == 0)return 0;
    return BodyRange() / size;
  }
  double             TailPart(void) {
    double size = Range();
    if(size == 0)return 0;
    return TailRange() / size;
  }
  double             WickPart(void) {
    double size = Range();
    if(size == 0)return 0;
    return WickRange() / size;
  }
  bool               IsHammer(double tailmin = 0.55) {
    return TailPart() >= tailmin && WickPart() <= TailPart() * 0.5;
  }
  bool               IsShootingStar(double wickmin = 0.55) {
    return WickPart() >= wickmin && TailPart() <= WickPart() * 0.5;
  }
  bool               IsSolid(double wickmax = 0.15, double tailmax = 0.15) {
    return(TailPart() <= tailmax && WickPart() <= wickmax);
  }
  bool               IsSolidBullish(double wickmax = 0.15) {
    return this.IsBullish() && WickPart() <= wickmax;
  }
  bool               IsSolidBearish(double tailmax = 0.15) {
    return this.IsBearish() && TailPart() <= tailmax;
  }
  bool               IsBreaking(double price) {
    return((this.open > price && this.close < price) || (this.open < price && this.close > price));
  }
  bool               IsBreakingLong(double price, double exceed = 0) {
    return(this.open < price && this.close > price && this.close > price + exceed);
  }
  bool               IsBreakingShort(double price, double exceed = 0) {
    return(this.open > price && this.close < price && this.close < price - exceed);
  }
  bool               IsCrossing(double price) {
    return((this.high >= price && this.low <= price));
  }
  bool               IsTouchingLow(double price) {
    return(this.low <= price && MIN(this.open, this.close) >= price);
  }
  bool               IsTouchingHigh(double price) {
    return(this.high >= price && MAX(this.open, this.close) <= price);
  }
  int                MinuteOfDay(void) {
    return(this.hour * 60) + this.minute;
  }
  int                SecondOfDay(void) {
    return(this.hour * 60 * 60) + (this.minute * 60) + this.second;
  }
  bool               IsInTimeRange(int beginh, int beginm, int endh, int endm) {
    int begintime = (beginh * 60) + beginm;
    int endtime = (endh * 60) + endm;
    int curtime = (this.hour * 60) + this.minute;
    if(endh < beginh) {
      endtime += 1440;
      if(this.hour < beginh)
        curtime += 1440;
    }
    return(curtime >= begintime && curtime <= endtime);
  }
  int                TimeCompareToLocal(int hr, int mn = WRONG_VALUE) {
    int h = this.hour;
    h -= m_gmth;
    if(h > 23)
      h -= 24;
    else if(h < 0)
      h += 24;
    if(h < hr)return 1;
    if(h > hr)return 1;
    if(mn == WRONG_VALUE)return 0;
    if(this.minute < mn)return -1;
    if(this.minute > mn)return +1;
    return 0;
  }
  int                TimeCompareToLocal(datetime dt) {
    MqlDateTime dts;
    TimeToStruct(dt, dts);
    return TimeCompareToLocal(dts.hour, dts.min);
  }
  double             FiboPrice(double levelmult) {
    return this.low + (Range() * levelmult);
  }
  double             PivotPrice(ENUM_PIVOT_POINT p) {
    if(m_base == CANDLE_BASE_HILO)
      return __Bars.PivotPrice(this.low, this.high, this.close, p);
    return __Bars.PivotPrice(MIN(this.open, this.close), MAX(this.open, this.close), this.close, p);
  }
};
#define SHIFTADJUST(shiftvalue) shiftvalue+m_defaultbarshift+m_offset
#define SHIFTUNADJUST(shiftvalue) shiftvalue-m_defaultbarshift-m_offset
#define INDEX(shiftvalue) Count()-m_offset-m_defaultbarshift-shiftvalue
class _CBarsGeneric {
protected:
  int                m_digits;
  int                m_gmth;
  int                m_defaultbarshift;
  int                m_offset;
private:
  int                m_currentbarindex;
  CBar               m_bar;
private:
  int                m_lastbars;
  int                m_lastshift;
protected:
  ENUM_TRUERANGE_MODE m_tr_mode;
  string             m_symbolname;
  ENUM_TIMEFRAMES    m_timeframe;
  ENUM_CANDLE_BASE   m_candlebase;
  bool               m_custom;
  CBar               m_rates[];
  int                m_ratescount;
  bool               m_apimode;
  CIndicatorValueBuffers m_ind_buffers;
  bool               m_resetbuffersontfchange;
  int                m_timebegin_hh;
  int                m_timebegin_mm;
  int                m_timeend_hh;
  int                m_timeend_mm;
  bool               m_forcerequest;
public:
                     _CBarsGeneric(ENUM_TIMEFRAMES timeframe = PERIOD_CURRENT, string symbolname = NULL, int gmth = 0) {
    _Init(timeframe, symbolname, gmth);
    DayProfile(-1, -1, -1, -1);
  }
                    ~_CBarsGeneric() {
    m_ind_buffers.DeleteAll();
  }
protected:
  void               _Init(ENUM_TIMEFRAMES timeframe = PERIOD_CURRENT, string symbolname = NULL, int gmth = 0) {
    m_defaultbarshift = 0;
    m_offset = 0;
    m_digits = 2;
    m_gmth = 0;
    if(timeframe == WRONG_VALUE)
      timeframe = __TIMEFRAME;
    m_timeframe = timeframe;
    if(symbolname == NULL)
      m_symbolname = __SYMBOLNAME;
    else
      m_symbolname = symbolname;
    m_custom = false;
    m_ratescount = 0;
    m_apimode = false;
    m_forcerequest = false;
    m_candlebase = CANDLE_BASE_HILO;
    m_currentbarindex = -1;
    m_tr_mode = TRUERANGE_MODE_NONE;
    m_bar.GMTShift(gmth);
    m_resetbuffersontfchange = false;
    Reset();
  }
public:
  void               _APIMode(int count) {
    m_apimode = true;
    m_ratescount = count;
  }
  void               ForceRequest(bool flag) {
    m_forcerequest = flag;
  }
  bool               GMTShift(int hours) {
    m_gmth = hours;
    return m_bar.GMTShift(m_gmth);
  }
  int                GMTShift(void) {
    return m_gmth;
  }
  bool               Digits(int digits) {
    m_digits = digits;
    return true;
  }
  int                Digits(void) {
    return m_digits;
  }
  bool               SetDefaultBarShift(int shift) {
    m_defaultbarshift = shift;
    Reset();
    return true;
  }
  int                DefaultBarShift(void) {
    return m_defaultbarshift;
  }
  int                Shift(void) {
    return SHIFTADJUST(0);
  }
  int                ShiftToIndex(int shift) {
    shift = SHIFTADJUST(shift);
    return Count() - shift - 1;
  }
  bool               _Offset(int pos) {
    m_offset = pos;
    InvalidateBuffer();
    return true;
  }
  int                _Offset() {
    return m_offset;
  }
  bool               Reset(bool reset_indicatorbuffers = true) {
    InvalidateBuffer();
    if(reset_indicatorbuffers)
      m_ind_buffers.Reset();
    m_ind_buffers.SymbolNameGlobal(m_symbolname);
    m_ind_buffers.TimeFrameGlobal(m_timeframe);
    return true;
  }
protected:
  virtual bool       OnSetOffset(void) {
    return true;
  }
  virtual bool       OnReset(void) {
    return true;
  }
  virtual bool       OnSetGMTShift(void) {
    return true;
  }
public:
  int                Count(void) {
    if(m_custom || m_apimode)
      return m_ratescount;
    return::Bars(m_symbolname, m_timeframe);
  }
  bool               CandleCalcBase(ENUM_CANDLE_BASE base) {
    m_candlebase = base;
    return true;
  }
  ENUM_CANDLE_BASE   CandleBase(void) {
    return m_candlebase;
  }
  int                TimeFrameSeconds(ENUM_TIMEFRAMES tf = WRONG_VALUE) {
    return tf == WRONG_VALUE ? (PeriodSeconds(m_timeframe)) : (PeriodSeconds(tf));
  }
  int                TimeFrameMinutes(ENUM_TIMEFRAMES tf = WRONG_VALUE) {
    return TimeFrameSeconds(tf) / 60;
  }
  datetime           NormalizeTime(datetime time) {
    long timen = (long)time;
    long zfu638707147322097067 = (long)TimeFrameSeconds();
    timen = (long)MathRound(timen / zfu638707147322097067) * zfu638707147322097067;
    return(datetime)timen;
  }
  bool               SymbolName(string name) {
    if(name == m_symbolname)return true;
    m_symbolname = name;
    Reset();
    return true;
  }
  string             SymbolName(void) {
    return m_symbolname;
  }
  bool               TrueRangeMode(ENUM_TRUERANGE_MODE flag) {
    m_tr_mode = flag;
    return true;
  }
  ENUM_TRUERANGE_MODE TrueRangeMode(void) {
    return m_tr_mode;
  }
  int                _GetShiftSync(int shift) {
    return SHIFTADJUST(shift);
  }
  void               InvalidateBuffer(void) {
    m_lastbars = -1;
    m_lastshift = -1;
  }
  void               DayProfile(int timebeginhh, int timebeginmm, int timeendhh, int timeendmm) {
    m_timebegin_hh = timebeginhh;
    m_timebegin_mm = timebeginmm;
    m_timeend_hh = timeendhh;
    m_timeend_mm = timeendmm;
  }
  bool               Add(CBar&bar) {
    if(!m_custom)
      return false;
    m_ratescount++;
    if(ArraySize(m_rates) < m_ratescount)
      ArrayResize(m_rates, m_ratescount + 64);
    return m_rates[m_ratescount - 1].Update(bar);
  }
  bool               Update(CBar&bar, int shift = 0) {
    if(!m_custom)
      return false;
    int i = m_ratescount - shift - 1;
    if(i < 0)
      return false;
    return m_rates[i].Update(bar);
  }
  bool               Add(double close, double open, double high, double low, datetime time, long tickvolume, long volume, double gap) {
    if(!m_custom)
      return false;
    m_ratescount++;
    if(ArraySize(m_rates) < m_ratescount)
      ArrayResize(m_rates, m_ratescount + 64);
    return m_rates[m_ratescount - 1].Update(close, open, high, low, time, tickvolume, volume, gap);
  }
  bool               Update(double close, double open, double high, double low, datetime time, long tickvolume, long volume, double gap, int shift = 0) {
    if(!m_custom)
      return false;
    int i = m_ratescount - shift - 1;
    if(i < 0)
      return false;
    return m_rates[i].Update(close, open, high, low, time, tickvolume, volume, gap);
  }
public:
  double             Open(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.open;
  }
  double             Open(datetime t) {
    UpdateCurrentBar(t);
    return m_bar.open;
  }
  double             Close(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.close;
  }
  double             Close(datetime t) {
    UpdateCurrentBar(t);
    return m_bar.close;
  }
  double             Low(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_candlebase == CANDLE_BASE_HILO ? m_bar.low : MIN(m_bar.open, m_bar.close);
  }
  double             Low(datetime t) {
    UpdateCurrentBar(t);
    return m_candlebase == CANDLE_BASE_HILO ? m_bar.low : MIN(m_bar.open, m_bar.close);
  }
  double             High(int shift = 0) {
    UpdateCurrentBar(shift);
    return m_candlebase == CANDLE_BASE_HILO ? m_bar.high : MAX(m_bar.open, m_bar.close);
  }
  double             High(datetime t) {
    UpdateCurrentBar(t);
    return m_candlebase == CANDLE_BASE_HILO ? m_bar.high : MIN(m_bar.open, m_bar.close);
  }
  int                Year(int shift = 0) {
