class CVObject: public _CVObject {
protected:
  CVObject*m_parent;
  CObjectList        m_controls;
public:
                     CVObject() {
    m_classname = "CVObject";
    m_parent = NULL;
    m_controls.DeleteOnDestruct(true);
  }
public:
  void               SetParent(_CVObject*parent) {
    m_parent = parent;
  }
public:
  void               ResetParent() {
    m_parent = NULL;
  }
public:
  void               _RemoveFromParent() {
    if(PTR_VALID(m_parent))m_parent.Remove(PTR(this));
  }
public:
                     _CVObject*GetParent() {
    return m_parent;
  }
public:
  bool               Add(CVObject&control) {
    return Add(PTR(control));
  }
public:
  bool               Add(CVObject*control) {
    if(!PTR_VALID(control))
      return false;
    control.SetParent(PTR(this));
    return m_controls.Add(control) >= 0;
  }
public:
  bool               Remove(CVObject&control) {
    return Remove(PTR(control));
  }
public:
  bool               Remove(CVObject*control) {
    if(!PTR_VALID(control))
      return false;
    control.ResetParent();
    return true;
  }
};
class CVObjectGeneric: public CVObject {
protected:
  ENUM_OBJECT        m_typeobject;
  bool               m_nodelete;
  int                m_displaystate;
public:
                     CVObjectGeneric() {
    m_classname = "CVObjectGeneric";
    m_nodelete = false;
    m_typeobject = WRONG_VALUE;
  }
public:
                    ~CVObjectGeneric() {
    Destroy();
    m_name = NULL;
  }
  virtual            CVObject*GetContainingObject(const int x, const int y) {
    return NULL;
  }
  bool               Background(void) {
    return((__MT_Object_GetFlags(m_chart_id, m_name)&MT_OBJ_BACKGROUND) > 0);
  };
  bool               Background(const bool flag) {
    uint flags = __MT_Object_GetFlags(m_chart_id, m_name);
    if(flag)
      flags |= MT_OBJ_BACKGROUND;
    else
      flags &= (0xFFFF - MT_OBJ_BACKGROUND);
    return __MT_Object_SetFlags(m_chart_id, m_name, flags);
  }
  bool               ShowInList(void) {
    return((__MT_Object_GetFlags(m_chart_id, m_name)&MT_OBJ_HIDDEN) <= 0);
  };
  bool               ShowInList(const bool flag) {
    uint flags = __MT_Object_GetFlags(m_chart_id, m_name);
    if(!flag)
      flags |= MT_OBJ_HIDDEN;
    else
      flags &= (0xFFFF - MT_OBJ_HIDDEN);
    return __MT_Object_SetFlags(m_chart_id, m_name, flags);
  }
  bool               Selectable(void) {
    return((__MT_Object_GetFlags(m_chart_id, m_name)&MT_OBJ_SELECTABLE) > 0);
  };
  bool               Selectable(const bool flag) {
    uint flags = __MT_Object_GetFlags(m_chart_id, m_name);
    if(flag)
      flags |= MT_OBJ_SELECTABLE;
    else
      flags &= (0xFFFF - MT_OBJ_SELECTABLE);
    return __MT_Object_SetFlags(m_chart_id, m_name, flags);
  }
  long               Z_Order(void) {
    return __MT_Object_GetZOrder(m_chart_id, m_name);
  }
  bool               Z_Order(const long value) {
    return __MT_Object_SetZOrder(m_chart_id, m_name, value);
  }
public:
  bool               AssignChartObject(string name, long chartid = 0) {
    retf_if(m_created);
    if(chartid == 0) {
      m_subwin = __Chart.FindObjectSubWin(name);
      chartid = __Chart.ChartId();
    } else {
      CChartExt chart;
      chart.Attach(chartid);
      m_subwin = chart.FindObjectSubWin(name);
      chart.Detach();
    }
    if(m_subwin < 0)
      return false;
    m_name = name;
    m_chart_id = chartid;
    m_visible = __MT_Object_IsVisible(chartid, name);
    m_visibility = __MT_Object_GetTimeFrames(m_chart_id, name);
    m_typeobject = (ENUM_OBJECT)__MT_Object_GetType(m_chart_id, name);
    m_id_create = __vo_create_id++;
    m_enabled = true;
    m_created = true;
    if(m_parent == NULL)
      ResetParent();
    return OnAssignChartObject();
  }
public:
  bool               AssignChartObject(CVObjectGeneric*object) {
    retf_if(m_created);
    m_name = object.Name();
    m_chart_id = object.ChartID();
    m_visible = object.IsVisible();
    m_visibility = object.Visibility();
    m_typeobject = (ENUM_OBJECT)object.TypeObject();
    m_id_create = __vo_create_id++;
    m_enabled = true;
    m_created = true;
    if(m_parent == NULL)
      ResetParent();
    return OnAssignChartObject();
  }
public:
  bool               UnAssign(void) {
    retf_if(!m_created);
    _RemoveFromParent();
    __MT_Object_SetTimeFrames(m_chart_id, m_name, m_visibility);
    m_name = NULL;
    m_chart_id = NULL;
    m_subwin = -1;
    m_created = false;
    m_visible = false;
    m_enabled = false;
    m_activated = false;
    return OnUnAssignChartObject();
  }
public:
  bool               UnDeleteable(void) {
    return m_nodelete;
  }
public:
  bool               UnDeleteable(bool flag) {
    m_nodelete = flag;
    return true;
  }
public:
  ENUM_OBJECT        TypeObject(void) {
    return m_typeobject;
  }
public:
  bool               TypeObject(ENUM_OBJECT type) {
    m_typeobject = type;
    return true;
  }
protected:
  virtual bool       OnAssignChartObject(void) {
    return true;
  }
protected:
  virtual bool       OnUnAssignChartObject(void) {
    return true;
  }
protected:
  virtual bool       OnSetVisibility(void) {
    rett_if(m_name == NULL || !m_visible);
    return __MT_Object_SetTimeFrames(m_chart_id, m_name, m_visibility) && __Chart.Invalidate();
  }
protected:
  virtual bool       OnCreate() {
    OnSetVisibility();
    return CVObject::OnCreate();
  }
protected:
  virtual bool       OnHide(void) {
    __MT_Object_SetVisible(m_chart_id, m_name, false);
    return CVObject::OnHide();
  }
protected:
  virtual bool       OnShow(void) {
    __MT_Object_SetVisible(m_chart_id, m_name, false);
    __MT_Object_SetTimeFrames(m_chart_id, m_name, m_visibility);
    return CVObject::OnShow();
  }
protected:
  virtual bool       CcDestroy() {
    if(!m_nodelete)__MT_Object_Delete(m_chart_id, m_name);
    return CVObject::CcDestroy();
  }
public:
  bool               IsTypeWnd(void) {
    if(m_typeobject == OBJ_LABEL || m_typeobject == OBJ_BITMAP_LABEL || m_typeobject == OBJ_EDIT || m_typeobject == OBJ_CHART || m_typeobject == OBJ_RECTANGLE_LABEL)
      return true;
    return false;
  }
};
enum ENUM_WND_ALIGN_FLAGS {
  WND_ALIGN_NONE = 0,
  WND_ALIGN_LEFT = 1,
  WND_ALIGN_TOP = 2,
  WND_ALIGN_RIGHT = 4,
  WND_ALIGN_BOTTOM = 8,
  WND_ALIGN_WIDTH = WND_ALIGN_LEFT | WND_ALIGN_RIGHT,
  WND_ALIGN_HEIGHT = WND_ALIGN_TOP | WND_ALIGN_BOTTOM,
  WND_ALIGN_CLIENT = WND_ALIGN_WIDTH | WND_ALIGN_HEIGHT
};
