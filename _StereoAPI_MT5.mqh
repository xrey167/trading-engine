    return::user32::GetParent(m_hwndchart);
  }
private:
  int                _FindChartWindow(int hwnd = 0) {
    static HWND hwndsearch = 0;
    if(hwnd == 0) {
      hwndsearch = 0;
      m_hwndmt =::user32::GetForegroundWindow();
      hwnd =::user32::GetWindow(m_hwndmt, GW_CHILD);
    }
    HWND hwndthis =::user32::GetWindow(hwnd, GW_HWNDFIRST);
    while(hwndthis != 0) {
      string classname = User32_GetClassName(hwndthis);
      if(classname == "AfxFrameOrView140su") {
        hwndsearch = hwndthis;
        return hwndsearch;
      }
      HWND hwndchild =::user32::GetWindow(hwndthis, GW_CHILD);
      if(hwndchild != 0) {
        _FindChartWindow(hwndchild);
        if(hwndsearch != 0)
          return hwndsearch;
      }
      HWND hwndnext =::user32::GetWindow(hwndthis, GW_HWNDNEXT);
      if(hwndnext == hwndthis)
        break;
      hwndthis = hwndnext;
    }
    return 0;
  }
public:
  bool               SetTitle(string title, bool addsymbolname = true) {
    if(addsymbolname) {
      if(title != NULL)
        title = __SYMBOLNAME + " | " + TimeFrameName() + " | " + title;
      else
        title = __SYMBOLNAME + " | " + TimeFrameName();
    }
    return(bool)::user32::SetWindowTextW(HwndWindow(), title);
  }
