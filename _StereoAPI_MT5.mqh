  }
  if(__MT_Object_XY_hiddencreate)
    result &= __MT_Object_SetVisible(chartid, name, false);
  result &= __MT_Object_SetFlags(chartid, name, MT_OBJ_HIDDEN);
  result &= ObjectSetInteger(chartid, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
  result &= ObjectSetInteger(chartid, name, OBJPROP_XDISTANCE, x1);
  result &= ObjectSetInteger(chartid, name, OBJPROP_YDISTANCE, y1);
  result &= __MT_Object_SetToolTip(chartid, name, "\n");
  if(x2 > x1 && y2 > y1) {
    ObjectSetInteger(chartid, name, OBJPROP_XSIZE, x2 - x1 + 1);
    ObjectSetInteger(chartid, name, OBJPROP_YSIZE, y2 - y1 + 1);
  }
  return result;
}
