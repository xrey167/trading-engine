protected:
  string             ReplaceTextMarcos(string msg) {
    msg = _StringReplace(msg, "%productname", m_name);
    msg = _StringReplace(msg, "%name", m_name);
    msg = _StringReplace(msg, "%build", (string)m_build);
    msg = _StringReplace(msg, "%version", m_version);
    msg = _StringReplace(msg, "%homepage", m_homepage);
    msg = _StringReplace(msg, "%1", m_homepage);
    msg = _StringReplace(msg, "%edition", m_edition);
    msg = _StringReplace(msg, "%license", m_keys);
    return msg;
  }
public:
  string             GetSettingsFileName(uint flags = APP_SETTINGSFILE_STD, string strategyname = NULL, bool isactive = false, string suffix = ".set") {
    if(flags == 0)return NULL;
    string name = "";
    if(IS_BITSET(flags, APP_SETTINGSFILE_NAME))name = m_internalname;
    if(IS_BITSET(flags, APP_SETTINGSFILE_MTVERSION))name += "5";
    if(IS_BITSET(flags, APP_SETTINGSFILE_ACCOUNT))name += "_" + __Account.Company() + "_" + __Account.NumberStr();
    if(IS_BITSET(flags, APP_SETTINGSFILE_SYMBOL))name += "_" + __Symbol.Name();
    if(IS_BITSET(flags, APP_SETTINGSFILE_TRADING)) {
      if(isactive)name += "_A";
      else name += "_P";
    }
    if(IS_BITSET(flags, APP_SETTINGSFILE_STRATEGY)) {
      if(strategyname != NULL)name += "_" + strategyname;
    }
    if(IS_BITSET(flags, APP_SETTINGSFILE_TIMEFRAME))name += "_" + __Chart.TimeFrameName();
    name = _StringClean(name);
    return name + suffix;
  }
};
