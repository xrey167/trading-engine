datetime _TimeShift(datetime t, ENUM_TIME_COMPONENT component, int value) {
  MqlDateTime dt;
  TimeToStruct(t, dt);
  switch(component) {
  case TIME_COMPONENT_YEAR:
    return t + (value * 60 * 60 * 24 * 365);
  case TIME_COMPONENT_MONTH:
    if(value < 0) {
      value = 0 - value;
      while(value > 12) {
        dt.year--;
        value -= 12;
      }
      if(dt.mon - value < 1) {
        dt.year--;
        dt.mon += (12 - value);
      } else
        dt.mon -= value;
    } else {
      while(value > 12) {
        dt.year++;
        value -= 12;
      }
      if(dt.mon + value > 12) {
        dt.year++;
        dt.mon -= (12 - value);
      } else
        dt.mon += value;
    }
    return StructToTime(dt);
  case TIME_COMPONENT_DAY:
    return t + (value * 60 * 60 * 24);
  case TIME_COMPONENT_HOUR:
    return t + (value * 60 * 60);
  case TIME_COMPONENT_MINUTE:
    return t + (value * 60);
  case TIME_COMPONENT_SECOND:
    return t + value;
  }
  return t;
}
