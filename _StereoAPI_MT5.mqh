        return false;
      m_closebutton.Show();
    }
    CWndContainer::Add(m_closebutton);
    if(atbutton) {
      if(!m_activity.Create(m_chart_id, __RNDID, m_subwin, gap, gap + w + gap, w + gap, m_rect.Height() - gap))
        return false;
      CWndContainer::Add(m_activity);
      m_activity.Show();
    }
    return true;
