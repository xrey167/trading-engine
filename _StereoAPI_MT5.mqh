      rect[0].top = 0;
      rect[0].right = width / 3 * 2;
      rect[0].bottom = height;
      rect[1].left = width / 3 * 2;
      rect[1].top = 0;
      rect[1].right = width;
      rect[1].bottom = height / 2;
      rect[2].left = width / 3 * 2;
      rect[2].top = height / 2;
      rect[2].right = width;
      rect[2].bottom = height;
      break;
    case 4:
      rect[0].left = 0;
      rect[0].top = 0;
      rect[0].right = width / 2;
      rect[0].bottom = height;
      rect[1].left = width / 2;
      rect[1].top = 0;
      rect[1].right = width / 4 * 3;
      rect[1].bottom = height / 2;
      rect[2].left = width / 4 * 3;
      rect[2].top = 0;
      rect[2].right = width;
      rect[2].bottom = height / 2;
      rect[3].left = width / 2;
      rect[3].top = height / 2;
      rect[3].right = width;
      rect[3].bottom = height;
      break;
    case 5:
      rect[0].left = 0;
      rect[0].top = 0;
      rect[0].right = width / 2;
      rect[0].bottom = height;
      rect[1].left = width / 4 * 2;
      rect[1].top = 0;
      rect[1].right = width / 4 * 3;
      rect[1].bottom = height / 2;
      rect[2].left = width / 4 * 3;
      rect[2].top = 0;
      rect[2].right = width;
      rect[2].bottom = height / 2;
      rect[3].left = width / 4 * 2;
      rect[3].top = height / 2;
      rect[3].right = width / 4 * 3;
      rect[3].bottom = height;
      rect[4].left = width / 4 * 3;
      rect[4].top = height / 2;
      rect[4].right = width;
      rect[4].bottom = height;
      break;
    case 6:
      rect[0].left = 0;
      rect[0].top = 0;
      rect[0].right = width / 2;
      rect[0].bottom = height;
      rect[1].left = width / 6 * 3;
      rect[1].top = 0;
      rect[1].right = width / 6 * 4;
      rect[1].bottom = height / 2;
      rect[2].left = width / 6 * 4;
      rect[2].top = 0;
      rect[2].right = width / 6 * 5;
      rect[2].bottom = height / 2;
      rect[3].left = width / 6 * 5;
      rect[3].top = 0;
