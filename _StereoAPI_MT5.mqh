  }
  bool               IsTouchingHigh(double price, int shift = 0) {
    UpdateCurrentBar(shift);
    return m_bar.IsTouchingHigh(price);
  }
  bool               IsSolid(int shift = 0, double wickmax = 0.15, double tailmax = 0.15) {
