public:
  void               CFileBase() {
    m_handle = INVALID_HANDLE;
    m_name = NULL;
    m_read = true;
    m_write = true;
    m_shared = true;
    m_common = false;
    m_ansi = true;
    m_utf8 = false;
    m_ignoreexistance = true;
    m_mode = 0;
    m_flags = 0;
    m_openflags = 0;
    m_redirect_localtocommon = false;
    m_use_mt_bug_workaround = true;
    m_reseek = -1;
  }
public:
  void              ~CFileBase() {
    this.Close();
  }
public:
  bool               Open(string filename, uint flags) {
    if(!Name(filename))return false;
    Flags(flags);
    return Open();
  }
public:
  bool               Open(string filename, bool commonfolder) {
    if(!Name(filename))return false;
    FlagCommon(commonfolder);
    return Open();
  }
public:
  bool               Open(string filename) {
    if(!Name(filename))return false;
    return Open();
  }
public:
  bool               Open(void) {
    if(m_handle != INVALID_HANDLE)
      this.Close();
    string filename = GetFileName();
    if(!m_ignoreexistance) {
      if(!IsExist())return false;
    }
    if(m_mode == 0)
      return false;
    _BuildFlags();
    m_openflags = m_mode | m_flags;
    if(m_utf8)
      m_handle =::FileOpen(filename, m_openflags, (ushort)0, CP_UTF8);
    else
      m_handle =::FileOpen(filename, m_openflags);
    _Seek(0);
    if(m_handle == INVALID_HANDLE)
      return false;
    OnOpen();
    return true;
  }
public:
  bool               OpenRW(string filename = NULL, bool shared = false, bool commonfolder = false, bool ignoreexistance = true, bool redirect_localtocommon = false) {
    if(filename == NULL)
      filename = m_name;
    if(!Name(filename))
      return false;
    FlagRead(true);
    FlagWrite(true);
    FlagShared(shared);
    FlagCommon(commonfolder);
    FlagRedirectLocalToCommon(redirect_localtocommon);
    FlagIgnoreExistance(ignoreexistance);
    return CFileBase::Open();
  }
private:
  string             GetFileName() {
    if(!m_redirect_localtocommon || m_common)
      return m_name;
    string directory, filename;
    if(!_FileNameSplit(m_name, directory, filename)) {
      DEBUG_BREAK_("Filename could not be split");
      return NULL;
    }
    return directory + "\\" + __Terminal.DataId() + "\\" + filename;
  }
