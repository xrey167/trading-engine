bool __MT_Object_Line_CreateV(long chartid, string name, int subwin, datetime dt, uint flags = MT_OBJ_HIDDEN | MT_OBJ_BACKGROUND) {
  if(chartid == NULL)chartid = __CHARTID;
  bool result = ObjectCreate(chartid, name, OBJ_VLINE, subwin, __Time.LocalToChart(dt), 0.0);
  if(__MT_Object_TP_hiddencreate)
    result &= __MT_Object_SetVisible(chartid, name, false);
  result &= __MT_Object_TP_SetFlags(chartid, name, flags);
  return result;
