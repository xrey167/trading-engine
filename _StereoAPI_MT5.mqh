//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool __MT_Object_Line_CreateTrend(long chartid, string name, int subwin,
                                  const datetime time1, const double price1,
                                  const datetime time2, const double price2, uint flags = MT_OBJ_HIDDEN | MT_OBJ_BACKGROUND) {
  if(chartid == NULL)chartid = __CHARTID;
  datetime t1 = time1;
  bool rayL = false;
  if(time1 == 0) {
    t1 = __Time.Current() - 86400;
    rayL = true;
  }
  bool result = ObjectCreate(chartid, name, OBJ_TREND, subwin, __Time.LocalToChart(t1), price1, __Time.LocalToChart(time2), price2)&
                __MT_Object_TP_SetFlags(chartid, name, flags);
  if(__MT_Object_TP_hiddencreate)
    __MT_Object_SetVisible(chartid, name, false);
  if(result)
    __MT_Object_Line_SetRayL(chartid, name, rayL);
  return result;
}
