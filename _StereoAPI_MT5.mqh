//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
CWndContainer::CWndContainer(void) {
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
CWndContainer::~CWndContainer(void) {
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::OnDestroy() {
  int total = m_controls.Total();
  for(int i = 0; i < total; i++) {
    CWnd*control = Control(0);
    if(control == NULL)
      continue;
    control.Destroy();
    m_controls.Delete(0);
  }
  return CWnd::OnDestroy();
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Add(CWnd*control) {
  if(control == NULL)
    return(false);
  control.Shift(Left(), Top());
  if(IsVisible() && control.IsVisible()) {
    control.Visible(Contains(control));
  } else
    control.Hide();
  if(IsEnabled())
    control.Enable();
  else
    control.Disable();
  return CVObject::Add(control);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Add(CWnd&control) {
  return(Add((CWnd*)GetPointer(control)));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Delete(CWnd*control) {
  if(control == NULL)
    return(false);
  FOREACH_VAR_IN(CVObject*, child, m_controls) {
    if(child == control)
      return(m_controls.Delete(child));
  }
  return(false);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Delete(CWnd&control) {
  return(Delete((CWnd*)GetPointer(control)));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Move(const int x, const int y) {
  return(Shift(x - Left(), y - Top()));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Move(const CPoint&point) {
  return(Shift(point.x - Left(), point.y - Top()));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Shift(const int dx, const int dy) {
  if(!CWnd::Shift(dx, dy))return(false);
  FOREACH_VAR_IN(CVObject*, child, m_controls) {
    CWnd*wnd = child;
    wnd.Shift(dx, dy);
  }
  return(true);
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Enable(const bool flag = true) {
  FOREACH_VAR_IN(CVObject*, child, m_controls)
  child.Enable(flag);
  return(CWnd::Enable(flag));
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Disable(void) {
  FOREACH_VAR_IN(CVObject*, child, m_controls)
  child.Disable();
  return(CWnd::Disable());
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Show(void) {
  m_visible = true;
  FOREACH_VAR_IN(CVObject*, child, m_controls)
  child.Show();
  return CWnd::Show();
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::Hide(void) {
  FOREACH_VAR_IN(CVObject*, child, m_controls)
  child.Hide();
  return(CWnd::Hide());
}
//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CWndContainer::OnResize() {
  FOREACH_VAR_IN(CWnd*, child, m_controls) {
    if(!child.Align(Rect()))
      return(false);
  }
  return(true);
}
