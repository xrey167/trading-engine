double __GetBuffer(int handle, int index, int shift, bool wait = false) {
  if(handle == INVALID_HANDLE)
    return 0;
  static double buf[1];
  if(::CopyBuffer(handle, index, shift, 1, buf) > 0)
    return(buf[0]);
  if(!wait)
    return 0;
  ::Sleep(50);
  for(int i = 0; i < 100; i++) {
    if(::BarsCalculated(handle) > 0)
      break;
    ::Sleep(50);
  }
  if(::CopyBuffer(handle, index, shift, 1, buf) > 0)
    return(buf[0]);
  return 0;
}
