      rect[6].left = width / 6 * 5;
      rect[6].top = height / 2;
      rect[6].right = width / 6 * 6;
      rect[6].bottom = height / 2;
      break;
    }
    chart.FirstChart();
    cnt = 0;
    int i = 0;
    while(chart.ChartId() != INVALID_CHART) {
      if(chart.IsVisible()) {
        chart.Restore();
        if(chart.ChartId() == chartbiggest)
          chart.Move(rect[0].left, rect[0].top, rect[0].Width(), rect[0].Height());
        else {
          i++;
          chart.Move(rect[i].left, rect[i].top, rect[i].Width(), rect[i].Height());
        }
      }
      chart.NextChart();
    }
  }
public:
  void               Lock() {
    if(m_locked)return;
    m_locked = true;
    ::ChartSetInteger(m_chart_id, CHART_MOUSE_SCROLL, false);
  }
public:
  void               UnLock() {
    if(!m_locked)return;
    m_locked = false;
    ::ChartSetInteger(m_chart_id, CHART_MOUSE_SCROLL, true);
  }
private:
  int                m_chartevent_test_counter;
protected:
  virtual void       OnEATimer(CEATimerParams*zfu638707147322097061) {
    if(IsStopped())
      return;
    m_chartevent_test_counter++;
    if(m_chartevent_test_counter < 20)return;
    m_chartevent_test_counter = 0;
    bool fire = false;
    PROFILE_TIME_START
    static double lastpricemax = PriceMax(0);
    if(!ScaleFix()) {
      double pm = __MT_GetChartPriceMax(m_chart_id, m_subwin);
      PROFILE_TIME_SHOW("Chart MaxPrice checked");
      if(pm != lastpricemax) {
        lastpricemax = pm;
        fire = true;
        UpdateMetrics();
      }
    }
    if(fire)
      FireEventChartChange();
  }
public:
  void               _Detach() {
    m_chart_id = INVALID_CHART;
    CChartExt::Detach();
  }
public:
  bool               Invalidate() {
    m_valid_chart = false;
    return true;
  }
public:
  void               Validate() {
    if(m_valid_chart)return;
    m_valid_chart = true;
    CChartBase::Redraw();
  }
public:
  bool               _IsValid() {
    return m_valid_chart;
  }
public:
  void               Redraw(void) {
    static bool displayed = false;
    if(!displayed)
      if(IS_DEBUG_MODE)
        Print("Do not call __Chart.Redraw() - use __Chart.Invalidate()");
    displayed = true;
    return;
  }
};
